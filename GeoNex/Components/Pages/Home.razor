            <button @onclick="AproximarCamada">Aproximar à Camada</button>

            @if (CamadasAtivas.FirstOrDefault(c => c.Nome == camadaSelecionadaMenu)?.Tipo == "Vetor")
            {
                <button @onclick="() => { FecharMenuContexto(); AbrirTabela(camadaSelecionadaMenu); }">Tabela de Atributos</button>
                <button @onclick="() => { FecharMenuContexto(); AbrirPropriedadesCamada(camadaSelecionadaMenu); }">Propriedades e Estilos</button>
            }

            <button @onclick="FecharMenuContexto">Renomear</button>

            <hr class="menu-divider" />

            <!-- NOVOS CONTROLES DE HIERARQUIA -->
            <button @onclick="() => MoverCamada(camadaSelecionadaMenu, -1)">Mover para Cima</button>
            <button @onclick="() => MoverCamada(camadaSelecionadaMenu, 1)">Mover para Baixo</button>

            <hr class="menu-divider" />

            <button @onclick="PrepararRemocaoCamada" class="btn-danger">Remover Camada</button>
        </div>
    }
    <!-- MODAL DE INJEÇÃO DE COORDENADAS TOPOGRÁFICAS -->
    <!-- MODAL DE INJEÇÃO DE COORDENADAS (CADERNETA DE CAMPO) -->
    <!-- MODAL DE INJEÇÃO DE COORDENADAS (CADERNETA DE CAMPO) -->
    <!-- MODAL DE INJEÇÃO DE COORDENADAS (CADERNETA DE CAMPO) -->
    @if (exibirModalCoordenadas)
    {
        <div class="modal-overlay">
            <div class="glass-panel" style="width: 550px; display: flex; flex-direction: column;">
                <div class="modal-header">
                    <h2>CADERNETA DE CAMPO DIGITAL</h2>
                    <button class="close-btn" @onclick="() => exibirModalCoordenadas = false">✕</button>
                </div>

                <!-- CORREÇÃO 1: height: auto e max-height para evitar que o conteúdo vaze -->
                <div class="modal-body custom-scrollbar" style="height: auto; max-height: 65vh; padding: 20px; display: flex; flex-direction: column; gap: 15px; overflow-y: auto;">

                    <!-- CONFIGURAÇÕES DE SISTEMA -->
                    <div class="form-row">
                        <div class="form-group-vertical">
                            <label>SISTEMA (CRS)</label>
                            <select class="glass-input" @bind="sistemaCoordenadas">
                                <option value="DECIMAL">Geográfica Decimal (WGS 84)</option>
                                <option value="UTM">UTM (SIRGAS 2000)</option>
                            </select>
                        </div>
                        <div class="form-group-vertical">
                            <label>GEOMETRIA ALVO</label>
                            <select class="glass-input" @bind="tipoGeometriaAlvo">
                                <option value="POLIGONO">Polígono (Área)</option>
                                <option value="LINHA">Linha / Eixo</option>
                                <option value="PONTOS">Pontos Individuais</option>
                            </select>
                        </div>
                    </div>

                    <!-- CONFIGURAÇÕES ESPECÍFICAS E MÉTODO DE ENTRADA -->
                    <div class="form-row" style="margin-top: 10px;">
                        @if (sistemaCoordenadas == "UTM")
                        {
                            <div class="form-group-vertical">
                                <label>FUSO / ZONA UTM (Ex: 22S)</label>
                                <input type="text" class="glass-input" @bind="zonaUtm" placeholder="Ex: 22S" />
                            </div>
                        }

                        <!-- Se não for UTM, este select ocupa a largura toda da grelha -->
                        <div class="form-group-vertical" style="@(sistemaCoordenadas != "UTM" ? "grid-column: span 2;" : "")">
                            <label>MÉTODO DE ENTRADA</label>
                            <select class="glass-input" @bind="metodoEntrada">
                                <option value="COORDENADA">Coordenadas Absolutas (X, Y)</option>
                                @if (sistemaCoordenadas == "UTM")
                                {
                                    <option value="AZIMUTE">Azimute e Distância (A partir do anterior)</option>
                                }
                            </select>
                        </div>
                    </div>

                    @if (sistemaCoordenadas == "UTM")
                    {
                        <div class="form-group-vertical">
                            <label>FUSO / ZONA UTM (Ex: 22S)</label>
                            <input type="text" class="glass-input" @bind="zonaUtm" placeholder="Ex: 22S" />
                        </div>
                    }

                    <hr style="border: none; border-top: 1px solid rgba(255,255,255,0.1); margin: 5px 0;" />

                    <!-- ENTRADA DOS DADOS -->
                    <div class="form-row" style="align-items: flex-end;">
                        <div class="form-group-vertical" style="flex: 0.3;">
