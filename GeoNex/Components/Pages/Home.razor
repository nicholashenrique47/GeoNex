    private double ParseAzimute(string azimuteText)
    {
        var clean = azimuteText.Replace("°", " ").Replace("'", " ").Replace("\"", " ").Trim();
        var parts = clean.Split(new[] { ' ' }, StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 1) return double.Parse(parts[0], System.Globalization.CultureInfo.InvariantCulture);
        double graus = parts.Length > 0 ? double.Parse(parts[0]) : 0;
        double minutos = parts.Length > 1 ? double.Parse(parts[1]) : 0;
        double segundos = parts.Length > 2 ? double.Parse(parts[2], System.Globalization.CultureInfo.InvariantCulture) : 0;
        return graus + (minutos / 60.0) + (segundos / 3600.0);
    }

    private async Task AdicionarPontoCaderneta()
    {
        if (string.IsNullOrWhiteSpace(novoNomePonto) || string.IsNullOrWhiteSpace(novaCoordenadaPonto)) return;
        var partes = novaCoordenadaPonto.Split(new[] { ',', ';' }, StringSplitOptions.RemoveEmptyEntries);
        if (partes.Length >= 2)
        {
            string valorX = "", valorY = "";
            if (metodoEntrada == "COORDENADA") { valorX = partes[0].Trim(); valorY = partes[1].Trim(); }
            else if (metodoEntrada == "AZIMUTE")
            {
                if (listaPontosCaderneta.Count == 0) { await JSRuntime.InvokeVoidAsync("alert", "O Ponto 1 de partida precisa ser uma COORDENADA absoluta."); return; }
                try
                {
                    double azimuteDecimal = ParseAzimute(partes[0]);
                    double distancia = double.Parse(partes[1].Trim(), System.Globalization.CultureInfo.InvariantCulture);
                    double azimuteRadianos = azimuteDecimal * (Math.PI / 180.0);
                    var pAnt = listaPontosCaderneta.Last();
                    double xA = double.Parse(pAnt["Coord1"], System.Globalization.CultureInfo.InvariantCulture);
                    double yA = double.Parse(pAnt["Coord2"], System.Globalization.CultureInfo.InvariantCulture);
                    double novoX = xA + (distancia * Math.Sin(azimuteRadianos)); double novoY = yA + (distancia * Math.Cos(azimuteRadianos));
                    valorX = novoX.ToString("0.000", System.Globalization.CultureInfo.InvariantCulture); valorY = novoY.ToString("0.000", System.Globalization.CultureInfo.InvariantCulture);
                }
                catch { await JSRuntime.InvokeVoidAsync("alert", "Erro nos parâmetros de irradiação."); return; }
            }
            listaPontosCaderneta.Add(new Dictionary<string, string> { { "Nome", novoNomePonto.Trim() }, { "Coord1", valorX }, { "Coord2", valorY } });
            contadorPontos++; novoNomePonto = $"P{contadorPontos}"; novaCoordenadaPonto = "";
        }
        else { await JSRuntime.InvokeVoidAsync("alert", "Delimite as coordenadas usando vírgulas."); }
    }

    private void RemoverPontoCaderneta(Dictionary<string, string> ponto) { listaPontosCaderneta.Remove(ponto); }

    private async Task ProcessarCadernetaDeCampo()
    {
        try
        {
            if (listaPontosCaderneta.Count == 0) return;
            if (!CamadasAtivas.Any(c => c.Nome == camadaAquisicaoAtual)) CamadasAtivas.Add(new Camada { Nome = camadaAquisicaoAtual, Tipo = "Vetor", Visivel = true });
            var pontosProcessados = new List<Dictionary<string, string>>();
            ProjNet.CoordinateSystems.Transformations.ICoordinateTransformation conversorUtm = null;
            if (sistemaCoordenadas == "UTM")
            {
                int zona = int.Parse(new String(zonaUtm.Where(char.IsDigit).ToArray()));
                bool isNorte = zonaUtm.ToUpper().Contains("N");
                conversorUtm = new ProjNet.CoordinateSystems.Transformations.CoordinateTransformationFactory().CreateFromCoordinateSystems(ProjNet.CoordinateSystems.ProjectedCoordinateSystem.WGS84_UTM(zona, isNorte), ProjNet.CoordinateSystems.GeographicCoordinateSystem.WGS84);
            }
            foreach (var ptOriginal in listaPontosCaderneta)
            {
                string nomePonto = ptOriginal["Nome"];
                double valor1 = double.Parse(ptOriginal["Coord1"], System.Globalization.CultureInfo.InvariantCulture);
                double valor2 = double.Parse(ptOriginal["Coord2"], System.Globalization.CultureInfo.InvariantCulture);
                double lat, lng;
                if (sistemaCoordenadas == "UTM")
                {
                    double[] geog = conversorUtm.MathTransform.Transform(new double[] { valor1, valor2 });
                    lng = geog[0]; lat = geog[1];
                }
                else { lat = valor1; lng = valor2; }
                pontosProcessados.Add(new Dictionary<string, string> { { "Nome", nomePonto }, { "Lat", lat.ToString(System.Globalization.CultureInfo.InvariantCulture) }, { "Lng", lng.ToString(System.Globalization.CultureInfo.InvariantCulture) } });
            }
            string jsonPontos = System.Text.Json.JsonSerializer.Serialize(pontosProcessados);
            await JSRuntime.InvokeVoidAsync("desenharAquisicaoAvancada", camadaAquisicaoAtual, jsonPontos, tipoGeometriaAlvo);
            exibirModalCoordenadas = false; listaPontosCaderneta.Clear(); contadorPontos = 1; novoNomePonto = "P1"; StateHasChanged();
        }
        catch (Exception ex) { await JSRuntime.InvokeVoidAsync("alert", $"Erro topográfico: {ex.Message}"); }
    }

