    private async Task RenderizarFrameOffScreen()
    {
        // Se a CPU já estiver a renderizar um frame, ignora o evento para manter fluidez
        if (_isRendering) return;
        _isRendering = true;

        try
        {
            // 1. Cria a tela virtual com a resolução EXATA do navegador (Fim das distorções!)
            int width = _larguraTela > 0 ? _larguraTela : 1920;
            int height = _alturaTela > 0 ? _alturaTela : 1080;

            var info = new SKImageInfo(width, height);
            using var surface = SKSurface.Create(info);
            var canvas = surface.Canvas;

            // Limpa o fundo com a cor base da interface
            canvas.Clear(new SKColor(22, 25, 33));


            canvas.Save();

            // 1. Descobre a Bounding Box combinando a Imagem e os Vetores
            SKRect limitesTotais = new SKRect();
            bool primeiro = true;

            // Inclui a Ortofoto no cálculo
            if (MapService.TemRaster)
            {
                limitesTotais = MapService.LimitesRasterGlobal;
                primeiro = false;
            }

            foreach (var path in MapService.PathsCompilados)
            {
                if (primeiro) { limitesTotais = path.Bounds; primeiro = false; }
                else { limitesTotais.Union(path.Bounds); }
            }

            if (!limitesTotais.IsEmpty)
            {
                float escalaX = width / limitesTotais.Width;
                float escalaY = height / limitesTotais.Height;
                float escalaAutoFit = Math.Min(escalaX, escalaY) * 0.8f;

                // GERA A MATRIZ DE TRANSFORMAÇÃO E GUARDA-A NA MEMÓRIA
                _matrizAtual = SKMatrix.CreateTranslation(-limitesTotais.MidX, -limitesTotais.MidY);
                _matrizAtual = _matrizAtual.PostConcat(SKMatrix.CreateScale(escalaAutoFit * MapService.CameraZoom, escalaAutoFit * MapService.CameraZoom));
                _matrizAtual = _matrizAtual.PostConcat(SKMatrix.CreateTranslation(width / 2f + MapService.CameraPanX, height / 2f + MapService.CameraPanY));

                // INJETA NA GPU
                canvas.SetMatrix(_matrizAtual);

                // --- 1º DESENHA A ORTOFOTO (COM A BOUNDING BOX DO RECORTE ATUAL) ---
                if (MapService.TemRaster)
                {
                    using var paintRaster = new SKPaint { FilterQuality = SKFilterQuality.High };
                    canvas.DrawBitmap(MapService.RasterAtivo, MapService.LimitesRasterDesenho, paintRaster);
                }

                // --- 2º DESENHA OS VETORES ---
                _pincelBorda.StrokeWidth = 1f / (escalaAutoFit * MapService.CameraZoom);

                foreach (var path in MapService.PathsCompilados)
                {
                    canvas.DrawPath(path, _pincelFill);
                    canvas.DrawPath(path, _pincelBorda);
                }
            }

            canvas.Restore(); // Fecha o estado matricial

            // 2. Extrai o frame da memória (Formato PNG sem perdas - ideal para vetores GIS)
            // No final do RenderizarFrameOffScreen (perto do Passo 2)
            using var image = surface.Snapshot();
            using var pixmap = image.PeekPixels();
            using var ms = new System.IO.MemoryStream();

            // Renderiza o painel final em JPEG de alta qualidade
            pixmap.Encode(ms, SkiaSharp.SKEncodedImageFormat.Jpeg, 90);

            string base64 = Convert.ToBase64String(ms.ToArray());
            
           

            // 3. Envia o binário diretamente para a interface web através do IPC
            await JSRuntime.InvokeVoidAsync("atualizarFundoSkia", base64);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erro crítico no motor off-screen: {ex.Message}");
        }
        finally
        {
            _isRendering = false;
        }
    
    }

