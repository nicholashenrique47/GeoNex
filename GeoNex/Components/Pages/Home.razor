    private DateTime _ultimoMovimentoMouse = DateTime.MinValue;
    private DateTime _ultimaAtualizacaoUI = DateTime.MinValue;

    private bool _isPanning = false;

    private string EstiloCursor =>
        _isPanning ? "grabbing" :
        (_ferramentaAtiva == ModoFerramenta.Navegacao ? "grab" :
         (_ferramentaAtiva == ModoFerramenta.Medicao || _ferramentaAtiva == ModoFerramenta.AquisicaoPoligono ? "crosshair" : "default"));
    private void ProcessarPressionarMouse(Microsoft.AspNetCore.Components.Web.PointerEventArgs e)
    {
        // GATILHO TÁTICO: Clique Direito durante a vetorização
        if (e.Button == 2 && _ferramentaAtiva == ModoFerramenta.AquisicaoPoligono)
        {
            _menuContextoX = e.ClientX;
            _menuContextoY = e.ClientY;
            _mostrarMenuContexto = true;
            _mostrarInputCogo = false;
            return;
        }

        // Se clicou com o esquerdo noutro local e o menu estava aberto, fecha-o
        if (e.Button == 0 && _mostrarMenuContexto)
        {
            _mostrarMenuContexto = false;
            _mostrarInputCogo = false;
        }

        if (e.Button == 1 || (e.Button == 0 && _ferramentaAtiva == ModoFerramenta.Navegacao))
        {
            _isPanning = true;
            MapService.IsPanning = true;
            return;
        }

        if (e.Button == 0 && _ferramentaAtiva != ModoFerramenta.Navegacao)
        {
            _ = ProcessarCliqueRaycast(e.OffsetX, e.OffsetY);
        }
    }

    private void ProcessarMovimentoMouse(Microsoft.AspNetCore.Components.Web.PointerEventArgs e)
    {
        // 1. CONGELAMENTO ESTRITO DA ÂNCORA (Zero lógica de arrasto aqui)
        if (_mostrarInputCogo == false && _mostrarInputAbsoluto == false && _mostrarMenuContexto == false)
        {
            _hudX = e.ClientX + 15;
            _hudY = e.ClientY;
        }

        // 2. FÍSICA DO MAPA (PAN E SNAP)
        if (_isPanning) return;
        if (_ferramentaAtiva == ModoFerramenta.Medicao || _ferramentaAtiva == ModoFerramenta.AquisicaoPoligono)
        {
            // OTIMIZAÇÃO: Limita o processamento a 30 FPS para salvar a GPU
            if ((DateTime.Now - _ultimoMovimentoMouse).TotalMilliseconds < 33) return;
            _ultimoMovimentoMouse = DateTime.Now;
            var matriz = ObterMatrizMatematica();
            if (matriz.TryInvert(out var matrizInversa))
            {
                var ptMundo = matrizInversa.MapPoint(new SkiaSharp.SKPoint((float)e.OffsetX, (float)e.OffsetY));

                // 1. A MATEMÁTICA DA RESTRIÇÃO DOMINA PRIMEIRO
                // 1. A MATEMÁTICA DA RESTRIÇÃO DOMINA PRIMEIRO
                // 2. A MATEMÁTICA DE RESTRIÇÃO DOMINA O FLUXO
                if (_ferramentaAtiva == ModoFerramenta.AquisicaoPoligono && _travaDistanciaAtiva && _travaDistanciaValor > 0 && MapService.PontosAquisicao.Count > 0)
                {
                    var ultimoPonto = MapService.PontosAquisicao.Last();

                    double dx = ptMundo.X - ultimoPonto.X;
                    double dy = ptMundo.Y - ultimoPonto.Y;

                    double distanciaRato = Math.Sqrt(dx * dx + dy * dy);
                    double anguloRadianos = Math.Atan2(dy, dx);

                    // SE FOR MODO FIXO *OU* SE O RATO TENTAR PASSAR DO LIMITE MÁXIMO
                    if (_travaModoFixo || distanciaRato > _travaDistanciaValor)
                    {
                        ptMundo = new SkiaSharp.SKPoint(
                            (float)(ultimoPonto.X + Math.Cos(anguloRadianos) * _travaDistanciaValor),
                            (float)(ultimoPonto.Y + Math.Sin(anguloRadianos) * _travaDistanciaValor)
                        );
                    }

                    MapService.PontoCursorMundo = ptMundo;
                    MapService.PontoCursorSnap = null;

                    SolicitarNovoFrame();
                    return;
                }

                // 2. SE A TRAVA ESTIVER DESLIGADA, O FLUXO CONTINUA NORMALMENTE:
                MapService.PontoCursorMundo = ptMundo;
                bool usarSnap = false;
                bool checarVertices = false;
                bool checarArestas = false;

                if (_ferramentaAtiva == ModoFerramenta.Medicao && _snapMedicaoAtivo)
                {
                    usarSnap = true;
                    checarVertices = true;
                    checarArestas = false;
                }
                else if (_ferramentaAtiva == ModoFerramenta.AquisicaoPoligono)
                {
                    if (_snapAquisicaoVertice || _snapAquisicaoAresta)
                    {
                        usarSnap = true;
                        checarVertices = _snapAquisicaoVertice;
                        checarArestas = _snapAquisicaoAresta;
                    }
                }

                if (usarSnap)
                {
                    var ptMagnetico = MapService.EncontrarVerticeProximo(ptMundo, 15.0f / matriz.ScaleX, checarVertices, checarArestas);
                    if (ptMagnetico.HasValue)
                    {
                        MapService.PontoCursorSnap = ptMagnetico.Value;
                        MapService.PontoCursorMundo = ptMagnetico.Value;
                    }
                    else { MapService.PontoCursorSnap = null; }
                }
                else { MapService.PontoCursorSnap = null; }

                // LÓGICA INTELIGENTE DE RENDERIZAÇÃO
                bool precisaRedesenhar = false;
                bool precisaAtualizarHTML = false;

                if (_ferramentaAtiva == ModoFerramenta.Medicao && MapService.PontosMedicao.Count > 0)
                {
                    RecalcularMedicoes();
                    precisaRedesenhar = true;
                    precisaAtualizarHTML = true; // A interface HTML precisa de atualizar os números na régua!
                }

                if (_ferramentaAtiva == ModoFerramenta.AquisicaoPoligono && MapService.PontosAquisicao.Count > 0)
                {
                    precisaRedesenhar = true;
                }

                if (!Nullable.Equals(MapService.PontoCursorSnap, _ultimoSnapRenderizado))
                {
                    precisaRedesenhar = true;
                    _ultimoSnapRenderizado = MapService.PontoCursorSnap;
                }

                if (precisaRedesenhar)
                {
                    SolicitarNovoFrame();
                    if (precisaAtualizarHTML) InvokeAsync(StateHasChanged);
                }
            }
        }
    }

