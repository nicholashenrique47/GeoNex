    private void SincronizarHierarquia()
    {
        MapService.OrdemCamadas.Clear();

        // O Filtro Absoluto: Só injeta na Placa Gráfica se o ícone do olho estiver ligado
        for (int i = CamadasAtivas.Count - 1; i >= 0; i--)
        {
            if (CamadasAtivas[i].Visivel)
            {
                MapService.OrdemCamadas.Add(CamadasAtivas[i].Nome);
            }
        }

        // Proteção contra Seleção Fantasma:
        // Apaga o lote amarelo e limpa o painel se a camada que o contém for ocultada
        if (!string.IsNullOrEmpty(camadaSelecionadaPainel))
        {
            var camadaSel = CamadasAtivas.FirstOrDefault(c => c.Nome == camadaSelecionadaPainel);
            if (camadaSel != null && !camadaSel.Visivel)
            {
                MapService.DestacarFeicao(null);
                camadaSelecionadaPainel = string.Empty;
                atributosFeicaoSelecionada?.Clear();
            }
        }

        SolicitarNovoFrame();
    }
    [JSInvokable]
    public async Task ProcessarCliqueRaycast(double telaX, double telaY)
    {
        SkiaSharp.SKRect limitesTotais = new SkiaSharp.SKRect();
        bool primeiro = true;

        if (MapService.TemRaster) { limitesTotais = MapService.LimitesRasterGlobal; primeiro = false; }

        foreach (var path in MapService.VetoresPorCamada.Values) { if (primeiro) { limitesTotais = path.Bounds; primeiro = false; } else { limitesTotais.Union(path.Bounds); } }
        foreach (var path in MapService.LinhasPorCamada.Values) { if (primeiro) { limitesTotais = path.Bounds; primeiro = false; } else { limitesTotais.Union(path.Bounds); } }
        foreach (var path in MapService.PontosPorCamada.Values) { if (primeiro) { limitesTotais = path.Bounds; primeiro = false; } else { limitesTotais.Union(path.Bounds); } }

        if (!limitesTotais.IsEmpty)
        {
            float escalaX = _larguraTela / limitesTotais.Width;
            float escalaY = _alturaTela / limitesTotais.Height;
            float escalaAutoFit = Math.Min(escalaX, escalaY) * 0.8f;

            var matriz = SkiaSharp.SKMatrix.CreateTranslation(-limitesTotais.MidX, -limitesTotais.MidY);
            matriz = matriz.PostConcat(SkiaSharp.SKMatrix.CreateScale(escalaAutoFit * MapService.CameraZoom, escalaAutoFit * MapService.CameraZoom));
            matriz = matriz.PostConcat(SkiaSharp.SKMatrix.CreateTranslation(_larguraTela / 2f + MapService.CameraPanX, _alturaTela / 2f + MapService.CameraPanY));

            if (matriz.TryInvert(out var matrizInversa))
            {
                var ptMundo = matrizInversa.MapPoint(new SkiaSharp.SKPoint((float)telaX, (float)telaY));

                double xMundo = ptMundo.X + MapService.OffsetMundoX;
                double yMundo = (-ptMundo.Y) + MapService.OffsetMundoY;

                // MÁQUINA DE ESTADOS DO CLIQUE COORDENADO
                switch (_ferramentaAtiva)
                {
                    case ModoFerramenta.Identificacao:
                        double tolerancia = 5.0 / (escalaAutoFit * MapService.CameraZoom);
                        var feicao = MapService.DispararRaycast(yMundo, xMundo, tolerancia, out string camadaAtingida);

                        MapService.DestacarFeicao(feicao);

                        if (feicao != null)
                        {
                            camadaSelecionadaPainel = camadaAtingida;
                            atributosFeicaoSelecionada = new Dictionary<string, string>();

                            if (feicao.Attributes != null)
                            {
                                foreach (var nomeCampo in feicao.Attributes.GetNames())
                                {
                                    var valor = feicao.Attributes[nomeCampo];
                                    atributosFeicaoSelecionada[nomeCampo] = valor?.ToString() ?? string.Empty;
                                }
                            }
                        }
                        else
                        {
                            camadaSelecionadaPainel = string.Empty;
                            atributosFeicaoSelecionada?.Clear();
                        }

                        SolicitarNovoFrame(); // Identificação exige re-renderizar do servidor para destacar polígono
                        break;

                    case ModoFerramenta.Medicao:
                        var ptFinal = ptMundo;

                        if (_snapMedicaoAtivo)
                        {
                            float toleranciaSnap = (float)(15.0 / (escalaAutoFit * MapService.CameraZoom));
                            var ptMagnetico = MapService.EncontrarVerticeProximo(ptMundo, toleranciaSnap);
                            if (ptMagnetico.HasValue)
                            {
                                ptFinal = ptMagnetico.Value;
                            }
                        }

                        MapService.PontosMedicao.Add(ptFinal);
                        RecalcularMedicoes();

                        // Atualização local imediata do desenho no frontend canvas
                        await AtualizarCanvasOverlayLocal();
                        break;

                    case ModoFerramenta.AquisicaoPoligono:
                        break;

                    case ModoFerramenta.Navegacao:
                        break;
                }

                await InvokeAsync(StateHasChanged);
            }
        }
    }
