    // Memória da Caderneta
    private List<Dictionary<string, string>> listaPontosCaderneta = new List<Dictionary<string, string>>();

    // Função 1: Adiciona o ponto digitado à lista visual
    // Variável nova de controle
    private string metodoEntrada = "COORDENADA";

    // Função auxiliar para interpretar qualquer formato de Azimute digitado
    private double ParseAzimute(string azimuteText)
    {
        // Limpa os símbolos clássicos de graus
        var clean = azimuteText.Replace("°", " ").Replace("'", " ").Replace("\"", " ").Trim();
        var parts = clean.Split(new[] { ' ' }, StringSplitOptions.RemoveEmptyEntries);

        if (parts.Length == 1) return double.Parse(parts[0], System.Globalization.CultureInfo.InvariantCulture);

        double graus = parts.Length > 0 ? double.Parse(parts[0]) : 0;
        double minutos = parts.Length > 1 ? double.Parse(parts[1]) : 0;
        double segundos = parts.Length > 2 ? double.Parse(parts[2], System.Globalization.CultureInfo.InvariantCulture) : 0;

        return graus + (minutos / 60.0) + (segundos / 3600.0);
    }

    private async Task AdicionarPontoCaderneta()
    {
        if (string.IsNullOrWhiteSpace(novoNomePonto) || string.IsNullOrWhiteSpace(novaCoordenadaPonto)) return;

        var partes = novaCoordenadaPonto.Split(new[] { ',', ';' }, StringSplitOptions.RemoveEmptyEntries);

        if (partes.Length >= 2)
        {
            string valorX = "";
            string valorY = "";

            if (metodoEntrada == "COORDENADA")
            {
                // Leitura Normal Absoluta
                valorX = partes[0].Trim();
                valorY = partes[1].Trim();
            }
            else if (metodoEntrada == "AZIMUTE")
            {
                // Regra topográfica: O primeiro ponto tem de estar ancorado no planeta Terra
                if (listaPontosCaderneta.Count == 0)
                {
                    await JSRuntime.InvokeVoidAsync("alert", "O Ponto 1 de partida precisa ser uma COORDENADA absoluta. Adicione o primeiro ponto e depois mude para Azimute.");
                    return;
                }

                try
                {
                    // Lógica de Irradiação / Caminhamento
                    double azimuteDecimal = ParseAzimute(partes[0]);
                    double distancia = double.Parse(partes[1].Trim(), System.Globalization.CultureInfo.InvariantCulture);

                    // Converte Azimute para Radianos (Em topografia, 0° é o Norte e gira no sentido horário)
                    double azimuteRadianos = azimuteDecimal * (Math.PI / 180.0);

                    // Pega o ponto anterior da lista para servir de Estação base
                    var pontoAnterior = listaPontosCaderneta.Last();
                    double xAnterior = double.Parse(pontoAnterior["Coord1"], System.Globalization.CultureInfo.InvariantCulture);
                    double yAnterior = double.Parse(pontoAnterior["Coord2"], System.Globalization.CultureInfo.InvariantCulture);

                    // Trigonomentria: Seno para Leste(X) e Cosseno para Norte(Y)
                    double novoX = xAnterior + (distancia * Math.Sin(azimuteRadianos));
                    double novoY = yAnterior + (distancia * Math.Cos(azimuteRadianos));

                    // Arredonda para milímetros (3 casas decimais)
                    valorX = novoX.ToString("0.000", System.Globalization.CultureInfo.InvariantCulture);
                    valorY = novoY.ToString("0.000", System.Globalization.CultureInfo.InvariantCulture);
                }
                catch
                {
                    await JSRuntime.InvokeVoidAsync("alert", "Falha ao calcular Azimute/Distância. Verifique a sintaxe.");
                    return;
                }
            }

            listaPontosCaderneta.Add(new Dictionary<string, string>
            {
                { "Nome", novoNomePonto.Trim() },
                { "Coord1", valorX },
                { "Coord2", valorY }
            });

            contadorPontos++;
            novoNomePonto = $"P{contadorPontos}";
            novaCoordenadaPonto = "";
        }
        else
        {
            await JSRuntime.InvokeVoidAsync("alert", "Formato inválido. Use a vírgula para separar.");
        }
    }

    // Função 2: Remove um ponto da lista caso o usuário erre
    private void RemoverPontoCaderneta(Dictionary<string, string> ponto)
    {
        listaPontosCaderneta.Remove(ponto);
    }

    // Função 3: Manda a lista inteira para o motor de desenho
    // Função 3: Motor Avançado de Conversão e Processamento
    private async Task ProcessarCadernetaDeCampo()
    {
        try
        {
            if (listaPontosCaderneta.Count == 0)
            {
                await JSRuntime.InvokeVoidAsync("alert", "A caderneta está vazia. Adicione pelo menos um ponto.");
                return;
            }

            if (!CamadasAtivas.Any(c => c.Nome == camadaAquisicaoAtual))
            {
                CamadasAtivas.Add(new Camada { Nome = camadaAquisicaoAtual, Tipo = "Vetor", Visivel = true });
            }

            var pontosProcessados = new List<Dictionary<string, string>>();
            ICoordinateTransformation conversorUtm = null;

            // PREPARA O CONVERSOR PROJNET SE FOR UTM
            if (sistemaCoordenadas == "UTM")
            {
                // Extrai o número da zona (Ex: "22S" -> 22)
                int zona = int.Parse(new String(zonaUtm.Where(char.IsDigit).ToArray()));
                // Determina o hemisfério (Se tem 'N' é Norte, senão é Sul)
                bool isNorte = zonaUtm.ToUpper().Contains("N");

                // Configura as matrizes matemáticas de origem e destino
                var sistemaUTM = ProjectedCoordinateSystem.WGS84_UTM(zona, isNorte);
                var sistemaGeografico = GeographicCoordinateSystem.WGS84;
                var factory = new CoordinateTransformationFactory();

                conversorUtm = factory.CreateFromCoordinateSystems(sistemaUTM, sistemaGeografico);
            }

            // VARRE TODOS OS PONTOS DA LISTA E FAZ A CONVERSÃO
            foreach (var ptOriginal in listaPontosCaderneta)
            {
                string nomePonto = ptOriginal["Nome"];
                double valor1 = double.Parse(ptOriginal["Coord1"], System.Globalization.CultureInfo.InvariantCulture);
                double valor2 = double.Parse(ptOriginal["Coord2"], System.Globalization.CultureInfo.InvariantCulture);

                double lat, lng;

                if (sistemaCoordenadas == "UTM")
                {
                    // A matemática acontece aqui! O ProjNet recebe {X, Y} e devolve {Lng, Lat}
                    double[] coordenadasLidas = new double[] { valor1, valor2 };
                    double[] coordenadasGeograficas = conversorUtm.MathTransform.Transform(coordenadasLidas);

                    lng = coordenadasGeograficas[0]; // O eixo X global é a Longitude
                    lat = coordenadasGeograficas[1]; // O eixo Y global é a Latitude
                }
                else
                {
                    // Se já era Decimal, o usuário digitou Lat, Lng
                    lat = valor1;
                    lng = valor2;
                }

                pontosProcessados.Add(new Dictionary<string, string>
                {
                    { "Nome", nomePonto },
                    { "Lat", lat.ToString(System.Globalization.CultureInfo.InvariantCulture) },
                    { "Lng", lng.ToString(System.Globalization.CultureInfo.InvariantCulture) }
                });
            }

            // Envia para o JavaScript desenhar
            string jsonPontos = System.Text.Json.JsonSerializer.Serialize(pontosProcessados);
            await JSRuntime.InvokeVoidAsync("desenharAquisicaoAvancada", camadaAquisicaoAtual, jsonPontos, tipoGeometriaAlvo);

            // Sucesso! Limpa a interface
            exibirModalCoordenadas = false;
            listaPontosCaderneta.Clear();
            contadorPontos = 1;
            novoNomePonto = "P1";
            StateHasChanged();
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", $"Erro fatal na conversão matemática.\nVerifique se as coordenadas UTM e a Zona estão corretas.\nDetalhe: {ex.Message}");
        }
    }
    // ==========================================
    // GESTOR DE ESTADO DE EDIÇÃO (TRANSAÇÕES)
    // ==========================================
    private bool temEdicoesPendentes = false;

    // O JS chama isto a cada vértice movido, mas AGORA NÃO SALVA direto no disco, apenas na "Memória Temporária"
    [JSInvokable]
    public async Task AtualizarGeometriaNoServidor(string nomeCamada, string propriedadesJson, string novaGeometriaJson)
    {
        // 1. Acende o alerta amarelo na interface!
        temEdicoesPendentes = true;

        var props = System.Text.Json.JsonSerializer.Deserialize<Dictionary<string, System.Text.Json.JsonElement>>(propriedadesJson);
        string idFeicao = (props != null && (props.ContainsKey("FID") || props.ContainsKey("ID")))
            ? (props.ContainsKey("FID") ? props["FID"].ToString() : props["ID"].ToString())
            : "Desconhecido";

        // 2. Coloca na "Fila de Modificações" (Log no Console para já)
        Console.WriteLine($"[MODIFICAÇÃO PENDENTE] Camada: {nomeCamada} | Lote: {idFeicao}");

        // Força o botão de salvar a acender na barra
        await InvokeAsync(StateHasChanged);
    }

    // O Engenheiro clica no botão 💾 "Salvar Edições"
    private async Task ConfirmarTodasEdicoes()
    {
        if (!temEdicoesPendentes) return;

        try
        {
            // ONDE A MÁGICA REAL ACONTECE:
            // Aqui, no futuro, pegamos na fila de modificações e fazemos um UPDATE em massa no SQLite ou reescrevemos o Shapefile.

            // Simulação de tempo de gravação
            await Task.Delay(500);

            // Dá o feedback de segurança ao engenheiro
            await JSRuntime.InvokeVoidAsync("alert", "EDIÇÕES CONSOLIDADAS!\n\nTodas as modificações de malha e vértices foram gravadas permanentemente no banco de dados.");

            // Apaga o alerta amarelo e desliga o modo de edição para proteger o mapa
            temEdicoesPendentes = false;

            if (modoEdicaoVerticeLigado)
            {
                await AlternarEdicaoVertices(); // Desliga as bolinhas brancas
            }

            StateHasChanged();
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", $"Falha ao gravar no disco: {ex.Message}");
        }
    }
