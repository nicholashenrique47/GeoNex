    private async Task AbrirPropriedadesCamada(string nomeCamada)
    {
        // Garante que o menu flutuante desaparece ao abrir as propriedades
        mostrarMenuContexto = false;
        camadaEmEdicao = nomeCamada;
        exibirModalPropriedades = true;
        abaAtivaPropriedades = "Simbologia"; // Inicia sempre na primeira aba

        // Busca as colunas para preencher a caixa de seleção da aba de rótulos
        var camada = CamadasAtivas.FirstOrDefault(c => c.Nome == nomeCamada);
        if (camada != null && !string.IsNullOrEmpty(camada.CaminhoArquivo))
        {
            // Lê o cabeçalho do DBF em background para não congelar a interface
            var resultado = await Task.Run(() => RasterService.ObterAtributosVetor(camada.CaminhoArquivo));

            // Filtramos o "FID" porque ele é uma coluna interna do motor
            colunasDisponiveisRotulo = resultado.Colunas.Where(c => c != "FID").ToList();
        }
        else
        {
            colunasDisponiveisRotulo = new List<string>();
        }

        await InvokeAsync(StateHasChanged);
    }
    private async Task RecarregarOrtofotoAltaResolucao()
    {
        // Só executa se houver uma ortofoto TIF importada e visível
        if (!MapService.TemRaster || string.IsNullOrEmpty(caminhoArquivoRaster)) return;

        try
        {
            // INVERSÃO DA MÁGICA: Pergunta à GPU quais são as coordenadas geográficas visíveis no monitor!
            if (_matrizAtual.TryInvert(out SKMatrix inverse))
            {
                // Mapeia os cantos do monitor (Pixel 0,0 até ao limite HD)
                SKPoint topLeft = inverse.MapPoint(new SKPoint(0, 0));
                SKPoint bottomRight = inverse.MapPoint(new SKPoint(_larguraTela > 0 ? _larguraTela : 1920, _alturaTela > 0 ? _alturaTela : 1080));

                // Descodifica o formato do SkiaSharp (O X é a Longitude e o Y é a Latitude INVERTIDA)
                double minLng = topLeft.X;
                double maxLat = -topLeft.Y;
                double maxLng = bottomRight.X;
                double minLat = -bottomRight.Y;

                // Garante que a orientação está correta
                double realMinLng = Math.Min(minLng, maxLng);
                double realMaxLng = Math.Max(minLng, maxLng);
                double realMinLat = Math.Min(minLat, maxLat);
                double realMaxLat = Math.Max(minLat, maxLat);

                // Vai ao motor GDAL buscar uma fotografia perfeita apenas desta área, a correr numa Thread Paralela (não congela o ecrã)
                string base64AltaQualidade = await Task.Run(() =>
                    RasterService.ObterRecorteDinamico(caminhoArquivoRaster, realMinLat, realMinLng, realMaxLat, realMaxLng, _larguraTela > 0 ? _larguraTela : 1920, _alturaTela > 0 ? _alturaTela : 1080)
                );

                if (!string.IsNullOrEmpty(base64AltaQualidade))
                {
                    byte[] imageBytes = Convert.FromBase64String(base64AltaQualidade);

                    // Altera a textura da placa gráfica silenciosamente
                    MapService.AtualizarRecorteRaster(imageBytes, (float)realMinLng, (float)realMinLat, (float)realMaxLng, (float)realMaxLat);

                    // Reseta o esticamento falso do CSS agora que temos a imagem Real HD
                    _zoomAtualCSS = 1.0f;
                    _arrastoAtualX = 0;
                    _arrastoAtualY = 0;

                    await InvokeAsync(RenderizarFrameOffScreen);
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erro no Zoom Infinito do Raster: {ex.Message}");
        }
    }
    
