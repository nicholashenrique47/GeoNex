    public void TrocarFerramenta(ModoFerramenta novaFerramenta)
    {
        // Impede processamento fantasma se já estiver na mesma ferramenta
        if (_ferramentaAtiva == novaFerramenta) return;

        // 1. Limpeza de Saída
        if (_ferramentaAtiva == ModoFerramenta.Medicao)
        {
            MapService.PontosMedicao.Clear();
            MapService.PontoCursorSnap = null;
            MapService.PontoCursorMundo = null;
            _distanciaTotalMetros = 0;
            _areaTotalM2 = 0;
        }
        else if (_ferramentaAtiva == ModoFerramenta.Identificacao)
        {
            MapService.DestacarFeicao(null);
            camadaSelecionadaPainel = string.Empty;
            atributosFeicaoSelecionada?.Clear();
            _geometriaDestacada = null;
        }
        else if (_ferramentaAtiva == ModoFerramenta.AquisicaoPoligono)
        {
            MapService.PontosAquisicao.Clear();
            MapService.PontoCursorSnap = null;
            MapService.PontoCursorMundo = null;
        }
        else if (_ferramentaAtiva == ModoFerramenta.EdicaoVertice)
        {
            modoEdicaoVerticeLigado = false;
        }

        // 2. Transição de Estado
        _ferramentaAtiva = novaFerramenta;
        if (_ferramentaAtiva == ModoFerramenta.EdicaoVertice)
        {
            modoEdicaoVerticeLigado = true;
        }

        // 3. A MÁGICA: Força a interface a ligar o painel PRIMEIRO, protegendo o HTML de qualquer falha do JS!
        InvokeAsync(StateHasChanged);

        // 4. Fire-and-Forget: Envia a ordem para o JavaScript e para a GPU em pano de fundo
        try
        {
            JSRuntime.InvokeVoidAsyncSafe("mapEngine.setFerramenta", novaFerramenta.ToString()); _ = SincronizarOverlay(false);
            SolicitarNovoFrame();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Aviso JS/Interop: {ex.Message}");
        }
    }
    // =========================================================================
    // 5. EVENTOS DO CICLO DE VIDA DA INTERFACE
