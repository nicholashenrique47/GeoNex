    <!-- ========================================== -->
    <!-- JANELA MODAL DE IMPORTAÇÃO (DATA MANAGER)  -->
    <!-- ========================================== -->
    @if (exibirModalImportacao)
    {
        <div class="modal-overlay">
            <div class="glass-panel import-modal">
                <div class="modal-header">
                    <h2>GERENCIADOR DE FONTES DE DADOS</h2>
                    <button class="close-modal-btn" @onclick="FecharModalImportacao">✕</button>
                </div>
                <div class="modal-body">
                    <div class="modal-tabs">
                        <button class="tab-btn @(AbaModalAtiva == "Raster" ? "active" : "")" @onclick="@(() => TrocarAbaModal("Raster"))">Raster (ECW, TIF)</button>
                        <button class="tab-btn @(AbaModalAtiva == "Vetor" ? "active" : "")" @onclick="@(() => TrocarAbaModal("Vetor"))">Vetor (SHP, GeoJSON)</button>
                        <button class="tab-btn @(AbaModalAtiva == "Texto" ? "active" : "")" @onclick="@(() => TrocarAbaModal("Texto"))">Texto Delimitado</button>
                        <button class="tab-btn @(AbaModalAtiva == "Nuvem" ? "active" : "")" @onclick="@(() => TrocarAbaModal("Nuvem"))">Nuvem (PostGIS)</button>
                    </div>

                    <div class="modal-content">

                        @if (AbaModalAtiva == "Raster")
                        {
                            <div class="form-group mb-15">
                                <label>Arquivo Fonte / Dataset (Raster)</label>
                                <div class="file-input-group">
                                    <input type="text" class="glass-input file-path" value="@caminhoArquivoRaster" placeholder="C:\Caminho\para\arquivo.tif" readonly />
                                    <button class="btn-browse" @onclick="SelecionarArquivoRaster">PROCURAR...</button>
                                </div>
                                <div style="margin-top: 10px; font-size: 0.7rem; color: #34d399; background: rgba(0,0,0,0.2); padding: 10px; border-radius: 4px; border: 1px solid rgba(52,211,153,0.2);">
                                    <pre style="margin:0; white-space: pre-wrap;">@statusGdal</pre>
                                </div>
                            </div>

                            <div class="import-actions">
                                <button class="btn-save add-layer-btn" @onclick="AdicionarCamadaAoMapa">ADICIONAR RASTER AO MAPA</button>
                                <button class="btn-cancel" @onclick="FecharModalImportacao">CANCELAR</button>
                            </div>
                        }
                        else if (AbaModalAtiva == "Vetor")
                        {
                            <div class="form-group mb-15">
                                <label>Arquivo Fonte Vetorial (Shapefile, KML, GeoJSON)</label>
                                <div class="file-input-group">
                                    <input type="text" class="glass-input file-path" value="@caminhoArquivoVetor" placeholder="C:\Caminho\para\lotes.shp" readonly />
                                    <button class="btn-browse" @onclick="SelecionarArquivoVetor">PROCURAR...</button>
                                </div>
                            </div>

                            <div class="form-group mb-15">
                                <label>Sistema de Referência de Coordenadas (CRS/EPSG)</label>
                                <select class="glass-input editable">
                                    <option>Automático (Lido do arquivo .prj)</option>
                                    <option>EPSG:31982 - SIRGAS 2000 / UTM zone 22S</option>
                                    <option>EPSG:4326 - WGS 84</option>
                                </select>
                            </div>

                            <div class="import-actions">
                                <button class="btn-save add-layer-btn" @onclick="AdicionarVetorAoMapa">ADICIONAR VETOR AO MAPA</button>
                                <button class="btn-cancel" @onclick="FecharModalImportacao">CANCELAR</button>
                            </div>
                        }
                        else
                        {
                            <div style="display: flex; height: 100%; align-items: center; justify-content: center; color: #64748b; font-size: 0.85rem;">
                                Módulo em desenvolvimento.
                            </div>
                        }

                    </div>
                </div>
            </div>
        </div>
    }
    @if (exibirModalPropriedades)
    {
        <style>
                /* =======================================================
                       FÍSICA DO DRAG & DROP (MÁXIMA SUAVIDADE E GRIP)
                       ======================================================= */

                .layer-item {
                    /* A branda transição que remove os pulos secos do ecrã */
                    transition: transform 0.2s cubic-bezier(0.2, 0.8, 0.2, 1), box-shadow 0.2s, background-color 0.2s;
                    will-change: transform;
                }

                    /* O Efeito de Levitação Magnética quando o clique é mantido */
                    .layer-item.is-dragging {
                        transform: scale(1.02); /* Aumenta um bocadinho, dando a ilusão que se descolou do fundo */
                        box-shadow: 0 12px 24px rgba(0, 0, 0, 0.6); /* Sombra pesada por baixo */
                        background-color: rgba(30, 41, 59, 0.95) !important;
                        border: 1px solid #38bdf8;
                        opacity: 0.95;
                        z-index: 100;
                    }

                /* O Seu Clique Perfeito (Refinado do seu Print) */
                .drag-handle {
                    padding: 6px;
                    border-radius: 4px;
                    background: rgba(0,0,0,0.15);
                    cursor: grab; /* Mão aberta a pedir clique */
                    touch-action: none;
                    transition: background 0.2s, color 0.2s;
                }

                    .drag-handle:hover {
                        background: rgba(0,0,0,0.3);
                        color: #38bdf8;
                    }

                    /* Quando clica, o ícone do rato muda para mão fechada! */
                    .drag-handle:active, .is-dragging .drag-handle {
                        cursor: grabbing !important;
                        background: rgba(56, 189, 248, 0.2);
                        color: #38bdf8;
                    }
                .geonex-toggle {
                    position: relative;
                    display: inline-block;
                    width: 36px;
                    height: 18px;
                    margin-right: 10px;
                }

                    .geonex-toggle input {
                        opacity: 0;
                        width: 0;
                        height: 0;
                    }

                .geonex-slider {
                    position: absolute;
                    cursor: pointer;
                    top: 0;
                    left: 0;
                    right: 0;
                    bottom: 0;
                    background-color: rgba(255,255,255,0.1);
                    border: 1px solid rgba(255,255,255,0.2);
                    transition: .3s;
                    border-radius: 18px;
                }

                    .geonex-slider:before {
                        position: absolute;
                        content: "";
                        height: 12px;
                        width: 12px;
                        left: 2px;
                        bottom: 2px;
                        background-color: #888;
                        transition: .3s;
                        border-radius: 50%;
                    }

                .geonex-toggle input:checked + .geonex-slider {
                    background-color: rgba(56, 189, 248, 0.2);
                    border-color: #38bdf8;
                }

                    .geonex-toggle input:checked + .geonex-slider:before {
                        transform: translateX(18px);
                        background-color: #38bdf8;
                    }

                .gis-toolbar {
                    display: flex;
                    align-items: center;
                    gap: 6px;
                    background: rgba(0,0,0,0.4);
                    padding: 6px;
                    border-radius: 6px;
                    border: 1px solid rgba(255,255,255,0.05);
                }

                .gis-tool-btn {
                    position: relative;
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    height: 32px;
                    border-radius: 4px;
                    cursor: pointer;
                    transition: 0.2s;
                    color: #cbd5e1;
                    background: transparent;
                    border: 1px solid transparent;
                    overflow: hidden;
                }

                    .gis-tool-btn:hover {
                        background: rgba(255,255,255,0.1);
                        color: #fff;
                        border-color: rgba(255,255,255,0.2);
                    }

                    .gis-tool-btn.active {
                        background: rgba(56, 189, 248, 0.15);
                        color: #38bdf8;
                        border-color: rgba(56, 189, 248, 0.4);
                    }

                .gis-color-input {
                    position: absolute;
                    opacity: 0;
                    width: 100%;
                    height: 100%;
                    cursor: pointer;
                }

                .gis-number-wrapper {
                    display: flex;
                    align-items: center;
                    background: rgba(0,0,0,0.4);
                    border: 1px solid rgba(255,255,255,0.05);
                    border-radius: 4px;
                    overflow: hidden;
                    transition: border-color 0.2s;
                }

                    .gis-number-wrapper:focus-within {
                        border-color: #38bdf8;
                    }

                .gis-number-input {
                    width: 100%;
                    background: transparent;
                    border: none;
                    color: #fff;
                    padding: 8px 10px;
                    font-size: 14px;
                    outline: none;
                }

                .gis-number-unit {
                    color: #94a3b8;
                    padding-right: 10px;
                    font-size: 12px;
                    user-select: none;
                }

                /* NOVOS ESTILOS: Textos mais claros e fortes */
                .gis-label {
                    font-size: 11px;
                    color: #cbd5e1;
                    font-weight: 600;
                    text-transform: uppercase;
                    letter-spacing: 0.5px;
                    margin-bottom: 6px;
                    display: block;
                }

                /* NOVOS ESTILOS: Fundo Escuro para a Lista de Atributos */
                .gis-select {
                    width: 100%;
                    background: rgba(0,0,0,0.4);
                    border: 1px solid rgba(255,255,255,0.1);
                    color: #fff;
                    padding: 8px 10px;
                    font-size: 13px;
                    border-radius: 4px;
                    outline: none;
                    transition: 0.2s;
                }

                    .gis-select:focus {
                        border-color: #38bdf8;
                    }

                    .gis-select option {
                        background-color: #1e293b;
                        color: #fff;
                        padding: 10px;
                    }

                /* NOVOS ESTILOS: Botão de Fechar Vermelho */
                .close-btn-red {
                    background: transparent;
                    border: none;
                    color: #ef4444;
                    font-size: 20px;
                    font-weight: bold;
                    cursor: pointer;
                    transition: 0.2s;
                    border-radius: 4px;
                    width: 30px;
                    height: 30px;
                    display: flex;
                    align-items: center;
                    justify-content: center;
                }

                    .close-btn-red:hover {
                        background: #ef4444;
                        color: #fff;
                    }
        </style>

        <div class="modal-overlay">
            <div class="glass-panel modal-container" style="width: 550px; min-height: 400px; max-height: 85vh; display: flex; flex-direction: column;">
                <div class="modal-header">
                    <h2>PROPRIEDADES: @camadaEmEdicao</h2>
                    <button class="close-btn-red" @onclick="() => exibirModalPropriedades = false">✕</button>
                </div>

                <div class="modal-body properties-layout" style="flex: 1; overflow-y: auto;">

                    <nav class="properties-sidebar">
                        <button class="tab-btn @(abaAtivaPropriedades == "Simbologia" ? "active" : "")" @onclick='() => abaAtivaPropriedades = "Simbologia"'>Simbologia</button>
                        <button class="tab-btn @(abaAtivaPropriedades == "Rotulos" ? "active" : "")" @onclick='() => abaAtivaPropriedades = "Rotulos"'>Rótulos</button>
                        <button class="tab-btn @(abaAtivaPropriedades == "Informacao" ? "active" : "")" @onclick='() => abaAtivaPropriedades = "Informacao"'>Informação</button>
                    </nav>

                    <div class="properties-content custom-scrollbar">

                        @if (abaAtivaPropriedades == "Simbologia")
                        {
                            <div class="form-group-vertical">
                                <label class="gis-label">TIPO DE SIMBOLOGIA</label>
                                <select class="gis-select" @bind="tipoSimbologia">
                                    <option value="UNICA">Símbolo Único (Cor Sólida)</option>
                                    <option value="CATEGORIZADA">Categorizado (Por Atributo)</option>
                                </select>
                            </div>

                            <hr style="border: none; border-top: 1px solid rgba(255,255,255,0.05); margin: 15px 0;" />

                            @if (tipoSimbologia == "UNICA")
                            {
                                <div class="form-group-vertical" style="position: relative; margin-bottom: 15px;">
                                    <label class="gis-label">Cor de Preenchimento</label>
                                    <div class="arcmap-picker-trigger" @onclick="() => { abrirSeletorFill = !abrirSeletorFill; abrirSeletorBorda = false; }">
                                        @if (semCorPreenchimento)
                                        {
                                            <div class="color-preview-box no-color-diagonal"></div>
                                            <span class="color-text-value">Sem Cor (Transparente)</span>
                                        }
                                        else
                                        {
                                            <div class="color-preview-box" style="background-color: @corPreenchimento;"></div>
                                            <span class="color-text-value">@corPreenchimento.ToUpper()</span>
                                        }
                                        <div class="dropdown-arrow-indicator">▼</div>
                                    </div>

                                    @if (abrirSeletorFill)
                                    {
                                        <div class="arcmap-dropdown-palette glass-panel">
                                            <button type="button" class="arcmap-no-color-btn" @onclick='() => SelecionarCorCustomizada("FILL", "transparent")'>
                                                <div class="no-color-icon-small"></div> Sem Cor
                                            </button>
                                            <div class="arcmap-color-grid">
                                                @foreach (var cor in PaletaCoresSIG)
                                                {
                                                    <div class="arcmap-color-cell" style="background-color: @cor;" @onclick='() => SelecionarCorCustomizada("FILL", cor)'></div>
                                                }
                                            </div>
                                            <label class="arcmap-more-colors-btn">
                                                Mais Cores...
                                                <input @ref="inputColorFillRef" type="color" value="@corPreenchimento" style="display:none;"
                                                       @onchange='(e) => SelecionarCorCustomizada("FILL", e.Value?.ToString() ?? "#38bdf8")' />
                                            </label>
                                        </div>
                                    }
                                </div>

                                <div class="form-group-vertical" style="position: relative; margin-bottom: 15px;">
                                    <label class="gis-label">Cor da Borda</label>
                                    <div class="arcmap-picker-trigger" @onclick="() => { abrirSeletorBorda = !abrirSeletorBorda; abrirSeletorFill = false; }">
                                        @if (semCorBorda)
                                        {
                                            <div class="color-preview-box no-color-diagonal"></div>
                                            <span class="color-text-value">Sem Cor (Transparente)</span>
                                        }
                                        else
                                        {
                                            <div class="color-preview-box" style="background-color: @corBorda;"></div>
                                            <span class="color-text-value">@corBorda.ToUpper()</span>
                                        }
                                        <div class="dropdown-arrow-indicator">▼</div>
                                    </div>

                                    @if (abrirSeletorBorda)
                                    {
                                        <div class="arcmap-dropdown-palette glass-panel">
                                            <button type="button" class="arcmap-no-color-btn" @onclick='() => SelecionarCorCustomizada("BORDA", "transparent")'>
                                                <div class="no-color-icon-small"></div> Sem Cor
                                            </button>
                                            <div class="arcmap-color-grid">
                                                @foreach (var cor in PaletaCoresSIG)
                                                {
                                                    <div class="arcmap-color-cell" style="background-color: @cor;" @onclick='() => SelecionarCorCustomizada("BORDA", cor)'></div>
                                                }
                                            </div>
                                            <label class="arcmap-more-colors-btn">
                                                Mais Cores...
                                                <input @ref="inputColorBordaRef" type="color" value="@corBorda" style="display:none;"
                                                       @onchange='(e) => SelecionarCorCustomizada("BORDA", e.Value?.ToString() ?? "#0ea5e9")' />
                                            </label>
                                        </div>
                                    }
                                </div>
                            }
                            else
                            {
                                <div class="form-group-vertical">
                                    <label class="gis-label">Separar Cores Usando a Coluna</label>
                                    <select class="gis-select" @bind="colunaSimbologiaCategorizada">
                                        <option value="">[ Selecione a Coluna ]</option>
                                        @foreach (var col in ColunasDaCamadaAtual)
                                        {
                                            <option value="@col">@col</option>
                                        }
                                    </select>
                                </div>
                            }

                            <div class="form-group-vertical" style="margin-top: 15px;">
                                <label class="gis-label" style="display: flex; justify-content: space-between;">
                                    Opacidade <span>@opacidadePreenchimento%</span>
                                </label>
                                <input type="range" min="0" max="100" step="1" @bind="opacidadePreenchimento" @bind:event="oninput" @bind:after="AtualizarSimbologiaAoVivo" class="slider" />
                            </div>

                            <div class="form-group-vertical" style="margin-top: 15px;">
                                <label class="gis-label" style="display: flex; justify-content: space-between;">
                                    Espessura da Linha <span>@espessuraLinha px</span>
                                </label>
                                <input type="range" min="0" max="5" step="0.5" @bind="espessuraLinha" class="slider" />
                            </div>
                        }
                        else if (abaAtivaPropriedades == "Rotulos")
                        {
                            <div style="display: flex; align-items: center; margin-bottom: 20px; padding-bottom: 15px; border-bottom: 1px solid rgba(255,255,255,0.05);">
                                <label class="geonex-toggle">
                                    <input type="checkbox" @bind="exibirRotulos">
                                    <span class="geonex-slider"></span>
                                </label>
                                <span style="color: #fff; font-weight: 600; font-size: 14px; letter-spacing: 0.5px;">Exibir Rótulos no Mapa</span>
                            </div>

                            @if (exibirRotulos)
                            {
                                <div style="margin-bottom: 18px;">
                                    <label class="gis-label">Atributo de Leitura</label>
                                    <select class="gis-select" @bind="colunaRotuloSelecionada">
                                        <option value="">Selecione a Coluna...</option>
                                        @foreach (var coluna in ColunasDaCamadaAtual)
                                        {
                                            <option value="@coluna">@coluna</option>
                                        }
                                    </select>
                                </div>

                                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px; margin-bottom: 18px;">
                                    <div>
                                        <label class="gis-label">Tamanho do Texto</label>
                                        <div class="gis-number-wrapper">
                                            <input type="number" min="6" max="72" step="1" @bind="tamanhoFonteRotulo" class="gis-number-input" />
                                            <span class="gis-number-unit">px</span>
                                        </div>
                                    </div>
                                    <div>
                                        <label class="gis-label">Espessura do Halo</label>
                                        <div class="gis-number-wrapper">
                                            <input type="number" min="0" max="15" step="0.5" @bind="tamanhoHaloRotulo" class="gis-number-input" />
                                            <span class="gis-number-unit">px</span>
                                        </div>
                                    </div>
                                </div>

                                <div style="margin-bottom: 15px;">
                                    <label class="gis-label">Formatação Visual</label>
                                    <div class="gis-toolbar">

                                        <label class="gis-tool-btn @(rotuloNegrito ? "active" : "")" style="width: 40px;" title="Negrito">
                                            <input type="checkbox" @bind="rotuloNegrito" style="display: none;" />
                                            <span style="font-weight: bold; font-family: serif; font-size: 16px;">N</span>
                                        </label>

                                        <div style="width: 1px; height: 24px; background: rgba(255,255,255,0.1); margin: 0 6px;"></div>

                                        <div class="gis-tool-btn" style="flex: 1; display: flex; gap: 10px; padding: 0 12px;" title="Cor da Fonte">
                                            <span style="font-weight: bold; font-size: 15px; border-bottom: 3px solid @corFonteRotulo; padding-bottom: 2px;">A</span>
                                            <span style="font-size: 13px; font-weight: 500; opacity: 0.8;">Texto</span>
                                            <input type="color" @bind="corFonteRotulo" class="gis-color-input" />
                                        </div>

                                        <div class="gis-tool-btn" style="flex: 1; display: flex; gap: 10px; padding: 0 12px;" title="Cor do Halo (Contorno)">
                                            <span style="font-weight: bold; font-size: 15px; color: transparent; -webkit-text-stroke: 1px @corHaloRotulo; padding-bottom: 2px;">A</span>
                                            <span style="font-size: 13px; font-weight: 500; opacity: 0.8;">Halo</span>
                                            <input type="color" @bind="corHaloRotulo" class="gis-color-input" />
                                        </div>

                                    </div>
                                </div>
                            }
                        }
                        else if (abaAtivaPropriedades == "Informacao")
                        {
                            <div style="color: #94a3b8; font-size: 0.85rem; padding: 10px;">
                                <p style="margin-bottom: 10px;"><strong>Sistema de Coordenadas:</strong> EPSG:4326</p>
                                <p style="margin-bottom: 10px;"><strong>Formato:</strong> Vetor OGR</p>
                            </div>
                        }

                    </div>
                </div>

                <div class="modal-footer">
                    <button class="btn-cancel" @onclick="() => exibirModalPropriedades = false">CANCELAR</button>
                    <button class="btn-save add-layer-btn" @onclick="AplicarPropriedadesUnificadas">APLICAR ESTILO</button>
                </div>
            </div>
        </div>
    }
    <!-- A CHAVE DO MODAL DE PROPRIEDADES FECHA AQUI PRIMEIRO -->
    <!-- AGORA SIM, O MENU DE CONTEXTO É TOTALMENTE INDEPENDENTE -->
    @if (mostrarMenuContexto)
    {
        // Lê a memória para saber o estado dos rótulos e da coluna
        var temEstilo = MapService.EstilosPorCamada.TryGetValue(camadaSelecionadaMenu, out var estMenu);
        bool rotulosAtivos = temEstilo && estMenu.ExibirRotulos;
        bool bloquearRotulos = !rotulosAtivos && (!temEstilo || string.IsNullOrEmpty(estMenu.ColunaRotulo));

        <div class="context-menu-overlay" @onclick="FecharMenuContexto" @oncontextmenu="FecharMenuContexto" @oncontextmenu:preventDefault="true"></div>
        <div class="context-menu glass-panel" style="left: @(menuContextoX)px; top: @(menuContextoY)px;">
            <button @onclick="AproximarCamada">Aproximar à Camada</button>

            @if (CamadasAtivas.FirstOrDefault(c => c.Nome == camadaSelecionadaMenu)?.Tipo == "Vetor")
            {
                <button @onclick="() => { FecharMenuContexto(); AbrirTabela(camadaSelecionadaMenu); }">Tabela de Atributos</button>
                <button @onclick="() => { FecharMenuContexto(); AbrirPropriedadesSincronizadas(camadaSelecionadaMenu); }">Propriedades e Estilos</button>

                <hr class="menu-divider" />

                <button @onclick="AlternarRotulosMenuRapido"
                        disabled="@bloquearRotulos"
                        title="@(bloquearRotulos ? "Configure a coluna nas Propriedades primeiro" : "")"
                        style="display: flex; justify-content: space-between; align-items: center; @(bloquearRotulos ? "opacity: 0.4; cursor: not-allowed;" : "")">
                    <span>@(rotulosAtivos ? "Ocultar Rótulos" : "Exibir Rótulos")</span>
                    <span style="color: @(rotulosAtivos ? "#f87171" : (bloquearRotulos ? "#64748b" : "#38bdf8")); font-weight: bold; font-family: serif;">T</span>
                </button>

                <hr class="menu-divider" />
            }

            <button @onclick="FecharMenuContexto">Renomear</button>

            <button @onclick="() => MoverCamada(camadaSelecionadaMenu, -1)">Mover para Cima</button>
            <button @onclick="() => MoverCamada(camadaSelecionadaMenu, 1)">Mover para Baixo</button>

            <hr class="menu-divider" />

            <button @onclick="PrepararRemocaoCamada" class="btn-danger">Remover Camada</button>
        </div>
    }
    
    <!-- MODAL DE INJEÇÃO DE COORDENADAS (CADERNETA DE CAMPO) -->
    @if (exibirModalCoordenadas)
    {
        <div class="modal-overlay">
            <div class="glass-panel" style="width: 550px; display: flex; flex-direction: column;">
                <div class="modal-header">
                    <h2>CADERNETA DE CAMPO DIGITAL</h2>
                    <button class="close-btn" @onclick="() => exibirModalCoordenadas = false">✕</button>
                </div>

                <!-- CORREÇÃO 1: height: auto e max-height para evitar que o conteúdo vaze -->
                <div class="modal-body custom-scrollbar" style="height: auto; max-height: 65vh; padding: 20px; display: flex; flex-direction: column; gap: 15px; overflow-y: auto;">

                    <!-- CONFIGURAÇÕES DE SISTEMA -->
                    <div class="form-row">
                        <div class="form-group-vertical">
                            <label>SISTEMA (CRS)</label>
                            <select class="glass-input" @bind="sistemaCoordenadas">
                                <option value="DECIMAL">Geográfica Decimal (WGS 84)</option>
                                <option value="UTM">UTM (SIRGAS 2000)</option>
                            </select>
                        </div>
                        <div class="form-group-vertical">
                            <label>GEOMETRIA ALVO</label>
                            <select class="glass-input" @bind="tipoGeometriaAlvo">
                                <option value="POLIGONO">Polígono (Área)</option>
                                <option value="LINHA">Linha / Eixo</option>
                                <option value="PONTOS">Pontos Individuais</option>
                            </select>
                        </div>
                    </div>

                    <!-- CONFIGURAÇÕES ESPECÍFICAS E MÉTODO DE ENTRADA -->
                    <div class="form-row" style="margin-top: 10px;">
                        @if (sistemaCoordenadas == "UTM")
                        {
                            <div class="form-group-vertical">
                                <label>FUSO / ZONA UTM (Ex: 22S)</label>
                                <input type="text" class="glass-input" @bind="zonaUtm" placeholder="Ex: 22S" />
                            </div>
                        }

                        <!-- Se não for UTM, este select ocupa a largura toda da grelha -->
                        <div class="form-group-vertical" style="@(sistemaCoordenadas != "UTM" ? "grid-column: span 2;" : "")">
                            <label>MÉTODO DE ENTRADA</label>
                            <select class="glass-input" @bind="metodoEntrada">
                                <option value="COORDENADA">Coordenadas Absolutas (X, Y)</option>
                                @if (sistemaCoordenadas == "UTM")
                                {
                                    <option value="AZIMUTE">Azimute e Distância (A partir do anterior)</option>
                                }
                            </select>
                        </div>
                    </div>

                    @if (sistemaCoordenadas == "UTM")
                    {
                        <div class="form-group-vertical">
                            <label>FUSO / ZONA UTM (Ex: 22S)</label>
                            <input type="text" class="glass-input" @bind="zonaUtm" placeholder="Ex: 22S" />
                        </div>
                    }

                    <hr style="border: none; border-top: 1px solid rgba(255,255,255,0.1); margin: 5px 0;" />

                    <!-- ENTRADA DOS DADOS -->
                    <div class="form-row" style="align-items: flex-end;">
                        <div class="form-group-vertical" style="flex: 0.3;">
                            <label>NOME</label>
                            <input type="text" class="glass-input" @bind="novoNomePonto" placeholder="Ex: P1" />
                        </div>
                        <div class="form-group-vertical" style="flex: 0.7;">
                            <label>COORDENADA (X, Y) ou (Lat, Lng)</label>
                            <div style="display: flex; gap: 10px;">
                                <input type="text" class="glass-input" @bind="novaCoordenadaPonto" placeholder="@(sistemaCoordenadas == "UTM" ? "743210.50, 7134560.80" : "-25.8828, -48.5747")" style="flex: 1;" />
                                <button class="btn-save" @onclick="AdicionarPontoCaderneta" style="margin: 0; padding: 8px 15px; width: auto;">+</button>
                            </div>
                        </div>
                    </div>

                    <!-- LISTA DE PONTOS (A Caderneta) -->
                    <div class="form-group-vertical">
                        <label>LISTA DE PONTOS ADICIONADOS (@listaPontosCaderneta.Count)</label>
                        <div class="layer-list custom-scrollbar" style="height: 140px; background: rgba(0,0,0,0.3); border-radius: 4px; padding: 5px; border: 1px solid rgba(255,255,255,0.05);">

                            @if (listaPontosCaderneta.Count == 0)
                            {
                                <div style="text-align: center; color: #64748b; font-size: 0.75rem; margin-top: 40px;">
                                    Nenhum ponto adicionado à caderneta.
                                </div>
                            }

                            @foreach (var pt in listaPontosCaderneta)
                            {
                                <div style="display: flex; justify-content: space-between; align-items: center; font-size: 0.8rem; padding: 8px; border-bottom: 1px solid rgba(255,255,255,0.05); background: rgba(255,255,255,0.02); margin-bottom: 2px; border-radius: 4px;">
                                    <span><strong style="color:#38bdf8; width: 40px; display: inline-block;">@pt["Nome"]</strong> | <span style="font-family: monospace;">@pt["Coord1"], @pt["Coord2"]</span></span>
                                    <button style="background:none; border:none; color:#ef4444; cursor:pointer; font-size: 1.1rem; font-weight: bold;" @onclick="() => RemoverPontoCaderneta(pt)" title="Remover Ponto">✕</button>
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <!-- CORREÇÃO 2: Botões isolados no rodapé -->
                <div class="modal-footer" style="padding: 15px 20px; border-top: 1px solid rgba(255,255,255,0.05); display: flex; justify-content: flex-end; gap: 10px; background: rgba(0,0,0,0.2);">
                    <button class="btn-cancel" @onclick="() => exibirModalCoordenadas = false">CANCELAR</button>
                    <button class="btn-save" style="margin: 0; width: auto;" @onclick="ProcessarCadernetaDeCampo">PROCESSAR LEVANTAMENTO</button>
                </div>

            </div>
        </div>
    }
    
    @if (exibirModalTrocaVertice)
    {
        <div class="modal-overlay">
            <div class="glass-panel" style="width: 400px;">
                <div class="modal-header">
                    <h2>AJUSTE DE VÉRTICE: V@(verticeEditandoIndice + 1)</h2>
                    <button class="close-btn" @onclick="() => exibirModalTrocaVertice = false">✕</button>
                </div>
                <div class="modal-body" style="padding: 15px; display: flex; flex-direction: column; gap: 10px;">

                    <div class="form-row">
                        <div class="form-group-vertical">
                            <label>SISTEMA (CRS)</label>
                            <select class="glass-input" @bind="sistemaCoordenadasEdicao">
                                <option value="DECIMAL">Decimal (WGS 84)</option>
                                <option value="UTM">UTM (SIRGAS 2000)</option>
                            </select>
                        </div>
                        @if (sistemaCoordenadasEdicao == "UTM")
                        {
                            <div class="form-group-vertical">
                                <label>FUSO / ZONA UTM</label>
                                <input type="text" class="glass-input" @bind="zonaUtmEdicao" placeholder="Ex: 22S" />
                            </div>
                        }
                    </div>

                    <div class="form-group-vertical">
                        <label>@(sistemaCoordenadasEdicao == "UTM" ? "COORDENADA NORTE (Y)" : "LATITUDE (Y)")</label>
                        <input type="text" class="glass-input" @bind="verticeEditandoY" />
                    </div>
                    <div class="form-group-vertical">
                        <label>@(sistemaCoordenadasEdicao == "UTM" ? "COORDENADA ESTE (X)" : "LONGITUDE (X)")</label>
                        <input type="text" class="glass-input" @bind="verticeEditandoX" />
                    </div>

                </div>
                <div class="modal-footer" style="padding: 15px; display: flex; justify-content: flex-end; gap: 10px; background: rgba(0,0,0,0.2);">
                    <button class="btn-cancel" @onclick="() => exibirModalTrocaVertice = false">CANCELAR</button>
                    <button class="btn-save" @onclick="ForcarVerticeManual">MOVER VÉRTICE</button>
                </div>
            </div>
        </div>
    }
    <!-- ========================================================= -->
    <!-- HUD DE ENGENHARIA: MENU DE CONTEXTO TÁTICO                -->
    <!-- ========================================================= -->
    <!-- ========================================================= -->
    <!-- HUD DE ENGENHARIA: MENU DE CONTEXTO TÁTICO                -->
    <!-- ========================================================= -->
    @if (_mostrarMenuContexto && !_mostrarInputCogo)
    {
        <div style="pointer-events: auto; position: fixed; top: @(_menuContextoY)px; left: @(_menuContextoX)px; width: 220px; background: rgba(15, 23, 42, 0.90); border: 1px solid rgba(255, 255, 255, 0.1); border-radius: 4px; box-shadow: 0 10px 30px rgba(0,0,0,0.6); z-index: 10000; backdrop-filter: blur(16px); display: flex; flex-direction: column; padding: 4px 0; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;"
             @onpointerdown:stopPropagation="true"
             @onpointerup:stopPropagation="true"
             @onclick:stopPropagation="true"
             @oncontextmenu:preventDefault="true">

            <button class="ctx-btn" @onclick="() => { _mostrarInputCogo = true; }" style="text-align: left; padding: 8px 16px; background: transparent; border: none; color: #e2e8f0; font-size: 13px; font-weight: 500; cursor: pointer; border-left: 3px solid transparent; transition: all 0.2s;" onmouseover="this.style.background='rgba(255,255,255,0.05)'; this.style.borderLeft='3px solid #38bdf8';" onmouseout="this.style.background='transparent'; this.style.borderLeft='3px solid transparent';">
                Vetor Restrito (Comprimento e Direção)
            </button>

            <div style="height: 1px; background: rgba(255,255,255,0.08); margin: 4px 0;"></div>

            <button class="ctx-btn" @onclick="() => { ConcluirAquisicaoPoligono(); _mostrarMenuContexto = false; }" style="text-align: left; padding: 8px 16px; background: transparent; border: none; color: #34d399; font-size: 13px; font-weight: 600; cursor: pointer; border-left: 3px solid transparent; transition: all 0.2s;" onmouseover="this.style.background='rgba(52, 211, 153, 0.1)'; this.style.borderLeft='3px solid #34d399';" onmouseout="this.style.background='transparent'; this.style.borderLeft='3px solid transparent';">
                Concluir Esboço
            </button>
        </div>
    }

    <!-- ========================================================= -->
    <!-- HUD DE ENGENHARIA [TAB]: COGO POLAR                       -->
    <!-- ========================================================= -->
    @if (_mostrarInputCogo)
    {
        <style>
                .hud-input::-webkit-inner-spin-button,
                .hud-input::-webkit-outer-spin-button {
                    -webkit-appearance: none;
                    margin: 0;
                }

                .hud-input {
                    -moz-appearance: textfield;
                    font-family: 'Consolas', 'Courier New', monospace;
                    text-align: right;
                }

                .hud-btn {
                    transition: all 0.2s ease-in-out;
                }

                    .hud-btn:hover {
                        filter: brightness(1.3);
                    }
        </style>

        <div id="hud-cogo" style="pointer-events: auto; position: fixed; top: 0px; left: 0px; transform: translate3d(@(_hudX)px, @(_hudY)px, 0); will-change: transform; width: 280px; background: rgba(15, 23, 42, 0.70); border: 1px solid rgba(255, 255, 255, 0.08); border-radius: 8px; box-shadow: 0 24px 48px rgba(0,0,0,0.6); z-index: 10001; backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); display: flex; flex-direction: column; overflow: hidden; font-family: 'Segoe UI', sans-serif;"
             @onpointerdown:stopPropagation="true"
             @onpointerup:stopPropagation="true"
             @onmousedown:stopPropagation="true"
             @onmouseup:stopPropagation="true"
             @onclick:stopPropagation="true"
             @oncontextmenu:preventDefault="true">

            <div onpointerdown="window.iniciarArrasteHUD(event, 'hud-cogo')" style="background: rgba(0, 0, 0, 0.25); padding: 12px 16px; cursor: grab; border-bottom: 1px solid rgba(255,255,255,0.05); display: flex; justify-content: space-between; align-items: center;" onmousedown="this.style.cursor='grabbing'" onmouseup="this.style.cursor='grab'">
                <span style="font-size: 10px; color: #38bdf8; font-weight: 700; letter-spacing: 1.5px;">COGO AVANÇADO (TAB)</span>
                <span style="color: #64748b; font-size: 14px; cursor: pointer;" @onclick="() => _mostrarInputCogo = false">✕</span>
            </div>

            <div style="padding: 16px; display: flex; flex-direction: column; gap: 14px;">

                <div>
                    <span style="font-size: 9px; color: #64748b; font-weight: 700; letter-spacing: 1px; display: block; margin-bottom: 8px;">1. VETOR POLAR</span>
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 6px;">
                        <label style="color: #94a3b8; font-size: 11px;">Distância (m)</label>
                        <input class="hud-input" type="number" @bind="_cogoDistancia" style="width: 120px; background: rgba(0,0,0,0.3); border: 1px solid rgba(255,255,255,0.1); color: #f8fafc; padding: 4px 8px; font-size: 12px; border-radius: 4px; outline: none;" />
                    </div>
                    <div style="display: flex; justify-content: space-between; align-items: center;">
                        <label style="color: #94a3b8; font-size: 11px;">Azimute (º)</label>
                        <input class="hud-input" type="number" @bind="_cogoAzimute" style="width: 120px; background: rgba(0,0,0,0.3); border: 1px solid rgba(255,255,255,0.1); color: #f8fafc; padding: 4px 8px; font-size: 12px; border-radius: 4px; outline: none;" />
                    </div>
                    <button class="hud-btn"
                            @onclick="AplicarVetorRestritoCogo"
                            @onclick:stopPropagation="true" @onpointerdown:stopPropagation="true" @onpointerup:stopPropagation="true"
                            style="width: 100%; margin-top: 8px; background: rgba(2, 132, 199, 0.15); border: 1px solid rgba(56, 189, 248, 0.3); color: #38bdf8; padding: 6px; font-size: 10px; font-weight: 700; letter-spacing: 1px; cursor: pointer; border-radius: 4px;">
                        PROJETAR POLAR
                    </button>
                </div>

                <div style="height: 1px; background: rgba(255,255,255,0.05);"></div>

                <div>
                    <span style="font-size: 9px; color: #64748b; font-weight: 700; letter-spacing: 1px; display: block; margin-bottom: 8px;">2. COORDENADA ABSOLUTA</span>
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 6px;">
                        <label style="color: #94a3b8; font-size: 11px;">ESTE (X)</label>
                        <input class="hud-input" type="number" @bind="_absolutoX" style="width: 120px; background: rgba(0,0,0,0.3); border: 1px solid rgba(255,255,255,0.1); color: #f8fafc; padding: 4px 8px; font-size: 12px; border-radius: 4px; outline: none;" />
                    </div>
                    <div style="display: flex; justify-content: space-between; align-items: center;">
                        <label style="color: #94a3b8; font-size: 11px;">NORTE (Y)</label>
                        <input class="hud-input" type="number" @bind="_absolutoY" style="width: 120px; background: rgba(0,0,0,0.3); border: 1px solid rgba(255,255,255,0.1); color: #f8fafc; padding: 4px 8px; font-size: 12px; border-radius: 4px; outline: none;" />
                    </div>
                    <button class="hud-btn"
                            @onclick="AplicarCoordenadaAbsoluta"
                            @onclick:stopPropagation="true" @onpointerdown:stopPropagation="true" @onpointerup:stopPropagation="true"
                            style="width: 100%; margin-top: 8px; background: rgba(16, 185, 129, 0.15); border: 1px solid rgba(52, 211, 153, 0.3); color: #34d399; padding: 6px; font-size: 10px; font-weight: 700; letter-spacing: 1px; cursor: pointer; border-radius: 4px;">
                        CRAVAR COORDENADA
                    </button>
                </div>

                <div style="height: 1px; background: rgba(255,255,255,0.05);"></div>
                <div>
                    <span style="font-size: 9px; color: #64748b; font-weight: 700; letter-spacing: 1px; display: block; margin-bottom: 8px;">3. RESTRIÇÃO DE DISTÂNCIA</span>

                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px;">
                        <label style="color: #94a3b8; font-size: 11px;">Raio (m)</label>
                        <input class="hud-input" type="number" @bind="_travaDistanciaValor" style="width: 120px; background: rgba(0,0,0,0.3); border: 1px solid rgba(255,255,255,0.1); color: #f8fafc; padding: 4px 8px; font-size: 12px; border-radius: 4px; outline: none;" />
                    </div>

                    <div style="display: flex; gap: 4px; margin-bottom: 10px;">
                        <button class="hud-btn" @onclick="() => _travaModoFixo = false" @onclick:stopPropagation="true" @onpointerdown:stopPropagation="true" @onpointerup:stopPropagation="true"
                                style="flex: 1; padding: 4px; font-size: 9px; font-weight: 700; border-radius: 4px; cursor: pointer;
                            background: @(!_travaModoFixo ? "rgba(56, 189, 248, 0.2)" : "rgba(255,255,255,0.05)");
                            color: @(!_travaModoFixo ? "#38bdf8" : "#64748b");
                            border: 1px solid @(!_travaModoFixo ? "rgba(56, 189, 248, 0.4)" : "transparent");">
                            MÁXIMO
                        </button>
                        <button class="hud-btn" @onclick="() => _travaModoFixo = true" @onclick:stopPropagation="true" @onpointerdown:stopPropagation="true" @onpointerup:stopPropagation="true"
                                style="flex: 1; padding: 4px; font-size: 9px; font-weight: 700; border-radius: 4px; cursor: pointer;
                            background: @(_travaModoFixo ? "rgba(56, 189, 248, 0.2)" : "rgba(255,255,255,0.05)");
                            color: @(_travaModoFixo ? "#38bdf8" : "#64748b");
                            border: 1px solid @(_travaModoFixo ? "rgba(56, 189, 248, 0.4)" : "transparent");">
                            FIXO
                        </button>
                    </div>

                    <button class="hud-btn"
                            @onclick="AlternarTravaDistancia"
                            @onclick:stopPropagation="true" @onpointerdown:stopPropagation="true" @onpointerup:stopPropagation="true"
                            style="width: 100%; padding: 6px; font-size: 10px; font-weight: 700; letter-spacing: 1px; cursor: pointer; border-radius: 4px;
                        background: @(_travaDistanciaAtiva ? "rgba(239, 68, 68, 0.15)" : "rgba(148, 163, 184, 0.1)");
                        border: 1px solid @(_travaDistanciaAtiva ? "rgba(248, 113, 113, 0.4)" : "rgba(148, 163, 184, 0.3)");
                        color: @(_travaDistanciaAtiva ? "#f87171" : "#94a3b8");">
                        @(_travaDistanciaAtiva ? "DESATIVAR RESTRIÇÃO" : "ATIVAR RESTRIÇÃO")
                    </button>
                </div>
            </div>
        </div>
    }
    @if (_mostrarInputAbsoluto && !_mostrarInputCogo)
    {
        <div id="hud-f6" style="pointer-events: auto; position: fixed; top: 0px; left: 0px; transform: translate3d(@(_hudX)px, @(_hudY)px, 0); will-change: transform; width: 260px; background: rgba(15, 23, 42, 0.95); border: 1px solid #10b981; border-radius: 6px; box-shadow: 0 15px 50px rgba(0,0,0,0.7); z-index: 10001; backdrop-filter: blur(16px); display: flex; flex-direction: column; overflow: hidden;"
             @onpointerdown:stopPropagation="true"
             @onpointerup:stopPropagation="true"
             @onclick:stopPropagation="true"
             @oncontextmenu:preventDefault="true">

            <div onpointerdown="window.iniciarArrasteHUD(event, 'hud-f6')" style="background: rgba(16, 185, 129, 0.15); padding: 6px 12px; cursor: grab; border-bottom: 1px solid rgba(255,255,255,0.05); display: flex; justify-content: space-between; align-items: center;" onmousedown="this.style.cursor='grabbing'" onmouseup="this.style.cursor='grab'">
                <span style="font-size: 10px; color: #10b981; font-weight: bold; letter-spacing: 1px;">INSERÇÃO ABSOLUTA (F6)</span>
                <span style="color: #94a3b8; font-size: 14px; cursor: pointer; padding: 0 4px;" @onclick="() => _mostrarInputAbsoluto = false" title="Fechar">✕</span>
            </div>

            <div style="padding: 12px; display: flex; flex-direction: column; gap: 10px;">
                <div style="display: flex; justify-content: space-between; align-items: center;">
                    <label style="color: #cbd5e1; font-size: 11px; font-weight: 600;">ESTE (X)</label>
                    <input @ref="_inputAbsolutoXRef" type="number" @bind="_absolutoX" style="width: 140px; background: rgba(0,0,0,0.4); border: 1px solid rgba(255,255,255,0.1); color: #fff; padding: 4px 8px; font-size: 13px; border-radius: 2px; outline: none; font-family: monospace;" />
                </div>
                <div style="display: flex; justify-content: space-between; align-items: center;">
                    <label style="color: #cbd5e1; font-size: 11px; font-weight: 600;">NORTE (Y)</label>
                    <input type="number" @bind="_absolutoY" style="width: 140px; background: rgba(0,0,0,0.4); border: 1px solid rgba(255,255,255,0.1); color: #fff; padding: 4px 8px; font-size: 13px; border-radius: 2px; outline: none; font-family: monospace;" />
                </div>

                <button @onclick="AplicarCoordenadaAbsoluta" style="background: #047857; border: none; color: white; padding: 6px; font-size: 12px; font-weight: 600; cursor: pointer; border-radius: 2px; margin-top: 4px; transition: 0.2s;" onmouseover="this.style.background='#059669';" onmouseout="this.style.background='#047857';">CRAVAR VÉRTICE</button>
            </div>
        </div>
    }
    @if (exibirModalNovaCamada)
    {
        <div class="modal-overlay">
            <div class="glass-panel import-modal" style="width: 550px; height: auto;">
                <div class="modal-header">
                    <h2>ALOCAÇÃO DE DATASET VETORIAL</h2>
                    <button class="close-btn-red" @onclick="FecharModalNovaCamada">✕</button>
                </div>
                <div class="modal-body" style="padding: 20px; display: flex; flex-direction: column; gap: 15px; height: auto;">

                    <div class="form-row">
                        <div class="form-group-vertical">
                            <label class="gis-label">NOME DA CAMADA</label>
                            <input type="text" class="glass-input" @bind="novaCamadaNome" @bind:event="oninput" placeholder="Ex: Levantamento_Topografico" />
                        </div>

                        <div class="form-group-vertical">
                            <label class="gis-label">FORMATO FÍSICO</label>
                            <select class="gis-select" @bind="novaCamadaFormato">
                                <option value="SHP">ESRI Shapefile (.shp)</option>
                                <option value="GEOJSON">GeoJSON (.geojson)</option>
                                <option value="GPKG">GeoPackage (.gpkg)</option>
                            </select>
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-group-vertical">
                            <label class="gis-label">CLASSE DE GEOMETRIA</label>
                            <select class="gis-select" @bind="novaCamadaGeometria">
                                <option value="POLIGONO">Polígono (Polygon)</option>
                                <option value="LINHA">Linha (LineString)</option>
                                <option value="PONTO">Ponto (Point)</option>
                            </select>
                        </div>

                        <div class="form-group-vertical">
                            <label class="gis-label">SISTEMA DE REFERÊNCIA (CRS)</label>
                            <select class="gis-select" @bind="novaCamadaCrs">
                                <option value="EPSG:31982">EPSG:31982 - SIRGAS 2000 / UTM 22S</option>
                                <option value="EPSG:4326">EPSG:4326 - WGS 84</option>
                            </select>
                        </div>
                    </div>

                    <div class="form-group-vertical">
                        <label class="gis-label">DIRETÓRIO DE DESTINO (PASTA)</label>
                        <div style="display: flex; gap: 10px;">
                            <input type="text" class="glass-input" @bind="pastaDestinoSelecionada" @bind:event="oninput" placeholder="Ex: C:\Projetos_SIG" style="flex: 1; font-family: monospace; font-size: 12px; color: #fff;" />
