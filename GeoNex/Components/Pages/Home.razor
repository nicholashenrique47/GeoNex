    private void SincronizarHierarquia()
    {
        MapService.OrdemCamadas.Clear();

        // O Filtro Absoluto: Só injeta na Placa Gráfica se o ícone do olho estiver ligado
        for (int i = CamadasAtivas.Count - 1; i >= 0; i--)
        {
            if (CamadasAtivas[i].Visivel)
            {
                MapService.OrdemCamadas.Add(CamadasAtivas[i].Nome);
            }
        }

        // Proteção contra Seleção Fantasma:
        // Apaga o lote amarelo e limpa o painel se a camada que o contém for ocultada
        if (!string.IsNullOrEmpty(camadaSelecionadaPainel))
        {
            var camadaSel = CamadasAtivas.FirstOrDefault(c => c.Nome == camadaSelecionadaPainel);
            if (camadaSel != null && !camadaSel.Visivel)
            {
                MapService.DestacarFeicao(null);
                camadaSelecionadaPainel = string.Empty;
                atributosFeicaoSelecionada?.Clear();
            }
        }

        SolicitarNovoFrame();
    }
    [JSInvokable]
    public async Task ProcessarCliqueRaycast(double telaX, double telaY)
    {
        var matriz = ObterMatrizMatematica();
        if (matriz.TryInvert(out var matrizInversa))
        {
            var ptMundo = matrizInversa.MapPoint(new SkiaSharp.SKPoint((float)telaX, (float)telaY));
            double xMundo = ptMundo.X + MapService.OffsetMundoX;
            double yMundo = (-ptMundo.Y) + MapService.OffsetMundoY;

            switch (_ferramentaAtiva)
            {
                case ModoFerramenta.Identificacao:
                    float escalaMatriz = matriz.ScaleX;
                    double tolerancia = 5.0 / escalaMatriz;
                    var feicao = MapService.DispararRaycast(yMundo, xMundo, tolerancia, out string camadaAtingida);
                    MapService.DestacarFeicao(feicao);

                    if (feicao != null)
                    {
                        camadaSelecionadaPainel = camadaAtingida;
                        atributosFeicaoSelecionada = new Dictionary<string, string>();
                        foreach (var nomeCampo in feicao.Attributes.GetNames())
                        {
                            atributosFeicaoSelecionada[nomeCampo] = feicao.Attributes[nomeCampo]?.ToString() ?? string.Empty;
                        }
                        _geometriaDestacada = feicao.Geometry;
                    }
                    else
                    {
                        camadaSelecionadaPainel = string.Empty;
                        atributosFeicaoSelecionada?.Clear();
                        _geometriaDestacada = null;
                    }
                    _ = SincronizarOverlay(false);
                    break;

                case ModoFerramenta.Medicao:
                    var ptFinalMed = ptMundo;
                    if (_snapMedicaoAtivo)
                    {
                        // MEDIÇÃO: checarVertices = true, checarArestas = false (Isolamento total!)
                        var ptMagneticoMed = MapService.EncontrarVerticeProximo(ptMundo, 15.0f / matriz.ScaleX, true, false);
                        if (ptMagneticoMed.HasValue) ptFinalMed = ptMagneticoMed.Value;
                    }
                    MapService.PontosMedicao.Add(ptFinalMed);
                    RecalcularMedicoes();
                    _ = SincronizarOverlay(false);
                    break;

                case ModoFerramenta.AquisicaoPoligono:
                    var ptFinalAq = ptMundo;

                    // 1. PRIORIDADE ABSOLUTA: RESTRIÇÃO DE DISTÂNCIA
                    if (_travaDistanciaAtiva && _travaDistanciaValor > 0 && MapService.PontosAquisicao.Count > 0)
                    {
                        var ultimoPonto = MapService.PontosAquisicao.Last();

                        // Recalcula o ângulo no momento exato do clique para evitar atrasos (lag) do rato
                        double dx = ptFinalAq.X - ultimoPonto.X;
                        double dy = ptFinalAq.Y - ultimoPonto.Y;
                        double anguloRadianos = Math.Atan2(dy, dx);

                        // Esmaga a coordenada do clique, forçando-a a ficar no raio
                        ptFinalAq = new SkiaSharp.SKPoint(
                            (float)(ultimoPonto.X + Math.Cos(anguloRadianos) * _travaDistanciaValor),
                            (float)(ultimoPonto.Y + Math.Sin(anguloRadianos) * _travaDistanciaValor)
                        );
                    }
                    // 2. SE A RESTRIÇÃO ESTIVER DESLIGADA: PROCURA O SNAP MAGNÉTICO
                    else if (_snapAquisicaoVertice || _snapAquisicaoAresta)
                    {
                        // DESENHO: Passa as variáveis exatas que ativou no menu
                        var ptMagneticoAq = MapService.EncontrarVerticeProximo(ptMundo, 15.0f / matriz.ScaleX, _snapAquisicaoVertice, _snapAquisicaoAresta);
                        if (ptMagneticoAq.HasValue) ptFinalAq = ptMagneticoAq.Value;
                    }

                    // 3. INJETA O VÉRTICE BLINDADO NA MEMÓRIA
                    MapService.PontosAquisicao.Add(ptFinalAq);
                    SolicitarNovoFrame();
                    break;
            }
            await InvokeAsync(StateHasChanged);
        }
    }
   
