        float mouseRelativoX = (float)e.ClientX - centroX;
        float mouseRelativoY = (float)e.ClientY - centroY;

        MapService.CameraPanX = (MapService.CameraPanX * proporcao) + (mouseRelativoX * (1 - proporcao));
        MapService.CameraPanY = (MapService.CameraPanY * proporcao) + (mouseRelativoY * (1 - proporcao));

