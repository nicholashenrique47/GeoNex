    private async Task AdicionarCamadaAoMapa()
    {
        try
        {
            if (string.IsNullOrEmpty(caminhoArquivoRaster))
            {
                await JSRuntime.InvokeVoidAsync("alert", "Selecione um ficheiro primeiro!");
                return;
            }

            exibirModalImportacao = false;

            // BLINDAGEM 3: Lock no momento da troca de Dataset para evitar choque de Threads
            // BLINDAGEM 3: Lock no momento da troca de Dataset para evitar choque de Threads
            lock (MapService)
            {
                if (MapService.DatasetRaster != null) MapService.DatasetRaster.Dispose();
                MapService.DatasetRaster = OSGeo.GDAL.Gdal.Open(caminhoArquivoRaster, OSGeo.GDAL.Access.GA_ReadOnly);

                // Prevenção contra ficheiros corrompidos
                if (MapService.DatasetRaster == null)
                {
                    InvokeAsync(() => JSRuntime.InvokeVoidAsync("alert", "O GDAL falhou ao abrir o arquivo. O ficheiro pode estar corrompido."));
                    return;
                }

                if (MapService.DatasetRaster.RasterCount > 0 && MapService.DatasetRaster.GetRasterBand(1).GetOverviewCount() == 0)
                {
                    MapService.DatasetRaster.BuildOverviews("AVERAGE", new int[] { 2, 4, 8, 16, 32 });
                }

                double[] trans = new double[6];
                MapService.DatasetRaster.GetGeoTransform(trans);
                double minX = trans[0];
                double maxY = trans[3];
                double maxX = minX + (MapService.DatasetRaster.RasterXSize * trans[1]);
                double minY = maxY + (MapService.DatasetRaster.RasterYSize * trans[5]);

                // === CORREÇÃO DE ALINHAMENTO UTM/RASTER ===
                // Se a ortofoto for o primeiro ficheiro a ser carregado, ela define a Âncora do Mundo.
                if (!MapService.OffsetMundoDefinido)
                {
                    MapService.OffsetMundoX = minX;
                    MapService.OffsetMundoY = maxY;
                    MapService.OffsetMundoDefinido = true;
                }

                // Grava os limites na memória gráfica anulando os "milhões" do UTM
                MapService.LimitesRasterGlobal = new SkiaSharp.SKRect(
                    (float)(minX - MapService.OffsetMundoX),
                    (float)-(maxY - MapService.OffsetMundoY),
                    (float)(maxX - MapService.OffsetMundoX),
                    (float)-(minY - MapService.OffsetMundoY)
                );

                MapService.NomeRasterAtivo = System.IO.Path.GetFileName(caminhoArquivoRaster);
                MapService.TemRaster = true;
            }

            MapService.CameraPanX = 0;
            MapService.CameraPanY = 0;
            MapService.CameraZoom = 1.0f;
            MapService.RasterCache?.Dispose();
            MapService.RasterCache = null;

            SolicitarNovoFrame();
            StateHasChanged();
            await JSRuntime.InvokeVoidAsync("mapEngine.resetarCamera");
            // Faça o mesmo onde adiciona a Ortofoto à interface:
            // Faça o mesmo onde adiciona a Ortofoto à interface:
            var rasterExistente = CamadasAtivas.FirstOrDefault(c => c.Nome == MapService.NomeRasterAtivo);
            if (rasterExistente == null)
            {
                CamadasAtivas.Insert(0, new Camada { Nome = MapService.NomeRasterAtivo, Tipo = "Raster", Visivel = true, CaminhoArquivo = caminhoArquivoRaster });
            }

            SincronizarHierarquia();
            SolicitarNovoFrame();
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", "Erro crítico na importação raster: " + ex.Message);
        }
