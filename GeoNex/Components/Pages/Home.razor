    // Função matemática para descobrir a Bounding Box do Shapefile inteiro
    private void CalcularLimitesDoMapa()
    {
        mapaMinX = float.MaxValue; mapaMaxX = float.MinValue;
        mapaMinY = float.MaxValue; mapaMaxY = float.MinValue;

        foreach (var poli in poligonosNativos)
        {
            // O array armazena [X, Y, X, Y...]
            for (int i = 0; i < poli.Length; i += 2)
            {
                float x = poli[i];
                float y = poli[i + 1];

                if (x < mapaMinX) mapaMinX = x;
                if (x > mapaMaxX) mapaMaxX = x;
                if (y < mapaMinY) mapaMinY = y;
                if (y > mapaMaxY) mapaMaxY = y;
            }
        }
    }
