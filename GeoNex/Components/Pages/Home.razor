    protected override void OnInitialized()
    {
        // === PREVENÇÃO DO BUG DO F5 ===
        // Zera a memória do servidor C# sempre que a UI é recarregada
        MapService.CameraZoom = 1.0f;
        MapService.CameraPanX = 0f;
        MapService.CameraPanY = 0f;

        objRef = DotNetObjectReference.Create(this);

        // === TURBO DE HARDWARE SEGURO (Universal) ===
        // 1. Impede o GDAL de vasculhar a pasta do Windows
        OSGeo.GDAL.Gdal.SetConfigOption("GDAL_DISABLE_READDIR_ON_OPEN", "EMPTY_DIR");

        // 2. Aloca 2048 Megabytes (2GB) de RAM puros. O GDAL lê valores pequenos (<100.000) nativamente como MB.
        OSGeo.GDAL.Gdal.SetConfigOption("GDAL_CACHEMAX", "4096");

        // 3. [NOVO] Ativa o cache VSI (Virtual File System) para o GDAL carregar o TIF na RAM.
        OSGeo.GDAL.Gdal.SetConfigOption("VSI_CACHE", "TRUE");

        // 4. [NOVO] Obriga a carregar buffers de 128 MB (em bytes) na frente do cursor.
        OSGeo.GDAL.Gdal.SetConfigOption("VSI_CACHE_SIZE", "134217728");

        _server = new GeoNex.Services.LocalMapServer(MapService);
        _server.Start();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await Task.Delay(100);
            try { await _mapContainerRef.FocusAsync(); } catch { }

            var dimensoes = await JSRuntime.InvokeAsync<DimensoesTela>("dimensoesJanela.obter");
            _larguraTela = dimensoes.largura > 0 ? dimensoes.largura : 1920;
            _alturaTela = dimensoes.altura > 0 ? dimensoes.altura : 1080;

            await JSRuntime.InvokeVoidAsync("dimensoesJanela.registrarResize", objRef);
            await JSRuntime.InvokeVoidAsync("mapEngine.init", objRef);
            await JSRuntime.InvokeVoidAsync("mapEngine.setFerramenta", _ferramentaAtiva.ToString()); // <-- ADICIONAR ESTA LINHA
            SolicitarNovoFrame();

            // JAVASCRIPT REMOVIDO: O C# agora assume o controlo absoluto!
        }
    }

