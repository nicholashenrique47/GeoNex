@page "/"
@inject IJSRuntime JSRuntime
@implements IDisposable
@inject GeoNex.Services.ProjetoService ProjetoService
@inject GeoNex.Services.RasterService RasterService
@inject GeoNex.Services.MapRenderingService MapService
@using SkiaSharp
@using SkiaSharp.Views.Blazor
@using ProjNet.CoordinateSystems
@using ProjNet.CoordinateSystems.Transformations
@using GeoNex.Services
<PageTitle>GeoNex - Professional GIS</PageTitle>

<div id="map-container"
     tabindex="0"
     @onpointerdown="ProcessarPressionarMouse"
     @onpointermove="ProcessarMovimentoMouse"
     @onpointerup="ProcessarSoltarMouse"
     @oncontextmenu:preventDefault="true"
     style="cursor: @EstiloCursor; width: 100vw; height: 100vh; background-color: #161921; position: absolute; left:0; top:0; z-index: 0; overflow: hidden; user-select: none; -webkit-user-select: none;">
    <img id="skia-buffer" style="width: 100%; height: 100%; object-fit: contain; pointer-events: none; position: absolute; left: 0; top: 0; opacity: 0;" />
    <img id="skia-layer" style="width: 100%; height: 100%; object-fit: contain; pointer-events: none; position: absolute; left: 0; top: 0; opacity: 1;" />

    <canvas id="overlayCanvas" style="width: 100%; height: 100%; position: absolute; left: 0; top: 0; pointer-events: none; z-index: 10;"></canvas>
</div>

<!-- A INTERFACE FLUTUANTE -->
<div class="geonex-ui">

    <!-- BARRA SUPERIOR (HEADER & RIBBON) -->
    <header class="glass-panel top-bar" style="display: flex; align-items: center; justify-content: flex-start; padding: 0 20px; gap: 15px;">

        <div class="brand-group" style="margin-right: 15px;">
            <h1>GEONEX</h1>
            <span class="sub-brand">PRO</span>
        </div>

        <nav class="main-menu" style="display: flex; height: 100%; align-items: stretch; margin-right: auto;">

            <div class="dropdown" style="display: flex; align-items: center; height: 100%;">
                <button class="menu-btn">Arquivo ▾</button>
                <div class="dropdown-content">
                    <button @onclick="CriarNovoProjeto">Novo Projeto</button>
                    <button>Abrir Projeto...</button>
                    <div class="drop-divider"></div>
                    <button>Salvar</button>
                    <button>Salvar Como...</button>
                    <div class="drop-divider"></div>
                    <button>Sincronizar Nuvem</button> <div class="drop-divider"></div>
                    <button>Configurações do Sistema</button>
                    <button>Sair</button>
                </div>
            </div>

            <div class="dropdown" style="display: flex; align-items: center; height: 100%;">
                <button class="menu-btn">Dados ▾</button>
                <div class="dropdown-content">

                    <div class="dropdown-submenu">
                        <button class="submenu-btn">
                            <span>Importar Fontes Locais</span>
                            <span style="font-size: 0.7rem; color: #64748b;">▸</span>
                        </button>

                        <div class="submenu-content">
                            <button class="drop-item" @onclick='() => { AbrirModalImportacao(); TrocarAbaModal("Raster"); }'>
                                Raster (ECW, TIF)
                            </button>

                            <button class="drop-item" @onclick='() => { AbrirModalImportacao(); TrocarAbaModal("Vetor"); }'>
                                Vetor (SHP, GeoJSON)
                            </button>

                            <button class="drop-item" @onclick='() => { AbrirModalImportacao(); TrocarAbaModal("Texto"); }'>
                                Pontos (CSV, TXT)
                            </button>
                        </div>
                    </div>
                    <div class="drop-divider"></div>
                    <button class="drop-item">Conectar Banco PostGIS</button>
                </div>
            </div>

            <div class="dropdown" style="display: flex; align-items: center; height: 100%;">
                <button class="menu-btn" style="@(_ferramentaAtiva == ModoFerramenta.Identificacao ? "color: #38bdf8;" : "")">Aquisição ▾</button>
                <div class="dropdown-content">
                    <button class="drop-item" style="@(_ferramentaAtiva == ModoFerramenta.Navegacao ? "background: #0284c7; color: white;" : "")" @onclick="() => TrocarFerramenta(ModoFerramenta.Navegacao)">
                        Mover Mapa (Pan)
                    </button>
                    <button class="drop-item" style="@(_ferramentaAtiva == ModoFerramenta.Identificacao ? "background: #0284c7; color: white;" : "")" @onclick="() => TrocarFerramenta(ModoFerramenta.Identificacao)">
                        Identificar / Selecionar
                    </button>
                   
                    <button class="drop-item" style="@(_ferramentaAtiva == ModoFerramenta.Medicao ? "background: #0284c7; color: white;" : "")" @onclick="() => TrocarFerramenta(ModoFerramenta.Medicao)">
                        Régua Topográfica
                    </button>
                    <button class="drop-item" style="@(_ferramentaAtiva == ModoFerramenta.AquisicaoPoligono ? "background: #0284c7; color: white;" : "")" @onclick="() => TrocarFerramenta(ModoFerramenta.AquisicaoPoligono)">
                        Desenhar Novo Polígono
                    </button>
                </div>
            </div>

            <div class="dropdown" style="display: flex; align-items: center; height: 100%;">
                <button class="menu-btn" style="@(modoEdicaoVerticeLigado ? "color: #38bdf8; font-weight: bold;" : "")">Edição ▾</button>
                <div class="dropdown-content">
                    <button style="@(modoEdicaoVerticeLigado ? "color: #38bdf8; font-weight: bold; background: rgba(56, 189, 248, 0.1);" : "")" @onclick="AlternarEdicaoVertices">
                        @(modoEdicaoVerticeLigado ? "Modo Vértices [ ATIVO ]" : "Ativar Edição de Vértices")
                    </button>
                    <button>Cortar Geometria</button>
                    <button>Mesclar Polígonos</button>
                </div>
            </div>

            <div class="dropdown" style="display: flex; align-items: center; height: 100%;">
                <button class="menu-btn">Exportar ▾</button>
                <div class="dropdown-content">
                    <button>Exportar Vetor (Shapefile)</button>
                    <button>Exportar Tabela (CSV)</button>
                </div>
            </div>

            <div class="dropdown" style="display: flex; align-items: center; height: 100%;">
                <button class="menu-btn">GNSS / RTK ▾</button>
                <div class="dropdown-content">
                    <button>Gerenciador de Conexão (COM/BT)</button>
                    <button>Monitor NMEA (Satélites)</button>
                </div>
            </div>
        </nav>

        <div style="display: flex; align-items: center; gap: 15px;">

            <button class="tool-btn"
                    style="@(temEdicoesPendentes ? "color: #facc15; border: 1px solid #facc15; font-weight: bold; background: rgba(250, 204, 21, 0.1);" : "opacity: 0.3; cursor: not-allowed; border: 1px solid rgba(255,255,255,0.1);")"
                    @onclick="ConfirmarTodasEdicoes"
                    disabled="@(!temEdicoesPendentes)">
                SALVAR EDIÇÕES
            </button>

            <div class="vertical-divider" style="height: 20px;"></div>

            <div class="status-group" style="padding: 0 5px;">
                <span class="status-indicator online"></span>
                <span class="status-text">API CONECTADA</span>
            </div>

            <button class="btn" style="background: transparent; border: 1px solid rgba(255,255,255,0.1); color: #94a3b8; font-size: 0.65rem; font-weight: bold; padding: 4px 8px; border-radius: 4px; cursor: pointer;" @onclick="TestarMotorCPlusPlus" title="Diagnóstico de Motor">
                CORE C++
            </button>
        </div>

    </header>
    <!-- ========================================================= -->
    <!-- PAINEL FLUTUANTE DE DESENHO (AQUISIÇÃO)                   -->
    <!-- ========================================================= -->
    <!-- ========================================================= -->
    <!-- PAINEL FLUTUANTE DE DESENHO (AQUISIÇÃO)                   -->
    <!-- ========================================================= -->
    <!-- ========================================================= -->
    <!-- PAINEL FLUTUANTE DE DESENHO (AQUISIÇÃO)                   -->
    <!-- ========================================================= -->
    <!-- ========================================================= -->
    <!-- PAINEL FLUTUANTE DE DESENHO (AQUISIÇÃO)                   -->
    <!-- ========================================================= -->
    @if (_ferramentaAtiva == ModoFerramenta.AquisicaoPoligono)
    {
        <div class="glass-panel" style="position: absolute; top: 80px; left: 50%; transform: translateX(-50%); background: rgba(30, 41, 59, 0.85); border: 1px solid rgba(255, 255, 255, 0.1); padding: 8px 20px; border-radius: 12px; z-index: 9999; display: flex; gap: 15px; align-items: center; box-shadow: 0 8px 32px rgba(0,0,0,0.3); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);">

            <span style="color: #f8fafc; font-weight: 600; font-size: 14px; letter-spacing: 0.5px; border-right: 1px solid rgba(255,255,255,0.2); padding-right: 15px; margin-right: 5px;">
                MODO DESENHO
            </span>

            <!-- NOVO: SELETOR DE CAMADA ALVO -->
            <select value="@_camadaDestinoAquisicao" @onchange="AoMudarCamadaDestino" style="background: rgba(0,0,0,0.3); border: 1px solid rgba(255,255,255,0.1); color: #38bdf8; padding: 6px 10px; border-radius: 4px; font-weight: bold; outline: none; cursor: pointer; max-width: 220px;">
                <option value="" disabled selected>[ Selecione o Destino ]</option>
                <option value="NOVA" style="background: #064e3b; color: #34d399;">+ Criar Novo Ficheiro...</option>
                @foreach (var camada in CamadasAtivas.Where(c => c.Tipo == "Vetor"))
                {
                    <option value="@camada.Nome">@camada.Nome</option>
                }
            </select>

            <div style="width: 1px; height: 20px; background: rgba(255,255,255,0.2);"></div>

            <!-- O BOTÃO SUSPENSO (DROPDOWN) DE SNAP -->
            <div class="dropdown" style="display: flex; align-items: center; height: 100%;">
                <button class="menu-btn" style="color: @(_snapAquisicaoVertice || _snapAquisicaoAresta ? "#38bdf8" : "#cbd5e1"); font-weight: bold; background: transparent; border: none; cursor: pointer;">
                    SNAP ▾
                </button>
                <div class="dropdown-content" style="top: 100%; left: 0; min-width: 180px; margin-top: 10px;">
                    <button class="drop-item" style="display: flex; justify-content: space-between; align-items: center; color: @(_snapAquisicaoVertice ? "#38bdf8" : "#cbd5e1"); background: @(_snapAquisicaoVertice ? "rgba(56, 189, 248, 0.1)" : "transparent");" @onclick="() => _snapAquisicaoVertice = !_snapAquisicaoVertice">
                        <span>Atrair Vértices</span>
                        <span style="font-weight: bold; font-size: 0.7rem;">@(_snapAquisicaoVertice ? "ON" : "")</span>
                    </button>
                    <button class="drop-item" style="display: flex; justify-content: space-between; align-items: center; color: @(_snapAquisicaoAresta ? "#38bdf8" : "#cbd5e1"); background: @(_snapAquisicaoAresta ? "rgba(56, 189, 248, 0.1)" : "transparent");" @onclick="() => _snapAquisicaoAresta = !_snapAquisicaoAresta">
                        <span>Atrair Arestas</span>
                        <span style="font-weight: bold; font-size: 0.7rem;">@(_snapAquisicaoAresta ? "ON" : "")</span>
                    </button>
                </div>
            </div>

            <div style="width: 1px; height: 20px; background: rgba(255,255,255,0.2);"></div>

            <button class="btn-clean" @onclick="DesfazerUltimoPontoAquisicao" title="Desfazer (Backspace)" disabled="@(MapService.PontosAquisicao.Count == 0)" style="background: transparent; border: none; color: #cbd5e1; font-weight: 500; cursor: pointer; transition: 0.2s; opacity: @(MapService.PontosAquisicao.Count == 0 ? "0.5" : "1");">
                DESFAZER
            </button>

            <button class="btn-clean" @onclick="CancelarAquisicao" title="Cancelar Desenho (Esc)" style="background: transparent; border: none; color: #f87171; font-weight: 500; cursor: pointer; transition: 0.2s;">
                CANCELAR
            </button>

            <button class="btn-clean" @onclick="ConcluirAquisicaoPoligono" title="Finalizar Polígono (Clique Direito ou Enter)" disabled="@(MapService.PontosAquisicao.Count < 3)" style="background: transparent; border: none; color: #34d399; font-weight: bold; cursor: pointer; transition: 0.2s; opacity: @(MapService.PontosAquisicao.Count < 3 ? "0.5" : "1");">
                CONCLUIR
            </button>
        </div>
    }
    <!-- PAINÉIS LATERAIS E ÁREA DE TRABALHO -->
    <main class="workspace-area">

        <!-- PAINEL ESQUERDO: CAMADAS -->
        <aside class="glass-panel side-panel left-panel">
            <div class="panel-header">
                <h2>CAMADAS</h2>
                <div class="header-actions">
                    <button class="icon-action-btn">+</button>
                </div>
            </div>

            <div class="layer-list custom-scrollbar" @onpointerup="FinalizarArraste">
                @foreach (var camada in CamadasAtivas)
                {
                    var camadaAtual = camada;

                    // Deteta se esta é a camada que o utilizador tem agarrada neste momento
                    bool sendoArrastada = (camadaArrastada == camadaAtual);

                    <div @key="camadaAtual.Nome"
                         class="layer-item @(camadaAtual.Tipo.ToLower()) @(sendoArrastada ? "is-dragging" : "")"
                         @onpointerenter="() => AoSobrevoarCamada(camadaAtual)"
                         @oncontextmenu="(e) => MostrarMenuContexto(e, camadaAtual.Nome)"
                         @oncontextmenu:preventDefault="true">

                        <div class="drag-handle" title="Arrastar para reordenar"
                             @onpointerdown="() => IniciarArraste(camadaAtual)"
                             @onpointerdown:stopPropagation="true">
                            <svg style="pointer-events: none;" width="14" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <circle cx="9" cy="12" r="1.5"></circle>
                                <circle cx="9" cy="5" r="1.5"></circle>
                                <circle cx="9" cy="19" r="1.5"></circle>
                                <circle cx="15" cy="12" r="1.5"></circle>
                                <circle cx="15" cy="5" r="1.5"></circle>
                                <circle cx="15" cy="19" r="1.5"></circle>
                            </svg>
                        </div>

                        <input type="checkbox" checked="@camadaAtual.Visivel" @onchange="@(e => ToggleCamada(camadaAtual, (bool)(e.Value ?? false)))" />
                        <span class="type-tag" style="background: @(camadaAtual.Tipo == "Raster" ? "#5b21b6" : "#065f46"); color: @(camadaAtual.Tipo == "Raster" ? "#ddd6fe" : "#a7f3d0");">
                            @(camadaAtual.Tipo == "Raster" ? "R" : "V")
                        </span>
                        <span class="layer-title no-select" title="@camadaAtual.Nome">@camadaAtual.Nome</span>

                        @if (camadaAtual.Tipo == "Vetor")
                        {
                            <div class="layer-actions" style="display: flex; gap: 5px; margin-left: auto;">
                                <button type="button" class="layer-action-btn" title="Abrir Tabela de Atributos" @onclick="() => AbrirTabela(camadaAtual.Nome)" @onclick:stopPropagation="true">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><line x1="3" y1="9" x2="21" y2="9"></line><line x1="9" y1="21" x2="9" y2="9"></line></svg>
                                </button>
                                <button type="button" class="layer-action-btn" title="Propriedades da Camada" @onclick="() => AbrirPropriedadesSincronizadas(camadaAtual.Nome)" @onclick:stopPropagation="true">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"></circle><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"></path></svg>
                                </button>
                                <button type="button" class="layer-action-btn" title="Opções da Camada" @onclick="(e) => BotaoOpcoesClicado(e, camadaAtual.Nome)" @onclick:stopPropagation="true">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="1"></circle><circle cx="12" cy="5" r="1"></circle><circle cx="12" cy="19" r="1"></circle></svg>
                                </button>
                            </div>
                        }
                    </div>
                }
            </div>
        </aside>

        <!-- O PAINEL SENSORIAL BLINDADO -->
       
        <!-- PAINEL DIREITO: ATRIBUTOS -->
        <aside class="glass-panel side-panel right-panel">
            <div class="panel-header">
                <h2>@(_ferramentaAtiva == ModoFerramenta.Medicao ? "FERRAMENTAS DE MEDIÇÃO" : "ATRIBUTOS DA FEIÇÃO")</h2>
            </div>

            <div class="properties-content custom-scrollbar" style="padding: 15px;">

                @if (_ferramentaAtiva == ModoFerramenta.Medicao)
                {
                    <div style="background: rgba(0,0,0,0.3); padding: 12px; border-radius: 6px; border: 1px solid rgba(255,255,255,0.05); margin-bottom: 20px;">
                        <span style="font-size: 0.65rem; color: #94a3b8; font-weight: bold; text-transform: uppercase; letter-spacing: 1px; display: block; margin-bottom: 10px;">Opções de Mensura</span>

                        <div style="display: flex; gap: 10px;">
                            <button class="tool-btn @(_snapMedicaoAtivo ? "active" : "")"
                                    @onclick="() => _snapMedicaoAtivo = !_snapMedicaoAtivo"
                                    title="Atrair para Vértices (Snap Magnético)"
                                    style="font-size: 1.2rem; padding: 6px 12px;">
                                🧲
                            </button>

                            <button class="tool-btn @(MapService.MostrarAreaMedicao ? "active" : "")"
                                    @onclick="@(() => { MapService.MostrarAreaMedicao = !MapService.MostrarAreaMedicao; _ = SincronizarOverlay(false); RecalcularMedicoes(); StateHasChanged(); })"
                                    title="Calcular e Desenhar Área Poligonal"
                                    style="font-size: 1.2rem; padding: 6px 12px;">
                                📐
                            </button>
                        </div>
                    </div>

                    <div style="display: flex; flex-direction: column; gap: 20px; padding: 10px 5px;">
                        <div class="form-group-vertical" style="background: rgba(0,0,0,0.2); padding: 15px; border-radius: 6px; border: 1px solid rgba(255,255,255,0.05);">
                            <label style="color: #64748b;">COMPRIMENTO LINEAR</label>
                            <span style="font-family: monospace; font-size: 1.6rem; font-weight: 500; color: #e2e8f0;">@_medicaoComprimentoMetros.ToString("N2") <span style="font-size: 1rem; color: #94a3b8;">m</span></span>
                        </div>

                        @if (MapService.MostrarAreaMedicao && MapService.PontosMedicao.Count >= 3)
                        {
                            <div class="form-group-vertical" style="background: rgba(0,0,0,0.2); padding: 15px; border-radius: 6px; border: 1px solid rgba(255,255,255,0.05);">
                                <label style="color: #64748b;">ÁREA PLANA FECHADA</label>
                                <span style="font-family: monospace; font-size: 1.6rem; font-weight: 500; color: #38bdf8;">@_medicaoAreaM2.ToString("N2") <span style="font-size: 1rem; color: #94a3b8;">m²</span></span>
                            </div>
                        }

                        <button class="btn-cancel" style="width: 100%; margin-top: 10px; border-color: rgba(239, 68, 68, 0.3); color: #f87171;" @onclick="LimparMedicao">
                            LIMPAR RASTRO
                        </button>
                    </div>
                }
                else
                {
                    @if (atributosFeicaoSelecionada != null && atributosFeicaoSelecionada.Count > 0)
                    {
                        <div class="attribute-form">
                            <div class="form-group mb-15" style="border-bottom: 1px solid rgba(255,255,255,0.1); padding-bottom: 10px;">
                                <label>Camada Origem</label>
                                <span style="font-size: 0.75rem; color: #38bdf8; font-weight: bold; word-break: break-all;">@camadaSelecionadaPainel</span>
                            </div>

                            @foreach (var atributo in atributosFeicaoSelecionada)
                            {
                                <div class="form-group">
                                    <label>@atributo.Key</label>
                                    @if (atributo.Key.ToUpper() == "FID" || atributo.Key.ToUpper() == "ID")
                                    {
                                        <input type="text" class="glass-input" value="@atributo.Value" readonly style="opacity: 0.6;" />
                                    }
                                    else
                                    {
                                        <input type="text" class="glass-input editable" value="@atributo.Value" @onchange="(e) => AtualizarAtributoPainel(atributo.Key, e.Value.ToString())" />
                                    }
                                </div>
                            }
                            <button class="btn-save add-layer-btn" style="width: 100%; margin-top: 20px;" @onclick="SalvarAtributosPainel">SALVAR ALTERAÇÕES</button>
                        </div>
                    }
                    else
                    {
                        <div style="display: flex; height: 100%; align-items: center; justify-content: center; color: #64748b; font-size: 0.85rem; text-align: center; padding: 20px; flex-direction: column; gap: 10px;">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
                            <span>Selecione um polígono no mapa para inspecionar seus atributos.</span>
                        </div>
                    }
                }
            </div>
        </aside>

    </main>
    <main class="workspace-area">
    </main>

    @if (exibirTabelaAtributos)
    {
        <div class="glass-panel attribute-table-container">
            <div class="table-header">
                <span>TABELA DE ATRIBUTOS: @nomeCamadaAtiva</span>
                <button class="close-btn" @onclick="() => exibirTabelaAtributos = false">✕</button>
            </div>
            <div class="table-wrapper custom-scrollbar">
                <table>
                    <thead>
                        <tr>
                            @foreach (var col in colunasTabela)
                            {
                                <th>@col</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var linha in dadosTabela)
                        {
                            <tr @onclick="() => SelecionarNoMapa(linha)">
                                @foreach (var col in colunasTabela)
                                {
                                    <td>
                                        <input class="cell-input"
                                               value="@(linha.ContainsKey(col) ? linha[col] : "")"
                                               @onchange="(e) => AtualizarAtributo(linha, col, e.Value)" />
                                    </td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

    <footer class="bottom-status-bar">
    </footer>
    <!-- RODAPÉ DE TELEMETRIA -->
    <footer class="bottom-status-bar">
        <div class="status-left">
            <span><strong>PROJETO:</strong> Guaratuba_ZonaSul.gnx</span>
        </div>
        <div class="status-right">
            <span><strong>X:</strong> <span class="mono">@longitude</span></span>
