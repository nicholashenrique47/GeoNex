    private DateTime _ultimoMovimentoMouse = DateTime.MinValue;

    private async Task ProcessarMovimentoMouse(Microsoft.AspNetCore.Components.Web.PointerEventArgs e)
    {
        bool precisaRenderizarServidor = false;
        bool precisaAtualizarCanvasOverlay = false;

        // 1. A MATEMÁTICA DO PAN (Executa sempre para não perder nenhum milímetro do rato)
        if (_isPanning)
        {
            float dx = (float)(e.OffsetX - _lastMouseX);
            float dy = (float)(e.OffsetY - _lastMouseY);

            MapService.CameraPanX += dx;
            MapService.CameraPanY += dy;

            _lastMouseX = e.OffsetX;
            _lastMouseY = e.OffsetY;

            precisaRenderizarServidor = true;
        }

        // 2. A MATEMÁTICA DA MEDIÇÃO / SNAP (Só executa se não estiver a usar o Pan)
        else if (_ferramentaAtiva == ModoFerramenta.Medicao)
        {
            SkiaSharp.SKRect limitesTotais = new SkiaSharp.SKRect();
            bool primeiro = true;
            if (MapService.TemRaster) { limitesTotais = MapService.LimitesRasterGlobal; primeiro = false; }
            foreach (var path in MapService.VetoresPorCamada.Values) { if (primeiro) { limitesTotais = path.Bounds; primeiro = false; } else { limitesTotais.Union(path.Bounds); } }
            foreach (var path in MapService.LinhasPorCamada.Values) { if (primeiro) { limitesTotais = path.Bounds; primeiro = false; } else { limitesTotais.Union(path.Bounds); } }
            foreach (var path in MapService.PontosPorCamada.Values) { if (primeiro) { limitesTotais = path.Bounds; primeiro = false; } else { limitesTotais.Union(path.Bounds); } }

            if (!limitesTotais.IsEmpty)
            {
                float escalaX = _larguraTela / limitesTotais.Width;
                float escalaY = _alturaTela / limitesTotais.Height;
                float escalaAutoFit = Math.Min(escalaX, escalaY) * 0.8f;

                var matriz = SkiaSharp.SKMatrix.CreateTranslation(-limitesTotais.MidX, -limitesTotais.MidY);
                matriz = matriz.PostConcat(SkiaSharp.SKMatrix.CreateScale(escalaAutoFit * MapService.CameraZoom, escalaAutoFit * MapService.CameraZoom));
                matriz = matriz.PostConcat(SkiaSharp.SKMatrix.CreateTranslation(_larguraTela / 2f + MapService.CameraPanX, _alturaTela / 2f + MapService.CameraPanY));

                if (matriz.TryInvert(out var matrizInversa))
                {
                    var ptMundo = matrizInversa.MapPoint(new SkiaSharp.SKPoint((float)e.OffsetX, (float)e.OffsetY));
                    MapService.PontoCursorMundo = ptMundo;

                    if (_snapMedicaoAtivo)
                    {
                        float toleranciaSnap = (float)(15.0 / (escalaAutoFit * MapService.CameraZoom));
                        var ptMagnetico = MapService.EncontrarVerticeProximo(ptMundo, toleranciaSnap);

                        if (ptMagnetico.HasValue)
                        {
                            MapService.PontoCursorSnap = ptMagnetico.Value;
                            MapService.PontoCursorMundo = ptMagnetico.Value;
                        }
                        else
                        {
                            MapService.PontoCursorSnap = null;
                        }
                    }
                    else
                    {
                        MapService.PontoCursorSnap = null;
                    }
                    precisaAtualizarCanvasOverlay = true;
                }
            }
        }

        // 3. SELEÇÃO INTELIGENTE DE RENDERING PIPELINE (60 FPS REAL)
        if (precisaRenderizarServidor)
        {
            if ((DateTime.Now - _ultimoMovimentoMouse).TotalMilliseconds >= 16)
            {
                _ultimoMovimentoMouse = DateTime.Now;
                SolicitarNovoFrame(); // Pan aciona renderização do fundo estático via servidor
            }
        }
        else if (precisaAtualizarCanvasOverlay)
        {
            if ((DateTime.Now - _ultimoMovimentoMouse).TotalMilliseconds >= 16)
            {
                _ultimoMovimentoMouse = DateTime.Now;

                // Atualiza as propriedades numéricas da UI lateral
                if (MapService.PontosMedicao.Count > 0)
                {
                    RecalcularMedicoes();
                    StateHasChanged();
                }

                // Desenho imediato na GPU local via Canvas Overlay (0ms HTTP Cost)
                await AtualizarCanvasOverlayLocal();
            }
        }
    }
    // =========================================================================
    // 16. ATALHOS DE TECLADO (ESC, ENTER)
    // =========================================================================
    private void ProcessarTeclado(Microsoft.AspNetCore.Components.Web.KeyboardEventArgs e)
    {
        if (e.Key == "Escape")
        {
            if (_ferramentaAtiva == ModoFerramenta.Medicao)
            {
                LimparMedicao(); // Aborta a medição instantaneamente
            }
            // Futuramente: Se estiver a desenhar um lote (AquisicaoPoligono), abortar também.
        }
    }
    // =========================================================================
    // 17. MOTOR DE NAVEGAÇÃO (PAN COM BOTÃO DO MEIO - PADRÃO CAD)
    // =========================================================================
    private bool _isPanning = false;
    private double _lastMouseX = 0;
    private double _lastMouseY = 0;

    private async Task ProcessarPressionarMouse(Microsoft.AspNetCore.Components.Web.PointerEventArgs e)
    {
        // e.Button == 1 é o botão do meio (Roda do Rato)
        if (e.Button == 1)
        {
            _isPanning = true;
            MapService.IsPanning = true; // AVISA A GPU: "O arrasto começou!"
            _lastMouseX = e.OffsetX;
            _lastMouseY = e.OffsetY;
            return;
        }

        // e.Button == 0 é o clique Esquerdo normal
        if (e.Button == 0)
        {
            await ProcessarCliqueRaycast(e.OffsetX, e.OffsetY);
        }
    }

    private void ProcessarSoltarMouse(Microsoft.AspNetCore.Components.Web.PointerEventArgs e)
    {
        // Quando larga a roda do rato, a câmara pára de ser arrastada
        if (e.Button == 1)
        {
            _isPanning = false;
            MapService.IsPanning = false; // AVISA A GPU: "Largou o rato!"
            SolicitarNovoFrame(); // Força a placa a renderizar as bordas da Ortofoto
        }
    }
    private SkiaSharp.SKPoint MatrizMundoParaTela(SkiaSharp.SKPoint ptMundo)
    {
        SkiaSharp.SKRect limitesTotais = new SkiaSharp.SKRect();
        bool primeiro = true;

        if (MapService.TemRaster) { limitesTotais = MapService.LimitesRasterGlobal; primeiro = false; }
        foreach (var path in MapService.VetoresPorCamada.Values) { if (primeiro) { limitesTotais = path.Bounds; primeiro = false; } else { limitesTotais.Union(path.Bounds); } }
        foreach (var path in MapService.LinhasPorCamada.Values) { if (primeiro) { limitesTotais = path.Bounds; primeiro = false; } else { limitesTotais.Union(path.Bounds); } }
        foreach (var path in MapService.PontosPorCamada.Values) { if (primeiro) { limitesTotais = path.Bounds; primeiro = false; } else { limitesTotais.Union(path.Bounds); } }

        if (limitesTotais.IsEmpty) return ptMundo;

        float escalaX = _larguraTela / limitesTotais.Width;
        float escalaY = _alturaTela / limitesTotais.Height;
        float escalaAutoFit = Math.Min(escalaX, escalaY) * 0.8f;

        // Criação da matriz direta de projeção para a viewport ativa
        var matriz = SkiaSharp.SKMatrix.CreateTranslation(-limitesTotais.MidX, -limitesTotais.MidY);
        matriz = matriz.PostConcat(SkiaSharp.SKMatrix.CreateScale(escalaAutoFit * MapService.CameraZoom, escalaAutoFit * MapService.CameraZoom));
        matriz = matriz.PostConcat(SkiaSharp.SKMatrix.CreateTranslation(_larguraTela / 2f + MapService.CameraPanX, _alturaTela / 2f + MapService.CameraPanY));

        return matriz.MapPoint(ptMundo);
    }

    // =========================================================================
    // PIPELINE DE ATUALIZAÇÃO DO CANVAS OVERLAY VIA INTEROP JAVASCRIPT
    // =========================================================================
    private async Task AtualizarCanvasOverlayLocal()
    {
        // Converte as coordenadas geográficas estáveis para píxeis inteiros de tela
        var pontosTela = MapService.PontosMedicao
            .Select(p => { var pt = MatrizMundoParaTela(p); return new { x = pt.X, y = pt.Y }; })
            .ToList();

        var mouseMundo = MapService.PontoCursorMundo;
        var mouseTela = mouseMundo.HasValue
            ? new { x = MatrizMundoParaTela(mouseMundo.Value).X, y = MatrizMundoParaTela(mouseMundo.Value).Y }
            : null;

        var snapMundo = MapService.PontoCursorSnap;
        var snapTela = snapMundo.HasValue
            ? new { x = MatrizMundoParaTela(snapMundo.Value).X, y = MatrizMundoParaTela(snapMundo.Value).Y }
            : null;

        // Invocação imediata do contexto gráfico 2D do navegador
        await JSRuntime.InvokeVoidAsync("GeoNexGraphics.atualizarOverlay", pontosTela, mouseTela, snapTela);
    }
