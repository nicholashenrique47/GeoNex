    // =========================================================================
    // MOTOR DE CÁLCULO TOPOGRÁFICO
    // =========================================================================
    private double _medicaoComprimentoMetros = 0;
    private double _medicaoAreaM2 = 0;

    private void RecalcularMedicoes()
    {
        _medicaoComprimentoMetros = 0;
        _medicaoAreaM2 = 0;

        // Cria uma lista temporária unindo os cliques REAIS com a posição flutuante do RATO
        var ptsMapeados = new List<SkiaSharp.SKPoint>(MapService.PontosMedicao);

        if (_ferramentaAtiva == ModoFerramenta.Medicao && ptsMapeados.Count > 0 && MapService.PontoCursorMundo.HasValue)
        {
            ptsMapeados.Add(MapService.PontoCursorMundo.Value);
        }

        if (ptsMapeados.Count < 2) return;

        // 1. Distância Linear Euclidiana
        for (int i = 1; i < ptsMapeados.Count; i++)
        {
            double dx = ptsMapeados[i].X - ptsMapeados[i - 1].X;
            double dy = ptsMapeados[i].Y - ptsMapeados[i - 1].Y;
            _medicaoComprimentoMetros += Math.Sqrt(dx * dx + dy * dy);
        }

        // 2. Área Poligonal (Fórmula de Shoelace)
        if (ptsMapeados.Count >= 3 && MapService.MostrarAreaMedicao)
        {
            double area = 0;
            int j = ptsMapeados.Count - 1;
            for (int i = 0; i < ptsMapeados.Count; i++)
            {
                area += (ptsMapeados[j].X + ptsMapeados[i].X) * (ptsMapeados[j].Y - ptsMapeados[i].Y);
                j = i;
            }
            _medicaoAreaM2 = Math.Abs(area / 2.0);
        }
    }

    // =========================================================================
    // 16. ATALHOS DE TECLADO (ESC, M, I)
    // =========================================================================
    // =========================================================================
    // 16. ATALHOS DE TECLADO GLOBAIS (ESC, M, I)
    // =========================================================================
    [JSInvokable]
    public void ProcessarTecladoGlobal(string tecla)
    {
        // A MÁGICA: Transfere o sinal do JavaScript para a Thread Visual do Blazor
        InvokeAsync(async () =>
        {
            tecla = tecla.ToLower();

            // 1. ATALHOS ABSOLUTOS GLOBAIS
            if (tecla == "m") { TrocarFerramenta(ModoFerramenta.Medicao); return; }
            if (tecla == "i") { TrocarFerramenta(ModoFerramenta.Identificacao); return; }
            if (tecla == "d" || tecla == "p") { TrocarFerramenta(ModoFerramenta.AquisicaoPoligono); return; }

            // 2. ATALHOS EXCLUSIVOS DA FERRAMENTA DE DESENHO
            if (_ferramentaAtiva == ModoFerramenta.AquisicaoPoligono)
            {
                if (tecla == "tab")
                {
                    _mostrarInputCogo = true;
                    _mostrarInputAbsoluto = false;
                    _mostrarMenuContexto = false;
                    StateHasChanged();

                    // Espera 50ms para o HTML renderizar e foca no campo automaticamente
                    await Task.Delay(50);
                    try { await _inputDistanciaRef.FocusAsync(); } catch { }
                    return;
                }

                if (tecla == "f6")
                {
                    _mostrarInputAbsoluto = true;
                    _mostrarInputCogo = false;
                    _mostrarMenuContexto = false;
                    StateHasChanged();

                    await Task.Delay(50);
                    try { await _inputAbsolutoXRef.FocusAsync(); } catch { }
                    return;
                }

                if (tecla == "escape") { CancelarAquisicao(); return; }
                if (tecla == "z" || tecla == "ctrl+z" || tecla == "backspace") { DesfazerUltimoPontoAquisicao(); return; }
                if (tecla == "enter" || tecla == "c") { ConcluirAquisicaoPoligono(); return; }
            }

            // 3. ATALHOS GLOBAIS DE CANCELAMENTO (ESC)
            if (tecla == "escape")
            {
                if (_ferramentaAtiva == ModoFerramenta.Medicao)
                {
                    LimparMedicao();
                }
                else if (_ferramentaAtiva == ModoFerramenta.Identificacao)
                {
                    MapService.DestacarFeicao(null);
                    camadaSelecionadaPainel = string.Empty;
                    atributosFeicaoSelecionada?.Clear();
                    _geometriaDestacada = null;

                    _ = SincronizarOverlay(false);
                    SolicitarNovoFrame();
                    StateHasChanged();
                }
            }
        });
    }
    private void LimparMedicao()
    {
        MapService.PontosMedicao.Clear();
        MapService.PontoCursorSnap = null;
        MapService.PontoCursorMundo = null;
        _medicaoComprimentoMetros = 0;
        _medicaoAreaM2 = 0;

        // Limpa o rastro animado do JS (se houver)
        _ = JSRuntime.InvokeVoidAsync("GeoNexGraphics.limparTudo");

        // A CORREÇÃO: Força o C# a gerar a imagem limpa sem a régua!
        SolicitarNovoFrame();

        StateHasChanged();
    }
