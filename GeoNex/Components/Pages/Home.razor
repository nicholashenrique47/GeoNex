    // =========================================================================
    // 5. EVENTOS DO CICLO DE VIDA DA INTERFACE
    // =========================================================================
    protected override void OnInitialized()
    {
        // === PREVENÇÃO DO BUG DO F5 ===
        // Zera a memória do servidor C# sempre que a UI é recarregada
        MapService.CameraZoom = 1.0f;
        MapService.CameraPanX = 0f;
        MapService.CameraPanY = 0f;

        objRef = DotNetObjectReference.Create(this);
        CamadasAtivas.Add(new Camada { Nome = "OpenStreetMap", Tipo = "Raster", Visivel = true });

        // === TURBO DE HARDWARE SEGURO (Universal) ===
        // 1. Impede o GDAL de vasculhar a pasta do Windows
        OSGeo.GDAL.Gdal.SetConfigOption("GDAL_DISABLE_READDIR_ON_OPEN", "EMPTY_DIR");

        // 2. Aloca 2048 Megabytes (2GB) de RAM puros. O GDAL lê valores pequenos (<100.000) nativamente como MB.
        OSGeo.GDAL.Gdal.SetConfigOption("GDAL_CACHEMAX", "2048");

        _server = new GeoNex.Services.LocalMapServer(MapService);
        _server.Start();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var dimensoes = await JSRuntime.InvokeAsync<DimensoesTela>("dimensoesJanela.obter");
            _larguraTela = dimensoes.largura > 0 ? dimensoes.largura : 1920;
            _alturaTela = dimensoes.altura > 0 ? dimensoes.altura : 1080;

            await JSRuntime.InvokeVoidAsync("dimensoesJanela.registrarResize", objRef);
            await JSRuntime.InvokeVoidAsync("mapEngine.init", objRef);
            SolicitarNovoFrame();
        }
    }

    [JSInvokable]
    public void AtualizarDimensoesTela(int w, int h)
    {
        _larguraTela = w;
        _alturaTela = h;
        SolicitarNovoFrame();
    }

    public void Dispose()
    {
        objRef?.Dispose();
        _server?.Stop();
        
    }

    // =========================================================================
    // 6. PIPELINE DE COMUNICAÇÃO DO MOTOR GRÁFICO (STREAMING BINÁRIO NATIVO)
    // =========================================================================
    private void SolicitarNovoFrame()
    {
        string url = $"{_server.BaseUrl}mapa/?w={_larguraTela}&h={_alturaTela}&t={DateTime.Now.Ticks}";
        InvokeAsync(() => JSRuntime.InvokeVoidAsync("mapEngine.carregarNovoFrame", url));

       
    }

    private async Task AdicionarCamadaAoMapa()
    {
        try
        {
            if (string.IsNullOrEmpty(caminhoArquivoRaster))
            {
                await JSRuntime.InvokeVoidAsync("alert", "Selecione um ficheiro primeiro!");
                return;
            }

            exibirModalImportacao = false;

            // BLINDAGEM 3: Lock no momento da troca de Dataset para evitar choque de Threads
            lock (MapService)
            {
                if (MapService.DatasetRaster != null) MapService.DatasetRaster.Dispose();
                MapService.DatasetRaster = OSGeo.GDAL.Gdal.Open(caminhoArquivoRaster, OSGeo.GDAL.Access.GA_ReadOnly);

                // Prevenção contra ficheiros corrompidos
                if (MapService.DatasetRaster == null)
                {
                    InvokeAsync(() => JSRuntime.InvokeVoidAsync("alert", "O GDAL falhou ao abrir o arquivo. O ficheiro pode estar corrompido."));
                    return;
                }

                if (MapService.DatasetRaster.RasterCount > 0 && MapService.DatasetRaster.GetRasterBand(1).GetOverviewCount() == 0)
                {
                    MapService.DatasetRaster.BuildOverviews("AVERAGE", new int[] { 2, 4, 8, 16, 32 });
                }

                double[] trans = new double[6];
                MapService.DatasetRaster.GetGeoTransform(trans);
                double minX = trans[0];
                double maxY = trans[3];
                double maxX = minX + (MapService.DatasetRaster.RasterXSize * trans[1]);
                double minY = maxY + (MapService.DatasetRaster.RasterYSize * trans[5]);

                double minLng = minX, minLat = minY, maxLng = maxX, maxLat = maxY;

                string wkt = MapService.DatasetRaster.GetProjection();
                if (!string.IsNullOrEmpty(wkt))
                {
                    using (var projOrigem = new OSGeo.OSR.SpatialReference(wkt))
                    using (var projDestino = new OSGeo.OSR.SpatialReference(""))
                    {
                        projDestino.ImportFromEPSG(4326);
                        projDestino.SetAxisMappingStrategy(OSGeo.OSR.AxisMappingStrategy.OAMS_TRADITIONAL_GIS_ORDER);

                        using (var transform = new OSGeo.OSR.CoordinateTransformation(projOrigem, projDestino))
                        {
                            double[] ptMin = new double[] { minX, minY, 0 };
                            double[] ptMax = new double[] { maxX, maxY, 0 };
                            transform.TransformPoint(ptMin);
                            transform.TransformPoint(ptMax);
                            minLng = ptMin[0]; minLat = ptMin[1]; maxLng = ptMax[0]; maxLat = ptMax[1];
                        }
                    }
                }

                MapService.LimitesRasterGlobal = new SkiaSharp.SKRect((float)minLng, (float)-maxLat, (float)maxLng, (float)-minLat);
                MapService.NomeRasterAtivo = System.IO.Path.GetFileName(caminhoArquivoRaster);
                MapService.TemRaster = true;
            }

            MapService.CameraPanX = 0;
            MapService.CameraPanY = 0;
            MapService.CameraZoom = 1.0f;
            await JSRuntime.InvokeVoidAsync("mapEngine.resetarCamera");
            var camadaExistente = CamadasAtivas.FirstOrDefault(c => c.Nome == MapService.NomeRasterAtivo);
            if (camadaExistente == null)
            {
                CamadasAtivas.Add(new Camada { Nome = MapService.NomeRasterAtivo, Tipo = "Raster", Visivel = true, CaminhoArquivo = caminhoArquivoRaster });
            }

            SincronizarHierarquia();
            SolicitarNovoFrame();
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", "Erro crítico na importação raster: " + ex.Message);
        }
    }

    // =========================================================================
