    // 3. O botão "MOVER VÉRTICE" (Agora com conversor UTM ProjNet integrado)
    private async Task ForcarVerticeManual()
    {
        try
        {
            double valorY = double.Parse(verticeEditandoY.Trim(), System.Globalization.CultureInfo.InvariantCulture);
            double valorX = double.Parse(verticeEditandoX.Trim(), System.Globalization.CultureInfo.InvariantCulture);

            double latFinal, lngFinal;

            // MÁGICA: Se o engenheiro escolheu UTM, convertemos antes de mandar pro mapa!
            if (sistemaCoordenadasEdicao == "UTM")
            {
                int zona = int.Parse(new String(zonaUtmEdicao.Where(char.IsDigit).ToArray()));
                bool isNorte = zonaUtmEdicao.ToUpper().Contains("N");

                var sistemaUTM = ProjectedCoordinateSystem.WGS84_UTM(zona, isNorte);
                var sistemaGeografico = GeographicCoordinateSystem.WGS84;
                var conversor = new CoordinateTransformationFactory().CreateFromCoordinateSystems(sistemaUTM, sistemaGeografico);

                // O ProjNet recebe { Este(X), Norte(Y) }
                double[] coordenadasGeograficas = conversor.MathTransform.Transform(new double[] { valorX, valorY });

                lngFinal = coordenadasGeograficas[0];
                latFinal = coordenadasGeograficas[1];
            }
            else
            {
                // Se já for Decimal, vai direto
                latFinal = valorY;
                lngFinal = valorX;
            }

            // Grita com o JavaScript para mover a quilha da linha para a nova posição geográfica
            await JSRuntime.InvokeVoidAsync("forcarPosicaoVertice", verticeEditandoCamada, verticeEditandoIndice, latFinal, lngFinal);

            exibirModalTrocaVertice = false;
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", $"Erro fatal de matemática ou digitação.\n{ex.Message}");
        }
    }
