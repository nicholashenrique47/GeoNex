    /* =======================================================================
       ARQUITETURA VISUAL DOS MENUS SUSPENSOS E CASCATA (PADRÃO CORPORATIVO)
       ======================================================================= */

    /* 1. Reset e Estilização dos Botões Internos */
    .dropdown-content button,
    .submenu-content button,
    .dropdown-content .drop-item {
        display: block;
        width: 100%;
        text-align: left;
        background: transparent;
        border: none;
        padding: 10px 16px;
        color: #cbd5e1; /* Cinza claro profissional */
        font-size: 0.8rem;
        font-weight: 500;
        font-family: 'Open Sans', 'Segoe UI', sans-serif;
        cursor: pointer;
        transition: all 0.15s ease;
    }

    /* 2. O Painel de Vidro do Menu Principal */
    .dropdown-content {
        display: none;
        position: absolute;
        top: 100%; /* Cola exatamente abaixo da barra superior */
        left: 0;
        background: rgba(18, 22, 31, 0.95); /* Vidro escuro sólido */
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 4px;
        min-width: 240px;
        padding: 6px 0;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.7);
        z-index: 4000;
    }

    /* Revelar o menu ao passar o rato */
    .dropdown:hover .dropdown-content {
        display: block;
    }

    /* 3. Efeito de Seleção (Hover) */
    .dropdown-content button:hover,
    .submenu-content button:hover,
    .dropdown-submenu:hover > .submenu-btn {
        background: rgba(56, 189, 248, 0.15); /* Fundo ciano translúcido */
        color: #38bdf8; /* Texto em ciano brilhante */
    }

    /* 4. Linhas Divisórias */
    .drop-divider {
        height: 1px;
        background: rgba(255, 255, 255, 0.06);
        margin: 4px 0;
    }

    /* =======================================================================
       SUBMENUS EM CASCATA (Ex: "Importar Fontes Locais ▸")
       ======================================================================= */
    .dropdown-submenu {
        position: relative;
    }

    /* Garante que a seta '▸' fique encostada à direita */
    .submenu-btn {
        display: flex !important;
        justify-content: space-between !important;
        align-items: center;
    }

    /* O Painel de Vidro do Nível 2 */
    .submenu-content {
        display: none;
        position: absolute;
        top: -6px; /* Alinha o topo do submenu com o item pai */
        left: 100%; /* Nasce exatamente do lado direito */
        background: rgba(18, 22, 31, 0.98);
        backdrop-filter: blur(12px);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 4px;
        min-width: 220px;
        padding: 6px 0;
        box-shadow: 4px 4px 20px rgba(0, 0, 0, 0.8);
        z-index: 4001;
    }

    /* Escudo Magnético de Proteção do Rato (Ponte de 15px) */
    .dropdown-submenu::after {
        content: '';
        position: absolute;
        top: 0;
        right: -15px;
        width: 15px;
        height: 100%;
        background: transparent;
    }

    /* Revelar o submenu em cascata */
    .dropdown-submenu:hover .submenu-content {
        display: block;
