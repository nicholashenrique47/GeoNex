@page "/"
@inject IJSRuntime JSRuntime
@implements IDisposable
@inject GeoNex.Services.ProjetoService ProjetoService
@inject GeoNex.Services.RasterService RasterService
@inject GeoNex.Services.MapRenderingService MapService
@using SkiaSharp
@using SkiaSharp.Views.Blazor
@using ProjNet.CoordinateSystems
@using ProjNet.CoordinateSystems.Transformations
<PageTitle>GeoNex - Professional GIS</PageTitle>

<div id="map-container"
     tabindex="0"
     @onkeydown="ProcessarTeclado"
     @onpointerdown="ProcessarPressionarMouse"
     @onpointerup="ProcessarSoltarMouse"
     @onpointermove="ProcessarMovimentoMouse"
     style="width: 100vw; height: 100vh; background-color: #161921; position: absolute; left:0; top:0; z-index: 0; overflow: hidden;">

    <img src="@_mapaUrl" style="width: 100%; height: 100%; object-fit: fill; pointer-events: none; position: absolute; left: 0; top: 0;" />

    <canvas id="overlayCanvas"
            style="position: absolute; left: 0; top: 0; width: 100%; height: 100%; pointer-events: none; z-index: 1;">
    </canvas>
</div>
//começou aqui
<!-- A INTERFACE FLUTUANTE -->
<div class="geonex-ui">

    <!-- BARRA SUPERIOR (HEADER & RIBBON) -->
    <header class="glass-panel top-bar" style="display: flex; align-items: center; justify-content: flex-start; padding: 0 20px; gap: 15px;">

        <div class="brand-group" style="margin-right: 15px;">
            <h1>GEONEX</h1>
            <span class="sub-brand">PRO</span>
        </div>

        <nav class="main-menu" style="display: flex; height: 100%; align-items: stretch; margin-right: auto;">

            <div class="dropdown" style="display: flex; align-items: center; height: 100%;">
                <button class="menu-btn">Arquivo ▾</button>
                <div class="dropdown-content">
                    <button @onclick="CriarNovoProjeto">Novo Projeto</button>
                    <button>Abrir Projeto...</button>
                    <div class="drop-divider"></div>
                    <button>Salvar</button>
                    <button>Salvar Como...</button>
                    <div class="drop-divider"></div>
                    <button>Sincronizar Nuvem</button> <div class="drop-divider"></div>
                    <button>Configurações do Sistema</button>
                    <button>Sair</button>
                </div>
            </div>

            <div class="dropdown" style="display: flex; align-items: center; height: 100%;">
                <button class="menu-btn">Dados ▾</button>
                <div class="dropdown-content">

                    <div class="dropdown-submenu">
                        <button class="submenu-btn">
                            <span>Importar Fontes Locais</span>
                            <span style="font-size: 0.7rem; color: #64748b;">▸</span>
                        </button>

                        <div class="submenu-content">
                            <button class="drop-item" @onclick='() => { AbrirModalImportacao(); TrocarAbaModal("Raster"); }'>
                                Raster (ECW, TIF)
                            </button>

                            <button class="drop-item" @onclick='() => { AbrirModalImportacao(); TrocarAbaModal("Vetor"); }'>
                                Vetor (SHP, GeoJSON)
                            </button>

                            <button class="drop-item" @onclick='() => { AbrirModalImportacao(); TrocarAbaModal("Texto"); }'>
                                Pontos (CSV, TXT)
                            </button>
                        </div>
                    </div>
                    <div class="drop-divider"></div>
                    <button class="drop-item">Conectar Banco PostGIS</button>
                </div>
            </div>

            <div class="dropdown" style="display: flex; align-items: center; height: 100%;">
                <button class="menu-btn" style="@(_ferramentaAtiva == ModoFerramenta.Identificacao ? "color: #38bdf8;" : "")">Aquisição ▾</button>
                <div class="dropdown-content">
                    <button class="drop-item" style="@(_ferramentaAtiva == ModoFerramenta.Identificacao ? "background: #0284c7; color: white;" : "")" @onclick="() => TrocarFerramenta(ModoFerramenta.Identificacao)">
                        Identificar / Selecionar
                    </button>
                    <button class="drop-item" style="@(_ferramentaAtiva == ModoFerramenta.AquisicaoPoligono ? "background: #0284c7; color: white;" : "")" @onclick="() => TrocarFerramenta(ModoFerramenta.AquisicaoPoligono)">
                        Desenhar Polígono (Lote)
                    </button>
                    <button class="drop-item" style="@(_ferramentaAtiva == ModoFerramenta.Medicao ? "background: #0284c7; color: white;" : "")" @onclick="() => TrocarFerramenta(ModoFerramenta.Medicao)">
                        Régua Topográfica
                    </button>
                </div>
            </div>

            <div class="dropdown" style="display: flex; align-items: center; height: 100%;">
                <button class="menu-btn" style="@(modoEdicaoVerticeLigado ? "color: #38bdf8; font-weight: bold;" : "")">Edição ▾</button>
                <div class="dropdown-content">
                    <button style="@(modoEdicaoVerticeLigado ? "color: #38bdf8; font-weight: bold; background: rgba(56, 189, 248, 0.1);" : "")" @onclick="AlternarEdicaoVertices">
                        @(modoEdicaoVerticeLigado ? "Modo Vértices [ ATIVO ]" : "Ativar Edição de Vértices")
                    </button>
                    <button>Cortar Geometria</button>
                    <button>Mesclar Polígonos</button>
                </div>
            </div>

            <div class="dropdown" style="display: flex; align-items: center; height: 100%;">
                <button class="menu-btn">Exportar ▾</button>
                <div class="dropdown-content">
                    <button>Exportar Vetor (Shapefile)</button>
                    <button>Exportar Tabela (CSV)</button>
                </div>
            </div>

            <div class="dropdown" style="display: flex; align-items: center; height: 100%;">
                <button class="menu-btn">GNSS / RTK ▾</button>
                <div class="dropdown-content">
                    <button>Gerenciador de Conexão (COM/BT)</button>
                    <button>Monitor NMEA (Satélites)</button>
                </div>
            </div>
        </nav>

        <div style="display: flex; align-items: center; gap: 15px;">

            <button class="tool-btn"
                    style="@(temEdicoesPendentes ? "color: #facc15; border: 1px solid #facc15; font-weight: bold; background: rgba(250, 204, 21, 0.1);" : "opacity: 0.3; cursor: not-allowed; border: 1px solid rgba(255,255,255,0.1);")"
                    @onclick="ConfirmarTodasEdicoes"
                    disabled="@(!temEdicoesPendentes)">
                SALVAR EDIÇÕES
            </button>

            <div class="vertical-divider" style="height: 20px;"></div>

            <div class="status-group" style="padding: 0 5px;">
                <span class="status-indicator online"></span>
                <span class="status-text">API CONECTADA</span>
            </div>

            <button class="btn" style="background: transparent; border: 1px solid rgba(255,255,255,0.1); color: #94a3b8; font-size: 0.65rem; font-weight: bold; padding: 4px 8px; border-radius: 4px; cursor: pointer;" @onclick="TestarMotorCPlusPlus" title="Diagnóstico de Motor">
                CORE C++
            </button>
        </div>

    </header>

    <!-- PAINÉIS LATERAIS E ÁREA DE TRABALHO -->
    <main class="workspace-area">

        <!-- PAINEL ESQUERDO: CAMADAS -->
        <aside class="glass-panel side-panel left-panel">
            <div class="panel-header">
                <h2>CAMADAS</h2>
                <div class="header-actions">
                    <button class="icon-action-btn">+</button>
                </div>
            </div>

            <div class="layer-list custom-scrollbar">
                @foreach (var camada in CamadasAtivas)
                {
                    // Variável local de segurança para o Blazor
                    var camadaAtual = camada;

                    <div @key="camadaAtual.Nome"
                         class="layer-item @(camadaAtual.Tipo.ToLower())"
                         draggable="true"
                         @ondragstart="() => AoIniciarArrastar(camadaAtual)"
                         @ondrop="() => AoSoltarCamada(camadaAtual)"
                         @ondragover:preventDefault="true"
                         @oncontextmenu="(e) => MostrarMenuContexto(e, camadaAtual.Nome)"
                         @oncontextmenu:preventDefault="true">

                        <div class="drag-handle" title="Arrastar para reordenar">
                            <svg width="12" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <circle cx="9" cy="12" r="1"></circle>
                                <circle cx="9" cy="5" r="1"></circle>
                                <circle cx="9" cy="19" r="1"></circle>
                                <circle cx="15" cy="12" r="1"></circle>
                                <circle cx="15" cy="5" r="1"></circle>
                                <circle cx="15" cy="19" r="1"></circle>
                            </svg>
                        </div>

                        <input type="checkbox"
                               checked="@camadaAtual.Visivel"
                               @onchange="@(e => ToggleCamada(camadaAtual, (bool)(e.Value ?? false)))" />

                        <span class="type-tag" style="background: @(camadaAtual.Tipo == "Raster" ? "#5b21b6" : "#065f46"); color: @(camadaAtual.Tipo == "Raster" ? "#ddd6fe" : "#a7f3d0");">
                            @(camadaAtual.Tipo == "Raster" ? "R" : "V")
                        </span>

                        <span class="layer-title no-select" title="@camadaAtual.Nome">@camadaAtual.Nome</span>

                        @if (camadaAtual.Tipo == "Vetor")
                        {
                            <div class="layer-actions" style="display: flex; gap: 5px; margin-left: auto;">

                                <button type="button" class="layer-action-btn" title="Abrir Tabela de Atributos"
                                        @onclick="() => AbrirTabela(camadaAtual.Nome)"
                                        @onclick:stopPropagation="true">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                                        <line x1="3" y1="9" x2="21" y2="9"></line>
                                        <line x1="9" y1="21" x2="9" y2="9"></line>
                                    </svg>
                                </button>

                                <button type="button" class="layer-action-btn" title="Propriedades da Camada"
                                        @onclick="() => AbrirPropriedadesCamada(camadaAtual.Nome)"
                                        @onclick:stopPropagation="true">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <circle cx="12" cy="12" r="3"></circle>
                                        <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"></path>
                                    </svg>
                                </button>

                                <button type="button" class="layer-action-btn" title="Opções da Camada"
                                        @onclick="(e) => BotaoOpcoesClicado(e, camadaAtual.Nome)"
                                        @onclick:stopPropagation="true">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <circle cx="12" cy="12" r="1"></circle>
                                        <circle cx="12" cy="5" r="1"></circle>
                                        <circle cx="12" cy="19" r="1"></circle>
                                    </svg>
                                </button>

                            </div>
                        }
                    </div>
                }

                @if (CamadasAtivas.Count == 0)
                {
                    <div style="padding: 15px; color: #64748b; font-size: 0.75rem; text-align: center;">
                        Nenhuma camada adicionada ao projeto.
                    </div>
                }
            </div>
        </aside>

        <!-- O PAINEL SENSORIAL BLINDADO -->
       
        <!-- PAINEL DIREITO: ATRIBUTOS -->
        <aside class="glass-panel side-panel right-panel">
            <div class="panel-header">
                <h2>@(_ferramentaAtiva == ModoFerramenta.Medicao ? "FERRAMENTAS DE MEDIÇÃO" : "ATRIBUTOS DA FEIÇÃO")</h2>
            </div>

            <div class="properties-content custom-scrollbar" style="padding: 15px;">

                @if (_ferramentaAtiva == ModoFerramenta.Medicao)
                {
                    <div style="background: rgba(0,0,0,0.3); padding: 12px; border-radius: 6px; border: 1px solid rgba(255,255,255,0.05); margin-bottom: 20px;">
                        <span style="font-size: 0.65rem; color: #94a3b8; font-weight: bold; text-transform: uppercase; letter-spacing: 1px; display: block; margin-bottom: 10px;">Opções de Mensura</span>

                        <div style="display: flex; gap: 10px;">
                            <button class="tool-btn @(_snapMedicaoAtivo ? "active" : "")"
                                    @onclick="() => _snapMedicaoAtivo = !_snapMedicaoAtivo"
                                    title="Atrair para Vértices (Snap Magnético)"
                                    style="font-size: 1.2rem; padding: 6px 12px;">
                                🧲
                            </button>

                            <button class="tool-btn @(MapService.MostrarAreaMedicao ? "active" : "")"
                                    @onclick="@(() => { MapService.MostrarAreaMedicao = !MapService.MostrarAreaMedicao; SolicitarNovoFrame(); StateHasChanged(); })"
                                    title="Calcular e Desenhar Área Poligonal"
                                    style="font-size: 1.2rem; padding: 6px 12px;">
                                📐
                            </button>
                        </div>
                    </div>

                    <div style="display: flex; flex-direction: column; gap: 20px; padding: 10px 5px;">
                        <div class="form-group-vertical" style="background: rgba(0,0,0,0.2); padding: 15px; border-radius: 6px; border: 1px solid rgba(255,255,255,0.05);">
                            <label style="color: #64748b;">COMPRIMENTO LINEAR</label>
                            <span style="font-family: monospace; font-size: 1.6rem; font-weight: 500; color: #e2e8f0;">@_medicaoComprimentoMetros.ToString("N2") <span style="font-size: 1rem; color: #94a3b8;">m</span></span>
                        </div>

                        @if (MapService.MostrarAreaMedicao && MapService.PontosMedicao.Count >= 3)
                        {
                            <div class="form-group-vertical" style="background: rgba(0,0,0,0.2); padding: 15px; border-radius: 6px; border: 1px solid rgba(255,255,255,0.05);">
                                <label style="color: #64748b;">ÁREA PLANA FECHADA</label>
                                <span style="font-family: monospace; font-size: 1.6rem; font-weight: 500; color: #38bdf8;">@_medicaoAreaM2.ToString("N2") <span style="font-size: 1rem; color: #94a3b8;">m²</span></span>
                            </div>
                        }

                        <button class="btn-cancel" style="width: 100%; margin-top: 10px; border-color: rgba(239, 68, 68, 0.3); color: #f87171;" @onclick="LimparMedicao">
                            LIMPAR RASTRO
                        </button>
                    </div>
                }
                else
                {
                    @if (atributosFeicaoSelecionada != null && atributosFeicaoSelecionada.Count > 0)
                    {
                        <div class="attribute-form">
                            <div class="form-group mb-15" style="border-bottom: 1px solid rgba(255,255,255,0.1); padding-bottom: 10px;">
                                <label>Camada Origem</label>
                                <span style="font-size: 0.75rem; color: #38bdf8; font-weight: bold; word-break: break-all;">@camadaSelecionadaPainel</span>
                            </div>

                            @foreach (var atributo in atributosFeicaoSelecionada)
                            {
                                <div class="form-group">
                                    <label>@atributo.Key</label>
                                    @if (atributo.Key.ToUpper() == "FID" || atributo.Key.ToUpper() == "ID")
                                    {
                                        <input type="text" class="glass-input" value="@atributo.Value" readonly style="opacity: 0.6;" />
                                    }
                                    else
                                    {
                                        <input type="text" class="glass-input editable" value="@atributo.Value" @onchange="(e) => AtualizarAtributoPainel(atributo.Key, e.Value.ToString())" />
                                    }
                                </div>
                            }
                            <button class="btn-save add-layer-btn" style="width: 100%; margin-top: 20px;" @onclick="SalvarAtributosPainel">SALVAR ALTERAÇÕES</button>
                        </div>
                    }
                    else
                    {
                        <div style="display: flex; height: 100%; align-items: center; justify-content: center; color: #64748b; font-size: 0.85rem; text-align: center; padding: 20px; flex-direction: column; gap: 10px;">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
                            <span>Selecione um polígono no mapa para inspecionar seus atributos.</span>
                        </div>
                    }
                }
            </div>
        </aside>

    </main>
    <main class="workspace-area">
    </main>

    @if (exibirTabelaAtributos)
    {
        <div class="glass-panel attribute-table-container">
            <div class="table-header">
                <span>TABELA DE ATRIBUTOS: @nomeCamadaAtiva</span>
                <button class="close-btn" @onclick="() => exibirTabelaAtributos = false">✕</button>
            </div>
            <div class="table-wrapper custom-scrollbar">
                <table>
                    <thead>
                        <tr>
                            @foreach (var col in colunasTabela)
                            {
                                <th>@col</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var linha in dadosTabela)
                        {
                            <tr @onclick="() => SelecionarNoMapa(linha)">
                                @foreach (var col in colunasTabela)
                                {
                                    <td>
                                        <input class="cell-input"
                                               value="@(linha.ContainsKey(col) ? linha[col] : "")"
                                               @onchange="(e) => AtualizarAtributo(linha, col, e.Value)" />
                                    </td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

    <footer class="bottom-status-bar">
    </footer>
    <!-- RODAPÉ DE TELEMETRIA -->
    <footer class="bottom-status-bar">
        <div class="status-left">
            <span><strong>PROJETO:</strong> Guaratuba_ZonaSul.gnx</span>
        </div>
        <div class="status-right">
            <span><strong>X:</strong> <span class="mono">@longitude</span></span>
            <span><strong>Y:</strong> <span class="mono">@latitude</span></span>
            <span class="scale-box">1:1.000</span>
        </div>
    </footer>

    <!-- ========================================== -->
    <!-- JANELA MODAL DE IMPORTAÇÃO (DATA MANAGER)  -->
    <!-- ========================================== -->
    @if (exibirModalImportacao)
    {
        <div class="modal-overlay">
            <div class="glass-panel import-modal">
                <div class="modal-header">
                    <h2>GERENCIADOR DE FONTES DE DADOS</h2>
                    <button class="close-modal-btn" @onclick="FecharModalImportacao">✕</button>
                </div>
                <div class="modal-body">
                    <div class="modal-tabs">
                        <button class="tab-btn @(AbaModalAtiva == "Raster" ? "active" : "")" @onclick="@(() => TrocarAbaModal("Raster"))">Raster (ECW, TIF)</button>
                        <button class="tab-btn @(AbaModalAtiva == "Vetor" ? "active" : "")" @onclick="@(() => TrocarAbaModal("Vetor"))">Vetor (SHP, GeoJSON)</button>
                        <button class="tab-btn @(AbaModalAtiva == "Texto" ? "active" : "")" @onclick="@(() => TrocarAbaModal("Texto"))">Texto Delimitado</button>
                        <button class="tab-btn @(AbaModalAtiva == "Nuvem" ? "active" : "")" @onclick="@(() => TrocarAbaModal("Nuvem"))">Nuvem (PostGIS)</button>
                    </div>

                    <div class="modal-content">

                        @if (AbaModalAtiva == "Raster")
                        {
                            <div class="form-group mb-15">
                                <label>Arquivo Fonte / Dataset (Raster)</label>
                                <div class="file-input-group">
                                    <input type="text" class="glass-input file-path" value="@caminhoArquivoRaster" placeholder="C:\Caminho\para\arquivo.tif" readonly />
                                    <button class="btn-browse" @onclick="SelecionarArquivoRaster">PROCURAR...</button>
                                </div>
                                <div style="margin-top: 10px; font-size: 0.7rem; color: #34d399; background: rgba(0,0,0,0.2); padding: 10px; border-radius: 4px; border: 1px solid rgba(52,211,153,0.2);">
                                    <pre style="margin:0; white-space: pre-wrap;">@statusGdal</pre>
                                </div>
                            </div>

                            <div class="import-actions">
                                <button class="btn-save add-layer-btn" @onclick="AdicionarCamadaAoMapa">ADICIONAR RASTER AO MAPA</button>
                                <button class="btn-cancel" @onclick="FecharModalImportacao">CANCELAR</button>
                            </div>
                        }
                        else if (AbaModalAtiva == "Vetor")
                        {
                            <div class="form-group mb-15">
                                <label>Arquivo Fonte Vetorial (Shapefile, KML, GeoJSON)</label>
                                <div class="file-input-group">
                                    <input type="text" class="glass-input file-path" value="@caminhoArquivoVetor" placeholder="C:\Caminho\para\lotes.shp" readonly />
                                    <button class="btn-browse" @onclick="SelecionarArquivoVetor">PROCURAR...</button>
                                </div>
                            </div>

                            <div class="form-group mb-15">
                                <label>Sistema de Referência de Coordenadas (CRS/EPSG)</label>
                                <select class="glass-input editable">
                                    <option>Automático (Lido do arquivo .prj)</option>
                                    <option>EPSG:31982 - SIRGAS 2000 / UTM zone 22S</option>
                                    <option>EPSG:4326 - WGS 84</option>
                                </select>
                            </div>

                            <div class="import-actions">
                                <button class="btn-save add-layer-btn" @onclick="AdicionarVetorAoMapa">ADICIONAR VETOR AO MAPA</button>
                                <button class="btn-cancel" @onclick="FecharModalImportacao">CANCELAR</button>
                            </div>
                        }
                        else
                        {
                            <div style="display: flex; height: 100%; align-items: center; justify-content: center; color: #64748b; font-size: 0.85rem;">
                                Módulo em desenvolvimento.
                            </div>
                        }

                    </div>
                </div>
            </div>
        </div>
    }
    @if (exibirModalPropriedades)
    {
        <div class="modal-overlay">
            <div class="glass-panel modal-container" style="width: 550px; min-height: 400px;">
                <div class="modal-header">
                    <h2>PROPRIEDADES: @camadaEmEdicao</h2>
                    <button class="close-btn" @onclick="() => exibirModalPropriedades = false">✕</button>
                </div>

                <div class="modal-body properties-layout">

                    <nav class="properties-sidebar">
                        <button class="tab-btn @(abaAtivaPropriedades == "Simbologia" ? "active" : "")" @onclick='() => abaAtivaPropriedades = "Simbologia"'>Simbologia</button>
                        <button class="tab-btn @(abaAtivaPropriedades == "Rotulos" ? "active" : "")" @onclick='() => abaAtivaPropriedades = "Rotulos"'>Rótulos</button>
                        <button class="tab-btn @(abaAtivaPropriedades == "Informacao" ? "active" : "")" @onclick='() => abaAtivaPropriedades = "Informacao"'>Informação</button>
                    </nav>

                    <div class="properties-content custom-scrollbar">

                        @if (abaAtivaPropriedades == "Simbologia")
                        {
                            <div class="form-group-vertical">
                                <label>TIPO DE SIMBOLOGIA</label>
                                <select class="glass-input" @bind="tipoSimbologia">
                                    <option value="UNICA">Símbolo Único (Cor Sólida)</option>
                                    <option value="CATEGORIZADA">Categorizado (Por Atributo)</option>
                                </select>
                            </div>

                            <hr style="border: none; border-top: 1px solid rgba(255,255,255,0.05); margin: 5px 0;" />

                            @if (tipoSimbologia == "UNICA")
                            {
                                <div class="form-group-vertical">
                                    <label>Cor de Preenchimento</label>
                                    <div class="color-picker-row">
                                        <input type="color" @bind="corPreenchimento" class="color-box" />
                                        <input type="text" class="glass-input" @bind="corPreenchimento" />
                                    </div>
                                </div>
                                <div class="form-group-vertical">
                                    <label>Cor da Borda</label>
                                    <div class="color-picker-row">
                                        <input type="color" @bind="corBorda" class="color-box" />
                                        <input type="text" class="glass-input" @bind="corBorda" />
                                    </div>
                                </div>
                            }
                            else
                            {
                                <div class="form-group-vertical">
                                    <label>Separar Cores Usando a Coluna:</label>
                                    <select class="glass-input" @bind="colunaSimbologiaCategorizada">
                                        <option value="">[ Selecione a Coluna ]</option>
                                        @foreach (var col in colunasDisponiveisRotulo)
                                        {
                                            <option value="@col">@col</option>
                                        }
                                    </select>
                                </div>
                            }

                            <div class="form-group-vertical" style="margin-top: 10px;">
                                <label>Opacidade (@opacidadePreenchimento%)</label>
                                <input type="range" min="0" max="100" step="1" @bind="opacidadePreenchimento" @bind:event="oninput" class="slider" />
                            </div>

                            <div class="form-group-vertical" style="margin-top: 10px;">
                                <label>Espessura da Linha (@espessuraLinha px)</label>
                                <input type="range" min="0" max="5" step="0.5" @bind="espessuraLinha" class="slider" />
                            </div>
                        }
                        else if (abaAtivaPropriedades == "Rotulos")
                        {
                            <div class="form-group-vertical">
                                <label>Rotular com (Coluna)</label>
                                <select class="glass-input" @bind="colunaRotuloSelecionada" style="width: 100%; padding: 8px; border: 1px solid rgba(255,255,255,0.2); background: rgba(0,0,0,0.4); color: #fff; border-radius: 4px;">
                                    <option value="">[ Nenhum Rótulo ]</option>
                                    @foreach (var col in colunasDisponiveisRotulo)
                                    {
                                        <option value="@col">@col</option>
                                    }
                                </select>
                            </div>

                            <div class="form-group-vertical" style="margin-top: 15px;">
                                <label>Tamanho da Fonte (@tamanhoFonteRotulo px)</label>
                                <input type="range" min="8" max="32" step="1" @bind="tamanhoFonteRotulo" class="slider" />
                            </div>

                            <div class="form-group-vertical" style="margin-top: 15px;">
                                <label>Cor do Texto</label>
                                <div class="color-picker-row">
                                    <input type="color" @bind="corFonteRotulo" class="color-box" />
                                    <input type="text" class="glass-input" @bind="corFonteRotulo" />
                                </div>
                            </div>
                        }
                        else if (abaAtivaPropriedades == "Informacao")
                        {
                            <div style="color: #94a3b8; font-size: 0.85rem; padding: 10px;">
                                <p style="margin-bottom: 10px;"><strong>Sistema de Coordenadas:</strong> EPSG:4326</p>
                                <p style="margin-bottom: 10px;"><strong>Formato:</strong> Vetor OGR</p>
                            </div>
                        }

                    </div>
                </div>

                <div class="modal-footer">
                    <button class="btn-cancel" @onclick="() => exibirModalPropriedades = false">CANCELAR</button>
                    <button class="btn-save add-layer-btn" @onclick="AplicarPropriedadesUnificadas">APLICAR ESTILO</button>
                </div>
            </div>
        </div>
    }
    <!-- A CHAVE DO MODAL DE PROPRIEDADES FECHA AQUI PRIMEIRO -->
    <!-- AGORA SIM, O MENU DE CONTEXTO É TOTALMENTE INDEPENDENTE -->
    @if (mostrarMenuContexto)
    {
        <div class="context-menu-overlay" @onclick="FecharMenuContexto" @oncontextmenu="FecharMenuContexto" @oncontextmenu:preventDefault="true"></div>
        <div class="context-menu glass-panel" style="left: @(menuContextoX)px; top: @(menuContextoY)px;">
            <button @onclick="AproximarCamada">Aproximar à Camada</button>

            @if (CamadasAtivas.FirstOrDefault(c => c.Nome == camadaSelecionadaMenu)?.Tipo == "Vetor")
            {
                <button @onclick="() => { FecharMenuContexto(); AbrirTabela(camadaSelecionadaMenu); }">Tabela de Atributos</button>
                <button @onclick="() => { FecharMenuContexto(); AbrirPropriedadesCamada(camadaSelecionadaMenu); }">Propriedades e Estilos</button>
            }

            <button @onclick="FecharMenuContexto">Renomear</button>

            <hr class="menu-divider" />

            <!-- NOVOS CONTROLES DE HIERARQUIA -->
            <button @onclick="() => MoverCamada(camadaSelecionadaMenu, -1)">Mover para Cima</button>
            <button @onclick="() => MoverCamada(camadaSelecionadaMenu, 1)">Mover para Baixo</button>

            <hr class="menu-divider" />

            <button @onclick="PrepararRemocaoCamada" class="btn-danger">Remover Camada</button>
        </div>
    }
    <!-- MODAL DE INJEÇÃO DE COORDENADAS TOPOGRÁFICAS -->
    <!-- MODAL DE INJEÇÃO DE COORDENADAS (CADERNETA DE CAMPO) -->
    <!-- MODAL DE INJEÇÃO DE COORDENADAS (CADERNETA DE CAMPO) -->
    <!-- MODAL DE INJEÇÃO DE COORDENADAS (CADERNETA DE CAMPO) -->
    @if (exibirModalCoordenadas)
    {
        <div class="modal-overlay">
            <div class="glass-panel" style="width: 550px; display: flex; flex-direction: column;">
                <div class="modal-header">
                    <h2>CADERNETA DE CAMPO DIGITAL</h2>
                    <button class="close-btn" @onclick="() => exibirModalCoordenadas = false">✕</button>
                </div>

                <!-- CORREÇÃO 1: height: auto e max-height para evitar que o conteúdo vaze -->
                <div class="modal-body custom-scrollbar" style="height: auto; max-height: 65vh; padding: 20px; display: flex; flex-direction: column; gap: 15px; overflow-y: auto;">

                    <!-- CONFIGURAÇÕES DE SISTEMA -->
                    <div class="form-row">
                        <div class="form-group-vertical">
                            <label>SISTEMA (CRS)</label>
                            <select class="glass-input" @bind="sistemaCoordenadas">
                                <option value="DECIMAL">Geográfica Decimal (WGS 84)</option>
                                <option value="UTM">UTM (SIRGAS 2000)</option>
                            </select>
                        </div>
                        <div class="form-group-vertical">
                            <label>GEOMETRIA ALVO</label>
                            <select class="glass-input" @bind="tipoGeometriaAlvo">
                                <option value="POLIGONO">Polígono (Área)</option>
                                <option value="LINHA">Linha / Eixo</option>
                                <option value="PONTOS">Pontos Individuais</option>
                            </select>
                        </div>
                    </div>

                    <!-- CONFIGURAÇÕES ESPECÍFICAS E MÉTODO DE ENTRADA -->
                    <div class="form-row" style="margin-top: 10px;">
                        @if (sistemaCoordenadas == "UTM")
                        {
                            <div class="form-group-vertical">
                                <label>FUSO / ZONA UTM (Ex: 22S)</label>
                                <input type="text" class="glass-input" @bind="zonaUtm" placeholder="Ex: 22S" />
                            </div>
                        }

                        <!-- Se não for UTM, este select ocupa a largura toda da grelha -->
                        <div class="form-group-vertical" style="@(sistemaCoordenadas != "UTM" ? "grid-column: span 2;" : "")">
                            <label>MÉTODO DE ENTRADA</label>
                            <select class="glass-input" @bind="metodoEntrada">
                                <option value="COORDENADA">Coordenadas Absolutas (X, Y)</option>
                                @if (sistemaCoordenadas == "UTM")
                                {
                                    <option value="AZIMUTE">Azimute e Distância (A partir do anterior)</option>
                                }
                            </select>
                        </div>
                    </div>

                    @if (sistemaCoordenadas == "UTM")
                    {
                        <div class="form-group-vertical">
                            <label>FUSO / ZONA UTM (Ex: 22S)</label>
                            <input type="text" class="glass-input" @bind="zonaUtm" placeholder="Ex: 22S" />
                        </div>
                    }

                    <hr style="border: none; border-top: 1px solid rgba(255,255,255,0.1); margin: 5px 0;" />

                    <!-- ENTRADA DOS DADOS -->
                    <div class="form-row" style="align-items: flex-end;">
                        <div class="form-group-vertical" style="flex: 0.3;">
                            <label>NOME</label>
                            <input type="text" class="glass-input" @bind="novoNomePonto" placeholder="Ex: P1" />
                        </div>
                        <div class="form-group-vertical" style="flex: 0.7;">
                            <label>COORDENADA (X, Y) ou (Lat, Lng)</label>
                            <div style="display: flex; gap: 10px;">
                                <input type="text" class="glass-input" @bind="novaCoordenadaPonto" placeholder="@(sistemaCoordenadas == "UTM" ? "743210.50, 7134560.80" : "-25.8828, -48.5747")" style="flex: 1;" />
                                <button class="btn-save" @onclick="AdicionarPontoCaderneta" style="margin: 0; padding: 8px 15px; width: auto;">+</button>
                            </div>
                        </div>
                    </div>

                    <!-- LISTA DE PONTOS (A Caderneta) -->
                    <div class="form-group-vertical">
                        <label>LISTA DE PONTOS ADICIONADOS (@listaPontosCaderneta.Count)</label>
                        <div class="layer-list custom-scrollbar" style="height: 140px; background: rgba(0,0,0,0.3); border-radius: 4px; padding: 5px; border: 1px solid rgba(255,255,255,0.05);">

                            @if (listaPontosCaderneta.Count == 0)
                            {
                                <div style="text-align: center; color: #64748b; font-size: 0.75rem; margin-top: 40px;">
                                    Nenhum ponto adicionado à caderneta.
                                </div>
                            }

                            @foreach (var pt in listaPontosCaderneta)
                            {
                                <div style="display: flex; justify-content: space-between; align-items: center; font-size: 0.8rem; padding: 8px; border-bottom: 1px solid rgba(255,255,255,0.05); background: rgba(255,255,255,0.02); margin-bottom: 2px; border-radius: 4px;">
                                    <span><strong style="color:#38bdf8; width: 40px; display: inline-block;">@pt["Nome"]</strong> | <span style="font-family: monospace;">@pt["Coord1"], @pt["Coord2"]</span></span>
                                    <button style="background:none; border:none; color:#ef4444; cursor:pointer; font-size: 1.1rem; font-weight: bold;" @onclick="() => RemoverPontoCaderneta(pt)" title="Remover Ponto">✕</button>
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <!-- CORREÇÃO 2: Botões isolados no rodapé -->
                <div class="modal-footer" style="padding: 15px 20px; border-top: 1px solid rgba(255,255,255,0.05); display: flex; justify-content: flex-end; gap: 10px; background: rgba(0,0,0,0.2);">
                    <button class="btn-cancel" @onclick="() => exibirModalCoordenadas = false">CANCELAR</button>
                    <button class="btn-save" style="margin: 0; width: auto;" @onclick="ProcessarCadernetaDeCampo">PROCESSAR LEVANTAMENTO</button>
                </div>

            </div>
        </div>
    }
    
    @if (exibirModalTrocaVertice)
    {
        <div class="modal-overlay">
            <div class="glass-panel" style="width: 400px;">
                <div class="modal-header">
                    <h2>AJUSTE DE VÉRTICE: V@(verticeEditandoIndice + 1)</h2>
                    <button class="close-btn" @onclick="() => exibirModalTrocaVertice = false">✕</button>
                </div>
                <div class="modal-body" style="padding: 15px; display: flex; flex-direction: column; gap: 10px;">

                    <div class="form-row">
                        <div class="form-group-vertical">
                            <label>SISTEMA (CRS)</label>
                            <select class="glass-input" @bind="sistemaCoordenadasEdicao">
                                <option value="DECIMAL">Decimal (WGS 84)</option>
                                <option value="UTM">UTM (SIRGAS 2000)</option>
                            </select>
                        </div>
                        @if (sistemaCoordenadasEdicao == "UTM")
                        {
                            <div class="form-group-vertical">
                                <label>FUSO / ZONA UTM</label>
                                <input type="text" class="glass-input" @bind="zonaUtmEdicao" placeholder="Ex: 22S" />
                            </div>
                        }
                    </div>

                    <div class="form-group-vertical">
                        <label>@(sistemaCoordenadasEdicao == "UTM" ? "COORDENADA NORTE (Y)" : "LATITUDE (Y)")</label>
                        <input type="text" class="glass-input" @bind="verticeEditandoY" />
                    </div>
                    <div class="form-group-vertical">
                        <label>@(sistemaCoordenadasEdicao == "UTM" ? "COORDENADA ESTE (X)" : "LONGITUDE (X)")</label>
                        <input type="text" class="glass-input" @bind="verticeEditandoX" />
                    </div>

                </div>
                <div class="modal-footer" style="padding: 15px; display: flex; justify-content: flex-end; gap: 10px; background: rgba(0,0,0,0.2);">
                    <button class="btn-cancel" @onclick="() => exibirModalTrocaVertice = false">CANCELAR</button>
                    <button class="btn-save" @onclick="ForcarVerticeManual">MOVER VÉRTICE</button>
                </div>
            </div>
        </div>
    }

</div>} <!-- Fim da div geonex-ui -->
}
<style>
