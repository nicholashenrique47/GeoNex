    // Método para ser chamado pelos botões/inputs do painel de Propriedades da Camada
    // =========================================================================
    // APLICAÇÃO DE SIMBOLOGIA (MODAL DE PROPRIEDADES)
    // =========================================================================
    private void AplicarPropriedadesUnificadas()
    {
        if (string.IsNullOrEmpty(camadaEmEdicao)) return;
        var estilo = MapService.EstilosPorCamada.GetOrAdd(camadaEmEdicao, new GeoNex.Services.EstiloCamada());

        // =========================================================
        // LIMPEZA DE CACHE: Força o motor a recalcular os centros
        // geométricos (Resolve o problema do Mirim)
        // =========================================================
        MapService.PontosAncoragemRotulo.Remove(camadaEmEdicao);

        // 1. PROPRIEDADES GERAIS
        estilo.TipoSimbologia = tipoSimbologia;

        // 1. PROPRIEDADES GERAIS
        estilo.TipoSimbologia = tipoSimbologia;
        estilo.EspessuraBorda = Convert.ToSingle(espessuraLinha);
        estilo.Opacidade = Convert.ToSingle(opacidadePreenchimento) / 100f;
        // 2. A PONTE DOS RÓTULOS
        // 2. A PONTE DOS RÓTULOS
        // O motor só liga se o botão estiver ativado E uma coluna válida estiver selecionada!
        estilo.ExibirRotulos = !string.IsNullOrEmpty(colunaRotuloSelecionada);
        estilo.ColunaRotulo = colunaRotuloSelecionada; // <-- A LINHA QUE FALTAVA E QUEBROU TUDO!
        estilo.CorHaloRotulo = corHaloRotulo;
        estilo.TamanhoTextoRotulo = (float)tamanhoFonteRotulo;
        estilo.TamanhoHaloRotulo = (float)tamanhoHaloRotulo;
        estilo.RotuloNegrito = rotuloNegrito;
        estilo.AntiColisaoRotulos = antiColisaoRotulos; // Adicione esta linha aqui!
        estilo.TamanhoHaloRotulo = (float)tamanhoHaloRotulo;
        estilo.RotuloNegrito = rotuloNegrito;
        estilo.EscalaMinimaRotulo = escalaMinimaRotulo; // <-- Adicione esta linha
        estilo.ExibirRotulos = exibirRotulos && !string.IsNullOrEmpty(colunaRotuloSelecionada);
        // 3. MOTOR DE SIMBOLOGIA (ÚNICA OU CATEGORIZADA)
        if (tipoSimbologia == "UNICA")
        {
            estilo.PreenchimentoTransparente = semCorPreenchimento;
            estilo.BordaTransparente = semCorBorda;
            estilo.CorPreenchimento = corPreenchimento;
            estilo.CorBorda = corBorda;
        }
        else if (tipoSimbologia == "CATEGORIZADA")
        {
            estilo.ColunaSimbologia = colunaSimbologiaCategorizada;
            estilo.CoresCategorizadas.Clear();

            MapService.CompilarCategorias(camadaEmEdicao, colunaSimbologiaCategorizada);

            if (MapService.VetoresCategorizados.TryGetValue(camadaEmEdicao, out var dicionarioCategorias))
            {
                int corIndex = 0;
                foreach (string nomeCategoria in dicionarioCategorias.Keys)
                {
                    // Motor de Harmonia Cartográfica ArcMap
                    float hue = (corIndex * 137.508f) % 360f;
                    int perfil = corIndex % 4;

                    float sat = perfil switch { 0 => 80f, 1 => 45f, 2 => 65f, _ => 55f };
                    float val = perfil switch { 0 => 95f, 1 => 100f, 2 => 80f, _ => 90f };

                    var corHsv = SkiaSharp.SKColor.FromHsv(hue, sat, val);
                    estilo.CoresCategorizadas[nomeCategoria] = $"#{corHsv.Red:X2}{corHsv.Green:X2}{corHsv.Blue:X2}";

                    corIndex++;
                }
            }
        }

        SolicitarNovoFrame();
        exibirModalPropriedades = false;
    }

