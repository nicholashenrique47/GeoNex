                            <input type="text" class="glass-input" @bind="novoNomePonto" placeholder="Ex: P1" />
                        </div>
                        <div class="form-group-vertical" style="flex: 0.7;">
                            <label>COORDENADA (X, Y) ou (Lat, Lng)</label>
                            <div style="display: flex; gap: 10px;">
                                <input type="text" class="glass-input" @bind="novaCoordenadaPonto" placeholder="@(sistemaCoordenadas == "UTM" ? "743210.50, 7134560.80" : "-25.8828, -48.5747")" style="flex: 1;" />
                                <button class="btn-save" @onclick="AdicionarPontoCaderneta" style="margin: 0; padding: 8px 15px; width: auto;">+</button>
                            </div>
                        </div>
                    </div>

                    <!-- LISTA DE PONTOS (A Caderneta) -->
                    <div class="form-group-vertical">
                        <label>LISTA DE PONTOS ADICIONADOS (@listaPontosCaderneta.Count)</label>
                        <div class="layer-list custom-scrollbar" style="height: 140px; background: rgba(0,0,0,0.3); border-radius: 4px; padding: 5px; border: 1px solid rgba(255,255,255,0.05);">

                            @if (listaPontosCaderneta.Count == 0)
                            {
                                <div style="text-align: center; color: #64748b; font-size: 0.75rem; margin-top: 40px;">
                                    Nenhum ponto adicionado à caderneta.
                                </div>
                            }

                            @foreach (var pt in listaPontosCaderneta)
                            {
                                <div style="display: flex; justify-content: space-between; align-items: center; font-size: 0.8rem; padding: 8px; border-bottom: 1px solid rgba(255,255,255,0.05); background: rgba(255,255,255,0.02); margin-bottom: 2px; border-radius: 4px;">
                                    <span><strong style="color:#38bdf8; width: 40px; display: inline-block;">@pt["Nome"]</strong> | <span style="font-family: monospace;">@pt["Coord1"], @pt["Coord2"]</span></span>
                                    <button style="background:none; border:none; color:#ef4444; cursor:pointer; font-size: 1.1rem; font-weight: bold;" @onclick="() => RemoverPontoCaderneta(pt)" title="Remover Ponto">✕</button>
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <!-- CORREÇÃO 2: Botões isolados no rodapé -->
                <div class="modal-footer" style="padding: 15px 20px; border-top: 1px solid rgba(255,255,255,0.05); display: flex; justify-content: flex-end; gap: 10px; background: rgba(0,0,0,0.2);">
                    <button class="btn-cancel" @onclick="() => exibirModalCoordenadas = false">CANCELAR</button>
                    <button class="btn-save" style="margin: 0; width: auto;" @onclick="ProcessarCadernetaDeCampo">PROCESSAR LEVANTAMENTO</button>
                </div>

            </div>
        </div>
    }
    
        @if (exibirModalTrocaVertice)
        {
            <div class="modal-overlay">
                <div class="glass-panel" style="width: 400px;">
                    <div class="modal-header">
                        <h2>AJUSTE DE VÉRTICE: V@(verticeEditandoIndice + 1)</h2>
