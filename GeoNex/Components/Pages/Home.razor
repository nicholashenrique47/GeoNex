    // NOVO MÉTODO: Carrega o estado real da camada para a interface não sobrescrever dados
    private void AbrirPropriedadesSincronizadas(string nomeCamada)
    {
        camadaEmEdicao = nomeCamada;
        abaAtivaPropriedades = "Simbologia";

        // Tenta ir buscar o estilo à Placa Gráfica, ou cria um novo se a camada for virgem
        var estilo = MapService.EstilosPorCamada.TryGetValue(nomeCamada, out var est)
                     ? est : new GeoNex.Services.EstiloCamada();

        // 1. SINCRONIZA A MEMÓRIA DA SIMBOLOGIA E CORES
        tipoSimbologia = string.IsNullOrEmpty(estilo.TipoSimbologia) ? "UNICA" : estilo.TipoSimbologia;
        colunaSimbologiaCategorizada = estilo.ColunaSimbologia ?? "";
        opacidadePreenchimento = (int)(estilo.Opacidade * 100f);
        espessuraLinha = estilo.EspessuraBorda;

        // O SEGREDO: Força a interface a ler as cores exatas da camada que acabou de clicar!
        // Se a cor for vazia (camada nova), assume o Ciano Padrão do GeoNex
        semCorPreenchimento = (estilo.CorPreenchimento == "transparent");
        corPreenchimento = string.IsNullOrEmpty(estilo.CorPreenchimento) ? "#38bdf8" : (semCorPreenchimento ? "#38bdf8" : estilo.CorPreenchimento);

        semCorBorda = (estilo.CorBorda == "transparent");
        corBorda = string.IsNullOrEmpty(estilo.CorBorda) ? "#0ea5e9" : (semCorBorda ? "#0ea5e9" : estilo.CorBorda);

        // 2. SINCRONIZA A MEMÓRIA DOS RÓTULOS
        exibirRotulos = estilo.ExibirRotulos;
        colunaRotuloSelecionada = estilo.ColunaRotulo ?? "";
        tamanhoFonteRotulo = (int)(estilo.TamanhoTextoRotulo > 0 ? estilo.TamanhoTextoRotulo : 12f);
        tamanhoHaloRotulo = estilo.TamanhoHaloRotulo;
        corFonteRotulo = string.IsNullOrEmpty(estilo.CorTextoRotulo) ? "#FFFFFF" : estilo.CorTextoRotulo;
        corHaloRotulo = string.IsNullOrEmpty(estilo.CorHaloRotulo) ? "#000000" : estilo.CorHaloRotulo;
        rotuloNegrito = estilo.RotuloNegrito;

        exibirModalPropriedades = true;
    }
    private float _ultimoMidXUI = 0f;
    private float _ultimoMidYUI = 0f;
    private float _ultimaEscalaUI = 1f;

    private SkiaSharp.SKMatrix ObterMatrizMatematica()
{
    SkiaSharp.SKRect limitesTotais = new SkiaSharp.SKRect();
    bool primeiro = true;

    if (MapService.TemRaster) { limitesTotais = MapService.LimitesRasterGlobal; primeiro = false; }
    foreach (var path in MapService.VetoresPorCamada.Values) { if (primeiro) { limitesTotais = path.Bounds; primeiro = false; } else { limitesTotais.Union(path.Bounds); } }
    foreach (var path in MapService.LinhasPorCamada.Values) { if (primeiro) { limitesTotais = path.Bounds; primeiro = false; } else { limitesTotais.Union(path.Bounds); } }
    foreach (var path in MapService.PontosPorCamada.Values) { if (primeiro) { limitesTotais = path.Bounds; primeiro = false; } else { limitesTotais.Union(path.Bounds); } }

    float escalaAutoFit; float midX, midY;

    if (limitesTotais.IsEmpty || limitesTotais.Width < 0.001f || limitesTotais.Height < 0.001f)
    {
        escalaAutoFit = _ultimaEscalaUI > 0 ? _ultimaEscalaUI : 1f;
        midX = _ultimoMidXUI; midY = _ultimoMidYUI;
    }
    else
    {
        float escalaX = _larguraTela / limitesTotais.Width;
        float escalaY = _alturaTela / limitesTotais.Height;
        escalaAutoFit = Math.Min(escalaX, escalaY) * 0.8f;
        midX = limitesTotais.MidX; midY = limitesTotais.MidY;

        _ultimaEscalaUI = escalaAutoFit; _ultimoMidXUI = midX; _ultimoMidYUI = midY;
    }

    var matriz = SkiaSharp.SKMatrix.CreateTranslation(-midX, -midY);
    matriz = matriz.PostConcat(SkiaSharp.SKMatrix.CreateScale(escalaAutoFit * MapService.CameraZoom, escalaAutoFit * MapService.CameraZoom));
    
    // A MÁGICA DE ALINHAMENTO: Arredondamento para o pixel físico mais próximo
    float panXFinal = (float)Math.Round(_larguraTela / 2f + MapService.CameraPanX);
    float panYFinal = (float)Math.Round(_alturaTela / 2f + MapService.CameraPanY);

    matriz = matriz.PostConcat(SkiaSharp.SKMatrix.CreateTranslation(panXFinal, panYFinal));

    return matriz;
}
    

    private void ExtrairAneisMultiplos(NetTopologySuite.Geometries.Geometry geom, List<List<object>> listaSaida)
    {
        if (geom is NetTopologySuite.Geometries.Polygon poly)
        {
            listaSaida.Add(ConverterCoordenadas(poly.ExteriorRing.Coordinates));
            foreach (var furo in poly.InteriorRings) listaSaida.Add(ConverterCoordenadas(furo.Coordinates));
        }
        else if (geom is NetTopologySuite.Geometries.MultiPolygon multi)
        {
            foreach (NetTopologySuite.Geometries.Polygon p in multi.Geometries) ExtrairAneisMultiplos(p, listaSaida);
        }
        else if (geom is NetTopologySuite.Geometries.LineString linha)
        {
            listaSaida.Add(ConverterCoordenadas(linha.Coordinates));
        }
        else if (geom is NetTopologySuite.Geometries.MultiLineString multiLinha)
        {
            foreach (NetTopologySuite.Geometries.LineString l in multiLinha.Geometries) ExtrairAneisMultiplos(l, listaSaida);
        }
        else
        {
            listaSaida.Add(ConverterCoordenadas(geom.Coordinates));
        }
    }
    private SkiaSharp.SKMatrix ObterMatrizBaseSemMover()
    {
        // Esta matriz ignora o CameraPan e Zoom. Representa a "folha de papel" no estado zero.
        SkiaSharp.SKRect limitesTotais = new SkiaSharp.SKRect();
        bool primeiro = true;
        if (MapService.TemRaster) { limitesTotais = MapService.LimitesRasterGlobal; primeiro = false; }
        foreach (var path in MapService.VetoresPorCamada.Values) { if (primeiro) { limitesTotais = path.Bounds; primeiro = false; } else { limitesTotais.Union(path.Bounds); } }

        float escalaAutoFit = _ultimaEscalaUI > 0 ? _ultimaEscalaUI : 1f;
        var matriz = SkiaSharp.SKMatrix.CreateTranslation(-_ultimoMidXUI, -_ultimoMidYUI);
        matriz = matriz.PostConcat(SkiaSharp.SKMatrix.CreateScale(escalaAutoFit, escalaAutoFit));
        matriz = matriz.PostConcat(SkiaSharp.SKMatrix.CreateTranslation(_larguraTela / 2f, _alturaTela / 2f));
        return matriz;
    }
    private List<object> ConverterCoordenadas(NetTopologySuite.Geometries.Coordinate[] coords)
    {
        var matriz = ObterMatrizMatematica();
        return coords.Select(c =>
        {
            var pt = matriz.MapPoint(new SkiaSharp.SKPoint((float)(c.X - MapService.OffsetMundoX), -(float)(c.Y - MapService.OffsetMundoY)));
            return (object)new { x = pt.X, y = pt.Y };
        }).ToList();
    }
    private async Task SincronizarOverlay(bool pendenteParaSwap = false)
    {
        var destaque = new List<List<object>>();
        if (_geometriaDestacada != null && !_geometriaDestacada.IsEmpty)
            ExtrairAneisMultiplos(_geometriaDestacada, destaque);

        var medicao = MapService.PontosMedicao.Select(p =>
        {
            var pt = ObterMatrizBaseSemMover().MapPoint(p);
            return (object)new { x = pt.X, y = pt.Y };
        }).ToList();

        if (pendenteParaSwap)
            await JSRuntime.InvokeVoidAsync("GeoNexGraphics.prepararFuturo", destaque, medicao, MapService.MostrarAreaMedicao);
        else
            await JSRuntime.InvokeVoidAsync("GeoNexGraphics.definirAtivos", destaque, medicao, MapService.MostrarAreaMedicao);
    }
    private SkiaSharp.SKPoint MatrizMundoParaLocalImagem(SkiaSharp.SKPoint ptMundo)
    {
        // Cria a matriz base idêntica à do LocalMapServer, mas SEM a deformação instantânea da câmara
        SkiaSharp.SKRect limitesTotais = new SkiaSharp.SKRect();
        bool primeiro = true;
        if (MapService.TemRaster) { limitesTotais = MapService.LimitesRasterGlobal; primeiro = false; }
        foreach (var path in MapService.VetoresPorCamada.Values) { if (primeiro) { limitesTotais = path.Bounds; primeiro = false; } else { limitesTotais.Union(path.Bounds); } }
        foreach (var path in MapService.LinhasPorCamada.Values) { if (primeiro) { limitesTotais = path.Bounds; primeiro = false; } else { limitesTotais.Union(path.Bounds); } }
        foreach (var path in MapService.PontosPorCamada.Values) { if (primeiro) { limitesTotais = path.Bounds; primeiro = false; } else { limitesTotais.Union(path.Bounds); } }

        float escalaAutoFit = _ultimaEscalaUI > 0 ? _ultimaEscalaUI : 1f;
        float midX = _ultimoMidXUI; float midY = _ultimoMidYUI;

        var matriz = SkiaSharp.SKMatrix.CreateTranslation(-midX, -midY);
        matriz = matriz.PostConcat(SkiaSharp.SKMatrix.CreateScale(escalaAutoFit, escalaAutoFit));
        matriz = matriz.PostConcat(SkiaSharp.SKMatrix.CreateTranslation(_larguraTela / 2f, _alturaTela / 2f));

        return matriz.MapPoint(ptMundo);
    }
    private void ConcluirAquisicaoPoligono()
    {
        if (MapService.PontosAquisicao.Count >= 3)
        {
            string camadaAlvo = _camadaDestinoAquisicao;

            // SEGURANÇA: Se o engenheiro escolheu [ Nova Camada ] no menu flutuante
            if (string.IsNullOrEmpty(camadaAlvo))
            {
                camadaAlvo = "Novos_Lotes";

                // Evita criar camadas com o mesmo nome se o utilizador repetir o processo
                int contador = 1;
                while (CamadasAtivas.Any(c => c.Nome == camadaAlvo))
                {
                    camadaAlvo = $"Novos_Lotes_{contador}";
                    contador++;
                }

                CamadasAtivas.Insert(0, new Camada { Nome = camadaAlvo, Tipo = "Vetor", Visivel = true });

                MapService.EstilosPorCamada[camadaAlvo] = new GeoNex.Services.EstiloCamada
                { CorPreenchimento = "#10b981", CorBorda = "#047857", EspessuraBorda = 2, TipoSimbologia = "UNICA", Opacidade = 0.5f };

                // Avisa o visualizador que uma nova camada nasceu
                SincronizarHierarquia();
            }

            var pontos = MapService.PontosAquisicao.ToList();
            pontos.Add(pontos[0]); // Fecha o perímetro

            var coordsWkt = pontos.Select(p => $"{(p.X + MapService.OffsetMundoX).ToString(System.Globalization.CultureInfo.InvariantCulture)} {(-p.Y + MapService.OffsetMundoY).ToString(System.Globalization.CultureInfo.InvariantCulture)}");
            string geometriaWKT = $"POLYGON (({string.Join(", ", coordsWkt)}))";

            try
            {
                var leitorWkt = new NetTopologySuite.IO.WKTReader();
                var geometriaNts = leitorWkt.Read(geometriaWKT);

                // === ESTRUTURA DE ATRIBUTOS (HERANÇA) ===
                var atributos = new NetTopologySuite.Features.AttributesTable();

                if (!MapService.FeicoesOriginais.TryGetValue(camadaAlvo, out var colecao))
                {
                    colecao = new NetTopologySuite.Features.FeatureCollection();
                    MapService.FeicoesOriginais[camadaAlvo] = colecao;
                }

                // Clona as colunas da camada existente para que a Tabela de Atributos não sofra crash
                if (colecao.Count > 0 && colecao[0].Attributes != null)
                {
                    foreach (var nomeAtributo in colecao[0].Attributes.GetNames())
                    {
                        atributos.Add(nomeAtributo, ""); // Inicia em branco
                    }
                }

                var novaFeicao = new NetTopologySuite.Features.Feature(geometriaNts, atributos);
                colecao.Add(novaFeicao);

                // 1. INJETA NA PLACA DE VÍDEO
                MapService.PreCompilarPoligonos(camadaAlvo, colecao);

                // 2. ATUALIZA A MIRA DO RATO (Raycast) PARA PODERMOS CLICAR NA NOVA FEIÇÃO
                // 2. RECONSTRÓI A ÁRVORE ESPACIAL PARA O SNAP E O RAYCAST LEREM O NOVO LOTE
                MapService.ConstruirIndiceEspacial();
                // 3. SE O MAPA FOR TEMÁTICO, RECALCULA AS CORES DE TUDO
                if (MapService.EstilosPorCamada.TryGetValue(camadaAlvo, out var estilo) && estilo.TipoSimbologia == "CATEGORIZADA")
                {
                    MapService.CompilarCategorias(camadaAlvo, estilo.ColunaSimbologia);
                }
            }
            catch (Exception ex) { Console.WriteLine("Erro topológico: " + ex.Message); }

            // Limpeza final do rascunho de ecrã
            MapService.PontosAquisicao.Clear();
            MapService.PontoCursorMundo = null;

            SolicitarNovoFrame();
            StateHasChanged();
        }
    }

    private void CancelarAquisicao()
    {
        MapService.PontosAquisicao.Clear();
        MapService.PontoCursorMundo = null;
        SolicitarNovoFrame();
        StateHasChanged();
    }

    private void DesfazerUltimoPontoAquisicao()
    {
        if (MapService.PontosAquisicao.Count > 0)
        {
            MapService.PontosAquisicao.RemoveAt(MapService.PontosAquisicao.Count - 1);
            SolicitarNovoFrame(); // Força a placa gráfica a recalcular a linha elástica
            StateHasChanged();    // Atualiza a interface
        }
    }
    private void AplicarVetorRestritoCogo()
    {
        if (MapService.PontosAquisicao.Count == 0) return;

        var ultimoPonto = MapService.PontosAquisicao.Last();

        // Conversão de graus (azimute topográfico) para radianos
        double radianos = _cogoAzimute * (Math.PI / 180.0);

        // APLICAÇÃO DA INVERSÃO DE MATRIZ: Y negativo para subir na tela (Norte)
        float matrizMundoProjX = ultimoPonto.X + (float)(_cogoDistancia * Math.Sin(radianos));
        float matrizMundoProjY = ultimoPonto.Y - (float)(_cogoDistancia * Math.Cos(radianos));

        // Injeta a nova coordenada cravada no mapa
        MapService.PontosAquisicao.Add(new SkiaSharp.SKPoint(matrizMundoProjX, matrizMundoProjY));
        // Limpeza de estado e retorno ao modo fluido
        _mostrarInputCogo = false;
        _mostrarMenuContexto = false;
        _cogoDistancia = 0;
        _cogoAzimute = 0;

        SolicitarNovoFrame();
        InvokeAsync(StateHasChanged);
    }
    private void AplicarCoordenadaAbsoluta()
    {
        // Subtrai o "Offset do Mundo" (que tira os milhões da coordenada UTM)
        // e aplica a inversão forçada do Eixo Y na tela.
        float matrizX = (float)(_absolutoX - MapService.OffsetMundoX);
        float matrizY = (float)(MapService.OffsetMundoY - _absolutoY);

        MapService.PontosAquisicao.Add(new SkiaSharp.SKPoint(matrizX, matrizY));

        _mostrarInputAbsoluto = false;
        _absolutoX = 0;
        _absolutoY = 0;

        SolicitarNovoFrame();
        InvokeAsync(StateHasChanged);
    }
