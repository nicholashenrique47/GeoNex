    // =========================================================================
    private async Task SelecionarArquivoVetor()
    {
        try
        {
            var opcoes = new PickOptions
            {
                PickerTitle = "Selecione o Vetor (SHP, GeoJSON)",
                FileTypes = new FilePickerFileType(new Dictionary<DevicePlatform, IEnumerable<string>> { { DevicePlatform.WinUI, new[] { ".shp", ".geojson", ".kml" } } })
            };
            var resultado = await FilePicker.Default.PickAsync(opcoes);
            if (resultado != null) { caminhoArquivoVetor = resultado.FullPath; StateHasChanged(); }
        }
        catch (Exception ex) { await JSRuntime.InvokeVoidAsync("alert", $"Erro ao selecionar arquivo vetorial: {ex.Message}"); }
    }

    private async Task AdicionarVetorAoMapa()
    {
        try
        {
            if (string.IsNullOrEmpty(caminhoArquivoVetor))
            {
                await JSRuntime.InvokeVoidAsync("alert", "Selecione um arquivo Shapefile primeiro!");
                return;
            }

            exibirModalImportacao = false;
            string nomeArquivo = System.IO.Path.GetFileName(caminhoArquivoVetor);
            poligonosNativos = await Task.Run(() => RasterService.ExtrairPoligonosNativos(caminhoArquivoVetor));

            if (poligonosNativos.Count > 0)
            {
                CalcularLimitesDoMapa();
                MapService.PreCompilarPoligonos(nomeArquivo, poligonosNativos);

                // Impede que o Shapefile quebre o Blazor se for importado novamente
                var camadaExistente = CamadasAtivas.FirstOrDefault(c => c.Nome == nomeArquivo);
                if (camadaExistente == null)
                {
                    CamadasAtivas.Add(new Camada { Nome = nomeArquivo, Tipo = "Vetor", Visivel = true, CaminhoArquivo = caminhoArquivoVetor });
                }

                MapService.CameraPanX = 0; MapService.CameraPanY = 0; MapService.CameraZoom = 1.0f; await JSRuntime.InvokeVoidAsync("mapEngine.resetarCamera");
                StateHasChanged();
                SincronizarHierarquia();
            }
        }
        catch (Exception ex) { await JSRuntime.InvokeVoidAsync("alert", $"Erro Crítico na Importação Nativa: {ex.Message}"); }
    }

    private void CalcularLimitesDoMapa()
    {
        mapaMinX = float.MaxValue; mapaMaxX = float.MinValue;
        mapaMinY = float.MaxValue; mapaMaxY = float.MinValue;
        foreach (var poli in poligonosNativos)
        {
            for (int i = 0; i < poli.Length; i += 2)
            {
                float x = poli[i]; float y = poli[i + 1];
                if (x < mapaMinX) mapaMinX = x; if (x > mapaMaxX) mapaMaxX = x;
                if (y < mapaMinY) mapaMinY = y; if (y > mapaMaxY) mapaMaxY = y;
            }
        }
    }

