@page "/"
@inject IJSRuntime JSRuntime
@implements IDisposable
@inject GeoNex.Services.ProjetoService ProjetoService
@inject GeoNex.Services.RasterService RasterService
@inject GeoNex.Services.MapRenderingService MapService
@using SkiaSharp
@using SkiaSharp.Views.Blazor
@using ProjNet.CoordinateSystems
@using ProjNet.CoordinateSystems.Transformations
<PageTitle>GeoNex - Professional GIS</PageTitle>

<div class="map-background"
     style="width: 100vw; height: 100vh; background-color: #161921; overflow: hidden; cursor: @(isDragging ? "grabbing" : "grab"); position: relative;"
     @onwheel="AoRodarRato"
     @onmousedown="AoPressionarRato"
     @onmousemove="AoMoverRato"
     @onmouseup="AoSoltarRato"
     @onmouseleave="AoSoltarRato">

    @if (!string.IsNullOrEmpty(mapaUrl))
    {
        <img id="skia-layer" src="@mapaUrl" style="width: 100%; height: 100%; position: absolute; z-index: 10; object-fit: fill; pointer-events: none;" />
    }
</div>
//começou aqui
<!-- A INTERFACE FLUTUANTE -->
<div class="geonex-ui">

    <!-- BARRA SUPERIOR (HEADER & RIBBON) -->
    <header class="glass-panel top-bar">
        <div class="brand-group">
            <h1>GEONEX</h1>
            <span class="sub-brand">PRO</span>
        </div>
        <button class="btn btn-danger m-2" @onclick="TestarMotorCPlusPlus">🔥 TESTAR MOTOR C++</button>
        <nav class="main-menu">

            <div class="dropdown">
                <button class="menu-btn">Arquivo ▾</button>
                <div class="dropdown-content">
                    <button @onclick="CriarNovoProjeto">Novo Projeto</button>
                    <button>Abrir Projeto...</button>
                    <div class="drop-divider"></div>
                    <button>Salvar</button>
                    <button>Salvar Como...</button>
                    <div class="drop-divider"></div>
                    <button>Configurações do Sistema</button>
                    <button>Sair</button>
                </div>
            </div>
            <!-- MENU: DADOS (Com ação de abrir o modal) -->
            <div class="dropdown">
                <button class="menu-btn">Dados ▾</button>
                <div class="dropdown-content">
                    <button @onclick="AbrirModalImportacao">Importar Raster (ECW, TIF)</button>
                    <button @onclick="AbrirModalImportacao">Importar Vetor (SHP, GeoJSON)</button>
                    <button @onclick="AbrirModalImportacao">Importar Pontos (CSV, TXT)</button>
                    <div class="drop-divider"></div>
                    <button>Conectar Banco PostGIS</button>
                </div>
            </div>

            <div class="dropdown">
                <button class="menu-btn">Exportar ▾</button>
                <div class="dropdown-content">
                    <button>Exportar Vetor (Shapefile)</button>
                    <button>Exportar Tabela (CSV)</button>
                </div>
            </div>

            <div class="dropdown">
                <button class="menu-btn">GNSS / RTK ▾</button>
                <div class="dropdown-content">
                    <button>Gerenciador de Conexão (COM/BT)</button>
                    <button>Monitor NMEA (Satélites)</button>
                </div>
            </div>

            <button class="menu-btn sync-btn">Sincronizar Nuvem</button>
            <div class="vertical-divider"></div>

            <div class="toolbar-group">
                <span class="toolbar-label">AQUISIÇÃO</span>
                <button class="tool-btn active">Selecionar</button>
                <button class="tool-btn" @onclick="() => exibirModalCoordenadas = true">Inserir Coordenadas</button>
                <button class="tool-btn" @onclick="AtivarFerramentaPoligono">Polígono (Manual)</button>
            </div>

            <div class="toolbar-group">
                <span class="toolbar-label">EDIÇÃO</span>
                <button class="tool-btn @(modoEdicaoVerticeLigado ? "active" : "")" @onclick="AlternarEdicaoVertices">Vértices</button>
                <button class="tool-btn">Cortar</button>

                <div class="vertical-divider" style="height: 15px; margin: 0 5px;"></div>

                <button class="tool-btn"
                        style="@(temEdicoesPendentes ? "color: #facc15; border: 1px solid #facc15; font-weight: bold; background: rgba(250, 204, 21, 0.1);" : "opacity: 0.5; cursor: not-allowed;")"
                        @onclick="ConfirmarTodasEdicoes"
                        disabled="@(!temEdicoesPendentes)">
                    Salvar Edições
                </button>
            </div>
        </nav>

        <div class="status-group">
            <span class="status-indicator online"></span>
            <span class="status-text">API CONECTADA</span>
        </div>
    </header>

    <!-- PAINÉIS LATERAIS E ÁREA DE TRABALHO -->
    <main class="workspace-area">

        <!-- PAINEL ESQUERDO: CAMADAS -->
        <aside class="glass-panel side-panel left-panel">
            <div class="panel-header">
                <h2>CAMADAS</h2>
                <div class="header-actions">
                    <button class="icon-action-btn">+</button>
                </div>
            </div>

            <div class="layer-list custom-scrollbar">
                @foreach (var camada in CamadasAtivas)
                {
                    // Variável local de segurança para o Blazor não se perder nos eventos de clique
                    var camadaAtual = camada;

                    <!-- A camada agora é arrastável nativamente -->
                    <div @key="camadaAtual.Nome"
                         class="layer-item @(camadaAtual.Tipo.ToLower())"
                         draggable="true"
                         @ondragstart="() => AoIniciarArrastar(camadaAtual)"
                         @ondrop="() => AoSoltarCamada(camadaAtual)"
                         @ondragover="@(e => { })"
                         @ondragover:preventDefault="true"
                         @oncontextmenu="(e) => MostrarMenuContexto(e, camadaAtual.Nome)"
                         @oncontextmenu:preventDefault="true">

                        <!-- PEGADOR (Drag Handle) - Indica onde agarrar -->
                        <div class="drag-handle" title="Arrastar para reordenar">
                            <svg width="12" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <circle cx="9" cy="12" r="1"></circle>
                                <circle cx="9" cy="5" r="1"></circle>
                                <circle cx="9" cy="19" r="1"></circle>
                                <circle cx="15" cy="12" r="1"></circle>
                                <circle cx="15" cy="5" r="1"></circle>
                                <circle cx="15" cy="19" r="1"></circle>
                            </svg>
                        </div>

                        <input type="checkbox"
                               checked="@camadaAtual.Visivel"
                               @onchange="@(e => ToggleCamada(camadaAtual, (bool)(e.Value ?? false)))" />

                        <span class="type-tag" style="background: @(camadaAtual.Tipo == "Raster" ? "#5b21b6" : "#065f46"); color: @(camadaAtual.Tipo == "Raster" ? "#ddd6fe" : "#a7f3d0");">
                            @(camadaAtual.Tipo == "Raster" ? "R" : "V")
                        </span>

                        <span class="layer-title no-select">@camadaAtual.Nome</span>

                        <!-- O resto dos seus botões continuam iguais aqui para baixo... -->
                        @if (camadaAtual.Tipo == "Vetor")
                        {
                            <div class="layer-actions" style="display: flex; gap: 5px; margin-left: auto;">

                                <!-- Botão 1: Tabela -->
                                <button type="button" class="layer-action-btn" title="Abrir Tabela de Atributos"
                                        @onclick="() => AbrirTabela(camadaAtual.Nome)"
                                        @onclick:stopPropagation="true">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                                        <line x1="3" y1="9" x2="21" y2="9"></line>
                                        <line x1="9" y1="21" x2="9" y2="9"></line>
                                    </svg>
                                </button>

                                <!-- Botão 2: Propriedades -->
                                <button type="button" class="layer-action-btn" title="Propriedades da Camada"
                                        @onclick="() => AbrirPropriedadesCamada(camadaAtual.Nome)"
                                        @onclick:stopPropagation="true">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <circle cx="12" cy="12" r="3"></circle>
                                        <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"></path>
                                    </svg>
                                </button>

                                <!-- NOVO MENU DE CONTEXTO (Três Pontinhos) -->
                                <!-- MENU DE CONTEXTO (Três Pontinhos) -->
                                <button type="button" class="layer-action-btn" title="Opções da Camada"
                                        @onclick="(e) => BotaoOpcoesClicado(e, camadaAtual.Nome)"
                                        @onclick:stopPropagation="true">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <circle cx="12" cy="12" r="1"></circle>
                                        <circle cx="12" cy="5" r="1"></circle>
                                        <circle cx="12" cy="19" r="1"></circle>
                                    </svg>
                                </button>

                            </div>
                        }
                    </div>
                }

                @if (CamadasAtivas.Count == 0)
                {
                    <div style="padding: 15px; color: #64748b; font-size: 0.75rem; text-align: center;">
                        Nenhuma camada adicionada ao projeto.
                    </div>
                }
            </div>
        </aside>

        <!-- O PAINEL SENSORIAL BLINDADO -->
       
        <!-- PAINEL DIREITO: ATRIBUTOS -->
        <aside class="glass-panel side-panel right-panel">
            <div class="panel-header">
                <h2>ATRIBUTOS DA FEIÇÃO</h2>
            </div>
            <div class="properties-content custom-scrollbar">

                @if (atributosFeicaoSelecionada != null && atributosFeicaoSelecionada.Count > 0)
                {
                    <div class="attribute-form">
                        <div class="form-group mb-15" style="border-bottom: 1px solid rgba(255,255,255,0.1); padding-bottom: 10px;">
                            <label>Camada Origem</label>
                            <span style="font-size: 0.75rem; color: #38bdf8; font-weight: bold; word-break: break-all;">@camadaSelecionadaPainel</span>
                        </div>

                        @foreach (var atributo in atributosFeicaoSelecionada)
                        {
                            <div class="form-group">
                                <label>@atributo.Key</label>
                                @if (atributo.Key.ToUpper() == "FID" || atributo.Key.ToUpper() == "ID")
                                {
                                    <input type="text" class="glass-input" value="@atributo.Value" readonly style="opacity: 0.6;" />
                                }
                                else
                                {
                                    <input type="text" class="glass-input editable" value="@atributo.Value" @onchange="(e) => AtualizarAtributoPainel(atributo.Key, e.Value.ToString())" />
                                }
                            </div>
                        }

                        <div class="import-actions" style="margin-top: 20px;">
                            <button class="btn-save add-layer-btn" style="width: 100%;" @onclick="SalvarAtributosPainel">SALVAR ALTERAÇÕES</button>
                        </div>
                    </div>
                }
                else
                {
                    <div style="display: flex; height: 100%; align-items: center; justify-content: center; color: #64748b; font-size: 0.85rem; text-align: center; padding: 20px; flex-direction: column; gap: 10px;">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path>
                            <polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline>
                            <line x1="12" y1="22.08" x2="12" y2="12"></line>
                        </svg>
                        <span>Selecione um polígono no mapa para inspecionar seus atributos.</span>
                    </div>
                }

            </div>
        </aside>

    </main>
    <main class="workspace-area">
    </main>

    @if (exibirTabelaAtributos)
    {
        <div class="glass-panel attribute-table-container">
            <div class="table-header">
                <span>TABELA DE ATRIBUTOS: @nomeCamadaAtiva</span>
                <button class="close-btn" @onclick="() => exibirTabelaAtributos = false">✕</button>
            </div>
            <div class="table-wrapper custom-scrollbar">
                <table>
                    <thead>
                        <tr>
                            @foreach (var col in colunasTabela)
                            {
                                <th>@col</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var linha in dadosTabela)
                        {
                            <tr @onclick="() => SelecionarNoMapa(linha)">
                                @foreach (var col in colunasTabela)
                                {
                                    <td>
                                        <input class="cell-input"
                                               value="@(linha.ContainsKey(col) ? linha[col] : "")"
                                               @onchange="(e) => AtualizarAtributo(linha, col, e.Value)" />
                                    </td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

    <footer class="bottom-status-bar">
    </footer>
    <!-- RODAPÉ DE TELEMETRIA -->
    <footer class="bottom-status-bar">
        <div class="status-left">
            <span><strong>PROJETO:</strong> Guaratuba_ZonaSul.gnx</span>
        </div>
        <div class="status-right">
            <span><strong>X:</strong> <span class="mono">@longitude</span></span>
            <span><strong>Y:</strong> <span class="mono">@latitude</span></span>
            <span class="scale-box">1:1.000</span>
        </div>
    </footer>

    <!-- ========================================== -->
    <!-- JANELA MODAL DE IMPORTAÇÃO (DATA MANAGER)  -->
    <!-- ========================================== -->
    @if (exibirModalImportacao)
    {
        <div class="modal-overlay">
            <div class="glass-panel import-modal">
                <div class="modal-header">
                    <h2>GERENCIADOR DE FONTES DE DADOS</h2>
                    <button class="close-modal-btn" @onclick="FecharModalImportacao">✕</button>
                </div>
                <div class="modal-body">
                    <div class="modal-tabs">
                        <button class="tab-btn @(AbaModalAtiva == "Raster" ? "active" : "")" @onclick="@(() => TrocarAbaModal("Raster"))">Raster (ECW, TIF)</button>
                        <button class="tab-btn @(AbaModalAtiva == "Vetor" ? "active" : "")" @onclick="@(() => TrocarAbaModal("Vetor"))">Vetor (SHP, GeoJSON)</button>
                        <button class="tab-btn @(AbaModalAtiva == "Texto" ? "active" : "")" @onclick="@(() => TrocarAbaModal("Texto"))">Texto Delimitado</button>
                        <button class="tab-btn @(AbaModalAtiva == "Nuvem" ? "active" : "")" @onclick="@(() => TrocarAbaModal("Nuvem"))">Nuvem (PostGIS)</button>
                    </div>

                    <div class="modal-content">

                        @if (AbaModalAtiva == "Raster")
                        {
                            <div class="form-group mb-15">
                                <label>Arquivo Fonte / Dataset (Raster)</label>
                                <div class="file-input-group">
                                    <input type="text" class="glass-input file-path" value="@caminhoArquivoRaster" placeholder="C:\Caminho\para\arquivo.tif" readonly />
                                    <button class="btn-browse" @onclick="SelecionarArquivoRaster">PROCURAR...</button>
                                </div>
                                <div style="margin-top: 10px; font-size: 0.7rem; color: #34d399; background: rgba(0,0,0,0.2); padding: 10px; border-radius: 4px; border: 1px solid rgba(52,211,153,0.2);">
                                    <pre style="margin:0; white-space: pre-wrap;">@statusGdal</pre>
                                </div>
                            </div>

                            <div class="import-actions">
                                <button class="btn-save add-layer-btn" @onclick="AdicionarCamadaAoMapa">ADICIONAR RASTER AO MAPA</button>
                                <button class="btn-cancel" @onclick="FecharModalImportacao">CANCELAR</button>
                            </div>
                        }
                        else if (AbaModalAtiva == "Vetor")
                        {
                            <div class="form-group mb-15">
                                <label>Arquivo Fonte Vetorial (Shapefile, KML, GeoJSON)</label>
                                <div class="file-input-group">
                                    <input type="text" class="glass-input file-path" value="@caminhoArquivoVetor" placeholder="C:\Caminho\para\lotes.shp" readonly />
                                    <button class="btn-browse" @onclick="SelecionarArquivoVetor">PROCURAR...</button>
                                </div>
                            </div>

                            <div class="form-group mb-15">
                                <label>Sistema de Referência de Coordenadas (CRS/EPSG)</label>
                                <select class="glass-input editable">
                                    <option>Automático (Lido do arquivo .prj)</option>
                                    <option>EPSG:31982 - SIRGAS 2000 / UTM zone 22S</option>
                                    <option>EPSG:4326 - WGS 84</option>
                                </select>
                            </div>

                            <div class="import-actions">
                                <button class="btn-save add-layer-btn" @onclick="AdicionarVetorAoMapa">ADICIONAR VETOR AO MAPA</button>
                                <button class="btn-cancel" @onclick="FecharModalImportacao">CANCELAR</button>
                            </div>
                        }
                        else
                        {
                            <div style="display: flex; height: 100%; align-items: center; justify-content: center; color: #64748b; font-size: 0.85rem;">
                                Módulo em desenvolvimento.
                            </div>
                        }

                    </div>
                </div>
            </div>
        </div>
    }
    @if (exibirModalPropriedades)
    {
        <div class="modal-overlay">
            <div class="glass-panel modal-container" style="width: 550px; min-height: 400px;">
                <div class="modal-header">
                    <h2>PROPRIEDADES: @camadaEmEdicao</h2>
                    <button class="close-btn" @onclick="() => exibirModalPropriedades = false">✕</button>
                </div>

                <div class="modal-body properties-layout">

                    <nav class="properties-sidebar">
                        <button class="tab-btn @(abaAtivaPropriedades == "Simbologia" ? "active" : "")" @onclick='() => abaAtivaPropriedades = "Simbologia"'>Simbologia</button>
                        <button class="tab-btn @(abaAtivaPropriedades == "Rotulos" ? "active" : "")" @onclick='() => abaAtivaPropriedades = "Rotulos"'>Rótulos</button>
                        <button class="tab-btn @(abaAtivaPropriedades == "Informacao" ? "active" : "")" @onclick='() => abaAtivaPropriedades = "Informacao"'>Informação</button>
                    </nav>

                    <div class="properties-content custom-scrollbar">

                        @if (abaAtivaPropriedades == "Simbologia")
                        {
                            <div class="form-group-vertical">
                                <label>TIPO DE SIMBOLOGIA</label>
                                <select class="glass-input" @bind="tipoSimbologia">
                                    <option value="UNICA">Símbolo Único (Cor Sólida)</option>
                                    <option value="CATEGORIZADA">Categorizado (Por Atributo)</option>
                                </select>
                            </div>

                            <hr style="border: none; border-top: 1px solid rgba(255,255,255,0.05); margin: 5px 0;" />

                            @if (tipoSimbologia == "UNICA")
                            {
                                <div class="form-group-vertical">
                                    <label>Cor de Preenchimento</label>
                                    <div class="color-picker-row">
                                        <input type="color" @bind="corPreenchimento" class="color-box" />
                                        <input type="text" class="glass-input" @bind="corPreenchimento" />
                                    </div>
                                </div>
                                <div class="form-group-vertical">
                                    <label>Cor da Borda</label>
                                    <div class="color-picker-row">
                                        <input type="color" @bind="corBorda" class="color-box" />
                                        <input type="text" class="glass-input" @bind="corBorda" />
                                    </div>
                                </div>
                            }
                            else
                            {
                                <div class="form-group-vertical">
                                    <label>Separar Cores Usando a Coluna:</label>
                                    <select class="glass-input" @bind="colunaSimbologiaCategorizada">
                                        <option value="">[ Selecione a Coluna ]</option>
                                        @foreach (var col in colunasDisponiveisRotulo)
                                        {
                                            <option value="@col">@col</option>
                                        }
                                    </select>
                                </div>
                            }

                            <div class="form-group-vertical" style="margin-top: 10px;">
                                <label>Opacidade (@opacidadePreenchimento%)</label>
                                <input type="range" min="0" max="100" step="1" @bind="opacidadePreenchimento" @bind:event="oninput" class="slider" />
                            </div>

                            <div class="form-group-vertical" style="margin-top: 10px;">
                                <label>Espessura da Linha (@espessuraLinha px)</label>
                                <input type="range" min="0" max="5" step="0.5" @bind="espessuraLinha" class="slider" />
                            </div>
                        }
                        else if (abaAtivaPropriedades == "Rotulos")
                        {
                            <div class="form-group-vertical">
                                <label>Rotular com (Coluna)</label>
                                <select class="glass-input" @bind="colunaRotuloSelecionada" style="width: 100%; padding: 8px; border: 1px solid rgba(255,255,255,0.2); background: rgba(0,0,0,0.4); color: #fff; border-radius: 4px;">
                                    <option value="">[ Nenhum Rótulo ]</option>
                                    @foreach (var col in colunasDisponiveisRotulo)
                                    {
                                        <option value="@col">@col</option>
                                    }
                                </select>
                            </div>

                            <div class="form-group-vertical" style="margin-top: 15px;">
                                <label>Tamanho da Fonte (@tamanhoFonteRotulo px)</label>
                                <input type="range" min="8" max="32" step="1" @bind="tamanhoFonteRotulo" class="slider" />
                            </div>

                            <div class="form-group-vertical" style="margin-top: 15px;">
                                <label>Cor do Texto</label>
                                <div class="color-picker-row">
                                    <input type="color" @bind="corFonteRotulo" class="color-box" />
                                    <input type="text" class="glass-input" @bind="corFonteRotulo" />
                                </div>
                            </div>
                        }
                        else if (abaAtivaPropriedades == "Informacao")
                        {
                            <div style="color: #94a3b8; font-size: 0.85rem; padding: 10px;">
                                <p style="margin-bottom: 10px;"><strong>Sistema de Coordenadas:</strong> EPSG:4326</p>
                                <p style="margin-bottom: 10px;"><strong>Formato:</strong> Vetor OGR</p>
                            </div>
                        }

                    </div>
                </div>

                <div class="modal-footer">
                    <button class="btn-cancel" @onclick="() => exibirModalPropriedades = false">CANCELAR</button>
