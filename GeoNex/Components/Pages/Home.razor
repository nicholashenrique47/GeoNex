    private async Task AoSoltarCamada(Camada camadaAlvo)
    {
        Console.WriteLine($"[GEONEX] 2. SOLTOU em cima de: {camadaAlvo.Nome}");

        // Ignora se soltar no mesmo lugar
        if (camadaArrastada == null || camadaArrastada == camadaAlvo)
        {
            Console.WriteLine("[GEONEX] Movimento cancelado (Mesmo lugar ou fora).");
            return;
        }

        int indexOrigem = CamadasAtivas.IndexOf(camadaArrastada);
        int indexDestino = CamadasAtivas.IndexOf(camadaAlvo);

        if (indexOrigem < 0 || indexDestino < 0) return;

        // Faz a troca cirúrgica na lista do C#
        CamadasAtivas.RemoveAt(indexOrigem);
        CamadasAtivas.Insert(indexDestino, camadaArrastada);

        // Avisa o motor gráfico (Leaflet)
        var listaOrdenadaNomes = CamadasAtivas.Select(c => c.Nome).ToArray();
        await JSRuntime.InvokeVoidAsync("atualizarOrdemRenderizacao", listaOrdenadaNomes);

        Console.WriteLine("[GEONEX] 3. Hierarquia alterada com Sucesso!");

        // Limpa a memória e FORÇA A TELA A REDESENHAR
        camadaArrastada = null;
        StateHasChanged();
    }
    private async Task MoverCamada(string nomeCamada, int direcao)
    {
        // 1. Fecha o menu para não atrapalhar a visão
        FecharMenuContexto();

        // 2. Acha a posição atual da camada na memória
        int index = CamadasAtivas.FindIndex(c => c.Nome == nomeCamada);
        if (index < 0) return;

        // 3. Calcula o destino (-1 sobe na lista, +1 desce)
        int novoIndex = index + direcao;

        // 4. Bloqueio de segurança: impede que a camada saia dos limites da lista
        if (novoIndex >= 0 && novoIndex < CamadasAtivas.Count)
        {
            // Executa a troca cirúrgica
            var item = CamadasAtivas[index];
            CamadasAtivas.RemoveAt(index);
            CamadasAtivas.Insert(novoIndex, item);

            // 5. Avisa o Leaflet (JavaScript) para recalcular os Z-Index
            var listaOrdenadaNomes = CamadasAtivas.Select(c => c.Nome).ToArray();
            await JSRuntime.InvokeVoidAsync("atualizarOrdemRenderizacao", listaOrdenadaNomes);

            // 6. Repinta a interface do Blazor
            StateHasChanged();
        }
    }
