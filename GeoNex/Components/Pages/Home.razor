    private async Task AdicionarVetorAoMapa()
    {
        try
        {
            if (string.IsNullOrEmpty(caminhoArquivoVetor))
            {
                await JSRuntime.InvokeVoidAsync("alert", "Selecione um arquivo Shapefile primeiro!");
                return;
            }

            exibirModalImportacao = false;
            string nomeArquivo = System.IO.Path.GetFileName(caminhoArquivoVetor);

            // === A MÁGICA ACONTECE AQUI ===
            // Substituímos o extrator antigo pelo nosso Motor Duplo que carrega o SkiaSharp e a Árvore NTS
            // === A MÁGICA ACONTECE AQUI ===
            // Substituímos o extrator antigo pelo nosso Motor Duplo que carrega o SkiaSharp e a Árvore NTS
            await Task.Run(() =>
            {
                ProjetoService.CarregarShapefileParaMotorMapas(caminhoArquivoVetor, nomeArquivo, MapService);
            });

            // CORREÇÃO CRÍTICA: Popula a árvore de busca logarítmica com os lotes importados
            MapService.ConstruirIndiceEspacial();

            // Impede que o Shapefile duplique o painel se for importado novamente
            // Substitua o bloco do camadaExistente por este:
            var camadaExistente = CamadasAtivas.FirstOrDefault(c => c.Nome == nomeArquivo);
            if (camadaExistente == null)
            {
                // .Insert(0) atira a nova camada para o Topo absoluto do Painel Lateral
                CamadasAtivas.Insert(0, new Camada { Nome = nomeArquivo, Tipo = "Vetor", Visivel = true, CaminhoArquivo = caminhoArquivoVetor });
            }

            // Reinicia a câmara para o mapa inicial
            MapService.CameraPanX = 0;
            MapService.CameraPanY = 0;
            MapService.CameraZoom = 1.0f;
            MapService.RasterCache?.Dispose();
            MapService.RasterCache = null;

            SolicitarNovoFrame();
            StateHasChanged();
            await JSRuntime.InvokeVoidAsync("mapEngine.resetarCamera");

            StateHasChanged();
            SincronizarHierarquia();
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", $"Erro Crítico na Importação Nativa: {ex.Message}");
        }
    }

    private void CalcularLimitesDoMapa()
    {
        mapaMinX = float.MaxValue; mapaMaxX = float.MinValue;
        mapaMinY = float.MaxValue; mapaMaxY = float.MinValue;
        foreach (var poli in poligonosNativos)
        {
            for (int i = 0; i < poli.Length; i += 2)
            {
                float x = poli[i]; float y = poli[i + 1];
                if (x < mapaMinX) mapaMinX = x; if (x > mapaMaxX) mapaMaxX = x;
                if (y < mapaMinY) mapaMinY = y; if (y > mapaMaxY) mapaMaxY = y;
            }
        }
    }

