    [JSInvokable]
    public void AtualizarCameraJS(double deltaX, double deltaY, double scaleMultiplier)
    {
        MapService.CameraPanX = (float)((MapService.CameraPanX * scaleMultiplier) + deltaX);
        MapService.CameraPanY = (float)((MapService.CameraPanY * scaleMultiplier) + deltaY);
        MapService.CameraZoom *= (float)scaleMultiplier;

        _ = SincronizarOverlay(true); // Envia para a sala de espera antes da imagem carregar
        SolicitarNovoFrame();
    }
    // Variável que controla a física do íman de desenho
    // Variáveis que controlam os ímanes de desenho simultaneamente
    private bool _snapAquisicaoVertice = true;
    private bool _snapAquisicaoAresta = false; 
    [JSInvokable]
    public void ReceberMovimentoFerramentas(double pixelX, double pixelY)
    {
        if (_ferramentaAtiva == ModoFerramenta.Medicao || _ferramentaAtiva == ModoFerramenta.AquisicaoPoligono)
        {
            var matrizCompleta = ObterMatrizMatematica();

            if (matrizCompleta.TryInvert(out var matrizInversa))
            {
                var ptMundo = matrizInversa.MapPoint(new SkiaSharp.SKPoint((float)pixelX, (float)pixelY));
                MapService.PontoCursorMundo = ptMundo;

                // --- ISOLAMENTO MAGNÉTICO (Vértices e Arestas 100% Independentes) ---
                bool usarSnap = false;
                bool checarVertices = false;
                bool checarArestas = false;

                if (_ferramentaAtiva == ModoFerramenta.Medicao && _snapMedicaoAtivo)
                {
                    usarSnap = true;
                    checarVertices = true;
                    checarArestas = false; // A correção da Medição: Nunca usa arestas!
                }
                else if (_ferramentaAtiva == ModoFerramenta.AquisicaoPoligono)
                {
                    if (_snapAquisicaoVertice || _snapAquisicaoAresta)
                    {
                        usarSnap = true;
                        checarVertices = _snapAquisicaoVertice;
                        checarArestas = _snapAquisicaoAresta;
                    }
                }

                if (usarSnap)
                {
                    var ptMagnetico = MapService.EncontrarVerticeProximo(ptMundo, 15.0f / matrizCompleta.ScaleX, checarVertices, checarArestas);
                    if (ptMagnetico.HasValue)
                    {
                        MapService.PontoCursorSnap = ptMagnetico.Value;
                        MapService.PontoCursorMundo = ptMagnetico.Value;
                    }
                    else { MapService.PontoCursorSnap = null; }
                }
                else { MapService.PontoCursorSnap = null; }

                if ((DateTime.Now - _ultimoMovimentoMouse).TotalMilliseconds >= 33)
                {
                    _ultimoMovimentoMouse = DateTime.Now;
                    bool precisaRedesenhar = false;
                    bool precisaAtualizarHTML = false;

                    if (_ferramentaAtiva == ModoFerramenta.Medicao && MapService.PontosMedicao.Count > 0)
                    {
                        RecalcularMedicoes();
                        precisaRedesenhar = true;
                        precisaAtualizarHTML = true;
                    }

                    if (_ferramentaAtiva == ModoFerramenta.AquisicaoPoligono && MapService.PontosAquisicao.Count > 0)
                    {
                        precisaRedesenhar = true; 
                    }

                    if (!Nullable.Equals(MapService.PontoCursorSnap, _ultimoSnapRenderizado))
                    {
                        precisaRedesenhar = true;
                        _ultimoSnapRenderizado = MapService.PontoCursorSnap;
                    }

                    if (precisaRedesenhar)
                    {
                        SolicitarNovoFrame();
                        if (precisaAtualizarHTML) StateHasChanged();
                    }
                }
            }
        }
    }
