    private async Task PrepararRemocaoCamada()
    {
        string alvo = camadaSelecionadaMenu; FecharMenuContexto();
        var camada = CamadasAtivas.FirstOrDefault(c => c.Nome == alvo);
        if (camada != null) { CamadasAtivas.Remove(camada); StateHasChanged(); }
        await JSRuntime.InvokeVoidAsync("removerCamadaDoMapa", alvo);
    }

    private async Task MoverCamada(string nomeCamada, int direcao)
    {
        FecharMenuContexto();
        int index = CamadasAtivas.FindIndex(c => c.Nome == nomeCamada);
        if (index < 0) return;
        int novoIndex = index + direcao;
        if (novoIndex >= 0 && novoIndex < CamadasAtivas.Count)
        {
            var item = CamadasAtivas[index];
            CamadasAtivas.RemoveAt(index); CamadasAtivas.Insert(novoIndex, item);
            var listaOrdenadaNomes = CamadasAtivas.Select(c => c.Nome).ToArray();
            await JSRuntime.InvokeVoidAsync("atualizarOrdemRenderizacao", listaOrdenadaNomes);
            StateHasChanged();
            SincronizarHierarquia();
        }
    }

    private void AoIniciarArrastar(Camada camada) { camadaArrastada = camada; }

    private async Task AoSoltarCamada(Camada camadaAlvo)
    {
        if (camadaArrastada == null || camadaArrastada == camadaAlvo) return;
        int iOrigem = CamadasAtivas.IndexOf(camadaArrastada);
        int iDestino = CamadasAtivas.IndexOf(camadaAlvo);
        if (iOrigem < 0 || iDestino < 0) return;
        CamadasAtivas.RemoveAt(iOrigem); CamadasAtivas.Insert(iDestino, camadaArrastada);
        var listaOrdenadaNomes = CamadasAtivas.Select(c => c.Nome).ToArray();
        await JSRuntime.InvokeVoidAsync("atualizarOrdemRenderizacao", listaOrdenadaNomes);
        camadaArrastada = null; StateHasChanged();
        SincronizarHierarquia();
    }

