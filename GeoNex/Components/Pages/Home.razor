    /* =========================================================
           ARQUITETURA DE SUBMENUS EM CASCATA (NESTED DROPDOWNS)
           ========================================================= */
    .dropdown-submenu {
        position: relative;
    }

    .submenu-btn {
        display: flex;
        justify-content: space-between; /* Empurra a seta para a direita */
        align-items: center;
        width: 100%;
        text-align: left;
        background: transparent;
        border: none;
        color: #cbd5e1;
        padding: 8px 16px;
        font-size: 0.75rem;
        cursor: pointer;
        transition: background 0.1s;
    }

        .submenu-btn:hover {
            background: rgba(56, 189, 248, 0.1);
            color: #38bdf8;
        }

    /* O Submenu nasce do lado direito do item pai */
    .submenu-content {
        display: none;
        position: absolute;
        top: 0;
        left: 100%;
        background: rgba(30, 33, 42, 0.98); /* Vidro escuro sólido */
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 4px;
        min-width: 200px;
        box-shadow: 4px 4px 15px rgba(0, 0, 0, 0.5);
        z-index: 10000;
    }

    /* ESCUDO MAGNÉTICO: Uma ponte invisível de 15px para o rato atravessar em segurança */
    .dropdown-submenu::after {
        content: '';
        position: absolute;
        top: 0;
        right: -15px;
        width: 15px;
        height: 100%;
    }

    .dropdown-submenu:hover .submenu-content {
        display: block;
    }

