    private async Task MoverCamada(string nomeCamada, int direcao)
    {
        FecharMenuContexto();
        int index = CamadasAtivas.FindIndex(c => c.Nome == nomeCamada);
        if (index < 0) return;
        int novoIndex = index + direcao;
        if (novoIndex >= 0 && novoIndex < CamadasAtivas.Count)
        {
            var item = CamadasAtivas[index];
            CamadasAtivas.RemoveAt(index); CamadasAtivas.Insert(novoIndex, item);
            var listaOrdenadaNomes = CamadasAtivas.Select(c => c.Nome).ToArray();
            await JSRuntime.InvokeVoidAsync("atualizarOrdemRenderizacao", listaOrdenadaNomes);
            StateHasChanged();
            SincronizarHierarquia();
        }
    }

