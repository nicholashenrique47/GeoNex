    [JSInvokable]
    public void AtualizarCameraJS(double deltaX, double deltaY, double scaleMultiplier)
    {
        // O Javascript fez o movimento suave, e agora passa a matemática consolidada para o C# aplicar
        MapService.CameraPanX = (float)((MapService.CameraPanX * scaleMultiplier) + deltaX);
        MapService.CameraPanY = (float)((MapService.CameraPanY * scaleMultiplier) + deltaY);
        MapService.CameraZoom *= (float)scaleMultiplier;

        SolicitarNovoFrame();
    }

