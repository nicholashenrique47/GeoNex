    // 1. OS BOTÕES DO MENU DE CONTEXTO (Limpos do Javascript)
    private void MoverCamada(string nomeCamada, int direcao)
    {
        FecharMenuContexto();
        int index = CamadasAtivas.FindIndex(c => c.Nome == nomeCamada);
        if (index < 0) return;

        int novoIndex = index + direcao;
        if (novoIndex >= 0 && novoIndex < CamadasAtivas.Count)
        {
            var item = CamadasAtivas[index];

            CamadasAtivas.RemoveAt(index);
            CamadasAtivas.Insert(novoIndex, item);

            // Avisa a placa gráfica e força o ecrã a atualizar
            SincronizarHierarquia();
            StateHasChanged();
        }
    }

    
